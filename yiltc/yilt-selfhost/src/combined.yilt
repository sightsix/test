// ===========================================================================
// Yilt Self-Host Compiler — Combined (Stage 1 + Stage 2 + Stage 5)
// ===========================================================================
// AUTO-GENERATED by scripts/combine_yilt.sh — do not edit directly.
//
// This file is what gets fed to Go-yiltc to produce a native binary that
// can itself compile a subset of Yilt to native ELF binaries.
// ===========================================================================

// ===========================================================================
// SECTION 1: Lexer  (originally stage1/lexer.yilt, main() stripped)
// ===========================================================================
// ===========================================================================
// Yilt Self-Host Compiler — Stage 1: Full Yilt Lexer
// ===========================================================================
//
// A complete lexer for the Yilt programming language, written in Yilt.
// This is the second stage of the self-host bootstrap: it demonstrates
// that Yilt can tokenise its own source code.
//
// Supported tokens:
//   - 29 keywords: let, mut, fn, extern, pub, use, from, for, in, if, but,
//     else, while, match, case, default, return, break, continue, spawn,
//     await, const, assert, struct, enum, and, or, not, true, false, nil
//   - Identifiers: [a-zA-Z_][a-zA-Z0-9_]*
//   - Integer literals: decimal, 0x hex, 0b binary, 0o octal (with _ separators)
//   - Float literals: digits.digits
//   - String literals: "..." with escapes (\n, \t, \", \\, \r, \0)
//   - F-strings: f"...{expr}..." (preserved as a single token)
//   - Char literals: 'c' or '\n'
//   - All operators: + - * / % & | ^ ~ << >> == != < <= > >=
//     = += -= *= /= %= &= |= ^= <<= >>= ? -> . .. ... : , ;
//     ( ) { } [ ] ++ --
//   - Comments: // line and /* block (nested) */
//   - Indentation tokens: INDENT and DEDENT (Python-style, 4-space units)
//
// The lexer produces two parallel arrays (tables):
//   - tokens: integer-keyed table of Token structs
//   - indents: integer-keyed table of Indent structs (level + line)
//
// The output is designed to be byte-for-byte compatible with the Go-based
// yiltc lexer's token stream (modulo diagnostic differences).
//
// ===========================================================================

// ---------------------------------------------------------------------------
// Section 1: Token kinds
// ---------------------------------------------------------------------------
//
// We use integer constants matching the Go lexer's T* enum values, so the
// Yilt-written lexer and the Go-written lexer produce interchangeable token
// streams.  This is critical for Stage 2 (the parser) which will consume
// either.

let T_EOF = 0
let T_IDENT = 1
let T_INT_LIT = 2
let T_FLOAT_LIT = 3
let T_STRING_LIT = 4
let T_NIL = 5

// Keywords
let T_LET = 6
let T_MUT = 7
let T_FN = 8
let T_EXTERN = 9
let T_PUB = 10
let T_USE = 11
let T_FROM = 12
let T_FOR = 13
let T_IN = 14
let T_IF = 15
let T_BUT = 16
let T_ELSE = 17
let T_WHILE = 18
let T_MATCH = 19
let T_CASE = 20
let T_DEFAULT = 21
let T_RETURN = 22
let T_BREAK = 23
let T_CONTINUE = 24
let T_SPAWN = 25
let T_AWAIT = 26
let T_CONST = 27
let T_ASSERT = 28
let T_STRUCT = 29
let T_ENUM = 30

// Operators
let T_PLUS = 31
let T_MINUS = 32
let T_STAR = 33
let T_SLASH = 34
let T_PERCENT = 35
let T_AMP = 36
let T_PIPE = 37
let T_CARET = 38
let T_TILDE = 39
let T_LSHIFT = 40
let T_RSHIFT = 41
let T_EQ = 42          // ==
let T_NEQ = 43         // !=
let T_LT = 44
let T_LE = 45
let T_GT = 46
let T_GE = 47
let T_ASSIGN = 48      // =
let T_PLUS_EQ = 49
let T_MINUS_EQ = 50
let T_STAR_EQ = 51
let T_SLASH_EQ = 52
let T_PERCENT_EQ = 53
let T_AMP_EQ = 54
let T_PIPE_EQ = 55
let T_CARET_EQ = 56
let T_SHL_EQ = 57
let T_SHR_EQ = 58
let T_QUESTION = 59    // ?

// Delimiters
let T_LPAREN = 60      // (
let T_RPAREN = 61      // )
let T_LBRACE = 62      // {
let T_RBRACE = 63      // }
let T_LBRACK = 64      // [
let T_RBRACK = 65      // ]
let T_COMMA = 66       // ,
let T_PERIOD = 67      // .
let T_COLON = 68       // :
let T_DOTDOT = 69      // ..
let T_DOTDOTDOT = 70   // ...
let T_ARROW = 71       // ->

// Increment/decrement
let T_PLUS_PLUS = 72   // ++
let T_MINUS_MINUS = 73 // --

// Literals
let T_TRUE = 74
let T_FALSE = 75
let T_AND = 76         // and
let T_OR = 77          // or
let T_NOT = 78         // not

// Interpolated string (f"...")
let T_INTERP_STR = 79

// Character literal 'c'
let T_CHAR_LIT = 80

// Pseudo-tokens for indentation (not emitted by the Go lexer's token stream
// directly — the Go lexer uses a separate IndentToken array.  For Stage 1
// we fold them into the main token stream to simplify downstream parsing).
let T_INDENT = 81
let T_DEDENT = 82
let T_NEWLINE = 83
let T_SEMICOLON = 84  // ';' — not used by Yilt but emitted for safety

// ---------------------------------------------------------------------------
// Section 2: Data structures
// ---------------------------------------------------------------------------

// A single token.  We use `value` as a string for all literal kinds —
// integer and float literals store their source text (e.g. "0xFF", "3.14"),
// string literals store the (unescaped) content, f-strings store the raw
// content including {expr} segments.  This matches the Go lexer's
// behaviour where `Value` is always a string.
// 256-byte string containing all byte values 0-255.
// Used by byte_to_str to convert byte values to single-character strings.

fn byte_to_str(b int) str
    return ALL_BYTES.substr(b, b + 1)


struct Token
    mut kind int
    mut value str       // source text or literal value
    mut line int        // 1-indexed source line
    mut col int         // 1-indexed source column

// Indentation event: emitted at the start of a line when the indentation
// level changes.  `level` is in 4-space units (0 = no indent, 1 = 4 spaces,
// 2 = 8 spaces, etc.).  A positive jump from the previous line's level
// emits one INDENT token; a drop emits one or more DEDENT tokens.
struct Indent
    mut level int
    mut line int

// Lexer state.  We carry both the source string (for substr extraction)
// and a byte table (for character classification), plus position tracking.
//
// The indentation stack is a table of integers (integer-keyed) representing
// the active indentation levels.  The bottom of the stack is always 0.
// Example: inside a function body that has a nested if-block, the stack is
// {0: 0, 1: 1, 2: 2} (levels 0, 1, 2).  DEDENT pops levels off until we
// reach the target level.
struct Lexer
    mut src str
    mut bytes table
    mut pos int
    mut line int
    mut col int
    mut indent_stack table  // integer-keyed table of indentation levels
    mut indent_depth int    // number of entries in indent_stack
    mut at_line_start bool  // true if we're at the beginning of a logical line
    mut pending_dedents int // number of DEDENT tokens to emit before next token

// ---------------------------------------------------------------------------
// Section 3: Lexer construction and basic accessors
// ---------------------------------------------------------------------------

fn lex_new(source str) Lexer
    let mut l = Lexer{src: source, bytes: source.bytes(), pos: 0, line: 1, col: 1, indent_stack: {}, indent_depth: 1, at_line_start: true, pending_dedents: 0}
    l.indent_stack[0] = 0
    return l

// Returns the byte at the current position, or -1 at EOF.
fn lex_peek(l Lexer) int
    let b = l.bytes
    let pos = l.pos
    if pos >= b.len()
        return -1
    return b[pos]

// Returns the byte at position + n, or -1 if out of range.
fn lex_peek_n(l Lexer, n int) int
    let b = l.bytes
    let pos = l.pos
    let target = pos + n
    if target >= b.len()
        return -1
    return b[target]

// Advance one byte, updating line/col counters.
fn lex_advance(l Lexer)
    let b = l.bytes
    let pos = l.pos
    if pos >= b.len()
        return
    let ch = b[pos]
    l.pos = pos + 1
    if ch == 10  // '\n'
        l.line = l.line + 1
        l.col = 1
    else
        l.col = l.col + 1

// ---------------------------------------------------------------------------
// Section 4: Character classification
// ---------------------------------------------------------------------------
//
// Yilt doesn't expose char literals, so we use byte values directly.
// ASCII codes we care about:
//   '0' = 48, '9' = 57
//   'a' = 97, 'z' = 122
//   'A' = 65, 'Z' = 90
//   '_' = 95
//   ' ' = 32, '\t' = 9, '\n' = 10, '\r' = 13
//   '"' = 34, '\'' = 39
//   '/' = 47, '*' = 42, '+' = 43, '-' = 45
//   '<' = 60, '>' = 62, '=' = 61, '!' = 33
//   '&' = 38, '|' = 124, '^' = 94, '~' = 126
//   '(' = 40, ')' = 41, '{' = 123, '}' = 125
//   '[' = 91, ']' = 93, ',' = 44, '.' = 46
//   ':' = 58, ';' = 59, '?' = 63, '%' = 37

fn is_digit(b int) bool
    return b >= 48 and b <= 57

fn is_hex_digit(b int) bool
    return (b >= 48 and b <= 57) or (b >= 65 and b <= 70) or (b >= 97 and b <= 102)

fn is_alpha(b int) bool
    return (b >= 65 and b <= 90) or (b >= 97 and b <= 122) or b == 95

fn is_alnum(b int) bool
    return is_alpha(b) or is_digit(b)

fn is_space(b int) bool
    return b == 32 or b == 9

fn is_newline(b int) bool
    return b == 10 or b == 13

// ---------------------------------------------------------------------------
// Section 5: Keyword table
// ---------------------------------------------------------------------------

// Maps identifier text to its token kind.  Built once at lexer construction.
// Returns -1 if the text is not a keyword.
fn keyword_kind(text str) int
    if text == "let"
        return T_LET
    if text == "mut"
        return T_MUT
    if text == "fn"
        return T_FN
    if text == "extern"
        return T_EXTERN
    if text == "pub"
        return T_PUB
    if text == "use"
        return T_USE
    if text == "from"
        return T_FROM
    if text == "for"
        return T_FOR
    if text == "in"
        return T_IN
    if text == "if"
        return T_IF
    if text == "but"
        return T_BUT
    if text == "else"
        return T_ELSE
    if text == "while"
        return T_WHILE
    if text == "match"
        return T_MATCH
    if text == "case"
        return T_CASE
    if text == "default"
        return T_DEFAULT
    if text == "return"
        return T_RETURN
    if text == "break"
        return T_BREAK
    if text == "continue"
        return T_CONTINUE
    if text == "spawn"
        return T_SPAWN
    if text == "await"
        return T_AWAIT
    // 'const' removed (D001): everything is immutable by default, `mut` opts in.
    if text == "assert"
        return T_ASSERT
    if text == "struct"
        return T_STRUCT
    if text == "enum"
        return T_ENUM
    if text == "and"
        return T_AND
    if text == "or"
        return T_OR
    if text == "not"
        return T_NOT
    if text == "true"
        return T_TRUE
    if text == "false"
        return T_FALSE
    if text == "nil"
        return T_NIL
    return -1

// ---------------------------------------------------------------------------
// Section 6: Token constructors
// ---------------------------------------------------------------------------

fn make_token(kind int, value str, line int, col int) Token
    let mut t = Token{kind: kind, value: value, line: line, col: col}
    return t

// ---------------------------------------------------------------------------
// Section 7: Indentation handling
// ---------------------------------------------------------------------------
//
// Yilt uses Python-style indentation: blocks are introduced by an increase
// in indentation level (in 4-space units) and terminated by a decrease.
// The lexer emits INDENT tokens when the level increases and DEDENT tokens
// when it decreases.
//
// This function is called at the start of each logical line (after skipping
// blank lines and comments).  It counts leading spaces, computes the new
// indentation level, and updates the indent stack.  It does NOT emit tokens
// directly — instead it sets `pending_dedents` and returns whether an INDENT
// is needed.  The main lex loop calls this and then emits the appropriate
// tokens.
//
// Returns:
//   -1 if this line is blank or comment-only (skip it, no tokens)
//   0 if no indentation change (same level as previous line)
//   1 if indentation increased (emit one INDENT token)
//   The function also sets l.pending_dedents if DEDENT tokens are needed.

fn handle_indent(l Lexer) int
    // Count leading spaces.
    let mut spaces = 0
    while true
        let ch = lex_peek(l)
        if ch == 32  // space
            spaces = spaces + 1
            lex_advance(l)
        but ch == 9  // tab — treat as error but count as 1 for now
            spaces = spaces + 1
            lex_advance(l)
        else
            break
    // Check for blank line or comment-only line.
    let ch = lex_peek(l)
    if ch == -1
        return -1
    if ch == 10  // '\n'
        lex_advance(l)
        l.at_line_start = true
        return -1
    if ch == 13  // '\r'
        lex_advance(l)
        if lex_peek(l) == 10
            lex_advance(l)
        l.at_line_start = true
        return -1
    if ch == 47 and lex_peek_n(l, 1) == 47  // //
        return -1
    if ch == 47 and lex_peek_n(l, 1) == 42  // /*
        return -1
    // Validate 4-space indentation.
    if spaces % 4 != 0
        // For Stage 1 we just round down; the Go lexer emits an error.
        // We'll add proper diagnostics in Stage 2.
        spaces = (spaces / 4) * 4
    let level = spaces / 4
    // Compare with current top of stack.
    let cur_level = l.indent_stack[l.indent_depth - 1]
    if level == cur_level
        return 0
    if level > cur_level
        // Indent: push new level.
        l.indent_stack[l.indent_depth] = level
        l.indent_depth = l.indent_depth + 1
        return 1
    // Dedent: pop levels until we reach `level`.
    let mut count = 0
    while l.indent_depth > 1 and l.indent_stack[l.indent_depth - 1] > level
        l.indent_depth = l.indent_depth - 1
        count = count + 1
    l.pending_dedents = count
    return 0

// ---------------------------------------------------------------------------
// Section 8: Whitespace and comment skipping
// ---------------------------------------------------------------------------

// Skip horizontal whitespace (spaces and tabs) on the current line.
// Does NOT skip newlines — those are handled by the line-start logic.
fn skip_horizontal_ws(l Lexer)
    while true
        let ch = lex_peek(l)
        if ch == 32 or ch == 9
            lex_advance(l)
        else
            break

// Skip a // line comment.  Assumes we're positioned at the first '/'.
// Consumes up to (but not including) the newline.
fn skip_line_comment(l Lexer)
    // Consume '//'
    lex_advance(l)
    lex_advance(l)
    while true
        let ch = lex_peek(l)
        if ch == -1 or ch == 10  // EOF or '\n'
            break
        lex_advance(l)

// Skip a /* block comment (with nesting support).  Assumes we're at the
// first '/'.  Consumes through the matching '*/'.
// Returns true if successfully skipped, false if unterminated.
fn skip_block_comment(l Lexer) bool
    // Consume '/*'
    lex_advance(l)
    lex_advance(l)
    let mut depth = 1
    while depth > 0
        let ch = lex_peek(l)
        if ch == -1
            return false  // unterminated
        if ch == 47 and lex_peek_n(l, 1) == 42  // /*
            lex_advance(l)
            lex_advance(l)
            depth = depth + 1
        but ch == 42 and lex_peek_n(l, 1) == 47  // */
            lex_advance(l)
            lex_advance(l)
            depth = depth - 1
        else
            lex_advance(l)
    return true

// ---------------------------------------------------------------------------
// Section 9: Literal lexing
// ---------------------------------------------------------------------------

// Lex an identifier or keyword.  Assumes we're at the first [a-zA-Z_].
fn lex_identifier(l Lexer) Token
    let line = l.line
    let col = l.col
    let start = l.pos
    while true
        let ch = lex_peek(l)
        if ch == -1 or not is_alnum(ch)
            break
        lex_advance(l)
    let end = l.pos
    let text = l.src.substr(start, end)
    let kw = keyword_kind(text)
    if kw != -1
        return make_token(kw, text, line, col)
    return make_token(T_IDENT, text, line, col)

// Lex a number literal (integer or float, with hex/bin/oct prefixes and
// underscore separators).  Assumes we're at the first digit.
fn lex_number(l Lexer) Token
    let line = l.line
    let col = l.col
    let start = l.pos
    // Check for hex/bin/oct prefix.
    let ch = lex_peek(l)
    if ch == 48  // '0'
        let next = lex_peek_n(l, 1)
        if next == 120 or next == 88  // 'x' or 'X' — hex
            lex_advance(l)  // '0'
            lex_advance(l)  // 'x'
            while true
                let c = lex_peek(l)
                if is_hex_digit(c) or c == 95  // '_'
                    lex_advance(l)
                else
                    break
            let end = l.pos
            return make_token(T_INT_LIT, l.src.substr(start, end), line, col)
        if next == 98 or next == 66  // 'b' or 'B' — binary
            lex_advance(l)
            lex_advance(l)
            while true
                let c = lex_peek(l)
                if c == 48 or c == 49 or c == 95  // '0', '1', '_'
                    lex_advance(l)
                else
                    break
            let end = l.pos
            return make_token(T_INT_LIT, l.src.substr(start, end), line, col)
        if next == 111 or next == 79  // 'o' or 'O' — octal
            lex_advance(l)
            lex_advance(l)
            while true
                let c = lex_peek(l)
                if (c >= 48 and c <= 55) or c == 95  // '0'-'7' or '_'
                    lex_advance(l)
                else
                    break
            let end = l.pos
            return make_token(T_INT_LIT, l.src.substr(start, end), line, col)
    // Decimal integer or float.
    let mut is_float = false
    while true
        let c = lex_peek(l)
        if is_digit(c) or c == 95  // digit or '_'
            lex_advance(l)
        else
            break
    // Check for float: '.' followed by a digit.
    if lex_peek(l) == 46  // '.'
        let after = lex_peek_n(l, 1)
        if is_digit(after)
            is_float = true
            lex_advance(l)  // '.'
            while true
                let c = lex_peek(l)
                if is_digit(c) or c == 95
                    lex_advance(l)
                else
                    break
    let end = l.pos
    let text = l.src.substr(start, end)
    if is_float
        return make_token(T_FLOAT_LIT, text, line, col)
    return make_token(T_INT_LIT, text, line, col)

// Lex a string escape sequence.  Assumes we're at the backslash.
// Returns the decoded character as an integer byte value, or -1 on error.
// Consumes the backslash and the escape character(s).
fn lex_escape(l Lexer) int
    // Consume backslash.
    lex_advance(l)
    let ch = lex_peek(l)
    if ch == -1
        return -1
    lex_advance(l)
    // Common escapes.
    if ch == 110  // 'n'
        return 10  // newline
    if ch == 116  // 't'
        return 9   // tab
    if ch == 114  // 'r'
        return 13  // CR
    if ch == 48   // '0'
        return 0   // null
    if ch == 92   // '\\'
        return 92
    if ch == 34   // '"'
        return 34
    if ch == 39   // '\''
        return 39
    // Unknown escape: return the character literally (lenient).
    return ch

// Lex a string literal "...".  Assumes we're at the opening quote.
// The token's `value` field holds the UNESCAPED content (e.g. for "a\nb",
// value = "a<newline>b").
fn lex_string(l Lexer) Token
    let line = l.line
    let col = l.col
    lex_advance(l)  // consume opening '"'
    let mut content = ""
    while true
        let ch = lex_peek(l)
        if ch == -1 or ch == 10  // EOF or newline
            // Unterminated string — emit what we have so far.
            break
        if ch == 34  // '"'
            lex_advance(l)  // consume closing quote
            break
        if ch == 92  // backslash
            let escaped = lex_escape(l)
            if escaped == -1
                break
            content = content + byte_to_str(escaped)
        else
            content = content + byte_to_str(ch)
            lex_advance(l)
    return make_token(T_STRING_LIT, content, line, col)

// Lex an f-string f"...{expr}...".  Assumes we're at the 'f'.
// The token's `value` field holds the RAW content including {expr} segments
// (the parser will interpret the {expr} parts later).
fn lex_fstring(l Lexer) Token
    let line = l.line
    let col = l.col
    lex_advance(l)  // consume 'f'
    lex_advance(l)  // consume opening '"'
    let mut content = ""
    let mut depth = 0  // brace nesting inside {expr}
    while true
        let ch = lex_peek(l)
        if ch == -1 or ch == 10  // EOF or newline
            break
        if ch == 34 and depth == 0  // closing '"'
            lex_advance(l)
            break
        if ch == 92 and depth == 0  // backslash escape (only outside {expr})
            let escaped = lex_escape(l)
            if escaped == -1
                break
            content = content + byte_to_str(escaped)
        but ch == 123  // '{'
            depth = depth + 1
            content = content + byte_to_str(ch)
            lex_advance(l)
        but ch == 125  // '}'
            if depth > 0
                depth = depth - 1
            content = content + byte_to_str(ch)
            lex_advance(l)
        else
            content = content + byte_to_str(ch)
            lex_advance(l)
    return make_token(T_INTERP_STR, content, line, col)

// Helper for lex_char: process the character after the opening quote.
// Extracted to avoid the parser's nested-if-then-else bug (see Stage 1
// worklog).  Returns the decoded character value as a string.
fn lex_char_inner(l Lexer) str
    let ch = lex_peek(l)
    if ch == 92  // backslash
        let escaped = lex_escape(l)
        if escaped != -1
            return byte_to_str(escaped)
        return ""
    // Non-escape: take the character literally.
    if ch != -1
        let v = byte_to_str(ch)
        lex_advance(l)
        return v
    return ""

// Lex a character literal 'c' or '\n'.  Assumes we're at the opening quote.
fn lex_char(l Lexer) Token
    let line = l.line
    let col = l.col
    lex_advance(l)  // consume opening '\''
    let value = lex_char_inner(l)
    // Expect closing '\''
    if lex_peek(l) == 39
        lex_advance(l)
    return make_token(T_CHAR_LIT, value, line, col)

// ---------------------------------------------------------------------------
// Section 10: Byte-to-string conversion
// ---------------------------------------------------------------------------
//
// Yilt doesn't expose a chr() function or char literals, so we build a
// lookup table of all 256 byte values mapped to single-character strings.
// This is done once at program startup via .
//
// We use the module pattern: a global mutable table held inside a struct
// field, initialised on first use.  Yilt doesn't allow top-level mutable
// globals, so we wrap it in a function that returns the table (initialising
// on first call).


// ---------------------------------------------------------------------------
// Section 11: Operator lexing
// ---------------------------------------------------------------------------
//
// Operators are lexed by peeking at the current character and, where needed,
// the next character to distinguish multi-char operators (e.g. '=' vs '==',
// '<' vs '<=', '<<' vs '<<=').

fn lex_operator(l Lexer) Token
    let line = l.line
    let col = l.col
    let ch = lex_peek(l)
    let next = lex_peek_n(l, 1)
    // Two-character operators (check next char).
    // Three-character operators (... and <<= >>=) checked first.
    if ch == 46 and next == 46  // '..'
        let n2 = lex_peek_n(l, 2)
        if n2 == 46  // '...'
            lex_advance(l)
            lex_advance(l)
            lex_advance(l)
            return make_token(T_DOTDOTDOT, "...", line, col)
        lex_advance(l)
        lex_advance(l)
        return make_token(T_DOTDOT, "..", line, col)
    if ch == 60 and next == 60  // '<<'
        let n2 = lex_peek_n(l, 2)
        if n2 == 61  // '<<='
            lex_advance(l)
            lex_advance(l)
            lex_advance(l)
            return make_token(T_SHL_EQ, "<<=", line, col)
        lex_advance(l)
        lex_advance(l)
        return make_token(T_LSHIFT, "<<", line, col)
    if ch == 62 and next == 62  // '>>'
        let n2 = lex_peek_n(l, 2)
        if n2 == 61  // '>>='
            lex_advance(l)
            lex_advance(l)
            lex_advance(l)
            return make_token(T_SHR_EQ, ">>=", line, col)
        lex_advance(l)
        lex_advance(l)
        return make_token(T_RSHIFT, ">>", line, col)
    if ch == 45 and next == 62  // '->'
        lex_advance(l)
        lex_advance(l)
        return make_token(T_ARROW, "->", line, col)
    if ch == 43 and next == 43  // '++'
        lex_advance(l)
        lex_advance(l)
        return make_token(T_PLUS_PLUS, "++", line, col)
    if ch == 45 and next == 45  // '--'
        lex_advance(l)
        lex_advance(l)
        return make_token(T_MINUS_MINUS, "--", line, col)
    // Two-char ops with '='
    if ch == 61 and next == 61  // '=='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_EQ, "==", line, col)
    if ch == 33 and next == 61  // '!='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_NEQ, "!=", line, col)
    if ch == 60 and next == 61  // '<='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_LE, "<=", line, col)
    if ch == 62 and next == 61  // '>='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_GE, ">=", line, col)
    if ch == 43 and next == 61  // '+='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_PLUS_EQ, "+=", line, col)
    if ch == 45 and next == 61  // '-='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_MINUS_EQ, "-=", line, col)
    if ch == 42 and next == 61  // '*='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_STAR_EQ, "*=", line, col)
    if ch == 47 and next == 61  // '/='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_SLASH_EQ, "/=", line, col)
    if ch == 37 and next == 61  // '%='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_PERCENT_EQ, "%=", line, col)
    if ch == 38 and next == 61  // '&='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_AMP_EQ, "&=", line, col)
    if ch == 124 and next == 61  // '|='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_PIPE_EQ, "|=", line, col)
    if ch == 94 and next == 61  // '^='
        lex_advance(l)
        lex_advance(l)
        return make_token(T_CARET_EQ, "^=", line, col)
    // Single-char operators and delimiters.
    lex_advance(l)
    if ch == 43
        return make_token(T_PLUS, "+", line, col)
    if ch == 45
        return make_token(T_MINUS, "-", line, col)
    if ch == 42
        return make_token(T_STAR, "*", line, col)
    if ch == 47
        return make_token(T_SLASH, "/", line, col)
    if ch == 37
        return make_token(T_PERCENT, "%", line, col)
    if ch == 38
        return make_token(T_AMP, "&", line, col)
    if ch == 124
        return make_token(T_PIPE, "|", line, col)
    if ch == 94
        return make_token(T_CARET, "^", line, col)
    if ch == 126
        return make_token(T_TILDE, "~", line, col)
    if ch == 60
        return make_token(T_LT, "<", line, col)
    if ch == 62
        return make_token(T_GT, ">", line, col)
    if ch == 61
        return make_token(T_ASSIGN, "=", line, col)
    if ch == 63
        return make_token(T_QUESTION, "?", line, col)
    if ch == 40
        return make_token(T_LPAREN, "(", line, col)
    if ch == 41
        return make_token(T_RPAREN, ")", line, col)
    if ch == 123
        return make_token(T_LBRACE, "{", line, col)
    if ch == 125
        return make_token(T_RBRACE, "}", line, col)
    if ch == 91
        return make_token(T_LBRACK, "[", line, col)
    if ch == 93
        return make_token(T_RBRACK, "]", line, col)
    if ch == 44
        return make_token(T_COMMA, ",", line, col)
    if ch == 46
        return make_token(T_PERIOD, ".", line, col)
    if ch == 58
        return make_token(T_COLON, ":", line, col)
    if ch == 59
        return make_token(T_SEMICOLON, ";", line, col)
    // Unknown character — emit as a special token so the parser can report
    // a clean error.  Use kind -1 to signal "unknown".
    return make_token(-1, "?", line, col)

// ---------------------------------------------------------------------------
// Section 12: Main lexing loop
// ---------------------------------------------------------------------------

// Handle the line-start logic: indentation tracking and comment skipping.
// Inline in lex_all — extracted version didn't work because Yilt passes
// tables and ints by value, so mutations to `tokens` and `idx` in a
// helper function were lost.  See Stage 1 worklog for details.

// Lex the entire source.  Returns a table of Token structs (integer-keyed).
// Also produces indentation tokens (INDENT/DEDENT) inline in the stream.
fn lex_all(source str) table
    
    let mut l = lex_new(source)
    let mut tokens = {}
    let mut idx = 0
    let mut done = false
    while not done
        // Handle line start: indentation tracking.
        // We avoid nested if-then-else here because of a parser bug
        // (see test_minimal5.yilt in the worklog).  Instead we use
        // a flat sequence of if-continue blocks.
        if l.at_line_start
            l.at_line_start = false
            let indent_result = handle_indent(l)
            if indent_result == -1
                // Blank or comment-only line.
                let ch2 = lex_peek(l)
                if ch2 == 47
                    let n2 = lex_peek_n(l, 1)
                    if n2 == 47
                        skip_line_comment(l)
                        l.at_line_start = true
                    if n2 == 42
                        skip_block_comment(l)
                        l.at_line_start = true
                continue
            // Emit any pending DEDENT tokens first.
            while l.pending_dedents > 0
                tokens[idx] = make_token(T_DEDENT, "<dedent>", l.line, 1)
                idx = idx + 1
                l.pending_dedents = l.pending_dedents - 1
            // Then emit INDENT if level increased.
            if indent_result == 1
                tokens[idx] = make_token(T_INDENT, "<indent>", l.line, 1)
                idx = idx + 1
        // Check for EOF.
        let ch = lex_peek(l)
        if ch == -1
            // Emit final DEDENT tokens to close any open blocks.
            while l.indent_depth > 1
                l.indent_depth = l.indent_depth - 1
                tokens[idx] = make_token(T_DEDENT, "<dedent>", l.line, 1)
                idx = idx + 1
            tokens[idx] = make_token(T_EOF, "<eof>", l.line, l.col)
            done = true
            continue
        // Skip horizontal whitespace.
        if ch == 32 or ch == 9
            lex_advance(l)
            continue
        // Handle newlines.
        if ch == 10
            lex_advance(l)
            l.at_line_start = true
            continue
        if ch == 13
            lex_advance(l)
            if lex_peek(l) == 10
                lex_advance(l)
            l.at_line_start = true
            continue
        // Handle comments.
        if ch == 47
            let n = lex_peek_n(l, 1)
            if n == 47
                skip_line_comment(l)
                continue
            if n == 42
                skip_block_comment(l)
                continue
        // Handle f-string: identifier 'f' followed by '"'.
        if is_alpha(ch) and ch == 102
            let next = lex_peek_n(l, 1)
            if next == 34
                let tok = lex_fstring(l)
                tokens[idx] = tok
                idx = idx + 1
                continue
        // Identifiers and keywords.
        if is_alpha(ch)
            let tok = lex_identifier(l)
            tokens[idx] = tok
            idx = idx + 1
            continue
        // Numeric literals.
        if is_digit(ch)
            let tok = lex_number(l)
            tokens[idx] = tok
            idx = idx + 1
            continue
        // String literals.
        if ch == 34
            let tok = lex_string(l)
            tokens[idx] = tok
            idx = idx + 1
            continue
        // Char literals.
        if ch == 39
            let tok = lex_char(l)
            tokens[idx] = tok
            idx = idx + 1
            continue
        // Operators and delimiters.
        let tok = lex_operator(l)
        tokens[idx] = tok
        idx = idx + 1
    return tokens

// ---------------------------------------------------------------------------
// Section 13: Token pretty-printing (for testing)
// ---------------------------------------------------------------------------

// Map a token kind to a human-readable name for debug output.
fn token_kind_name(kind int) str
    if kind == T_EOF
        return "EOF"
    if kind == T_IDENT
        return "IDENT"
    if kind == T_INT_LIT
        return "INT"
    if kind == T_FLOAT_LIT
        return "FLOAT"
    if kind == T_STRING_LIT
        return "STRING"
    if kind == T_NIL
        return "nil"
    if kind == T_LET
        return "let"
    if kind == T_MUT
        return "mut"
    if kind == T_FN
        return "fn"
    if kind == T_EXTERN
        return "extern"
    if kind == T_PUB
        return "pub"
    if kind == T_USE
        return "use"
    if kind == T_FROM
        return "from"
    if kind == T_FOR
        return "for"
    if kind == T_IN
        return "in"
    if kind == T_IF
        return "if"
    if kind == T_BUT
        return "but"
    if kind == T_ELSE
        return "else"
    if kind == T_WHILE
        return "while"
    if kind == T_MATCH
        return "match"
    if kind == T_CASE
        return "case"
    if kind == T_DEFAULT
        return "default"
    if kind == T_RETURN
        return "return"
    if kind == T_BREAK
        return "break"
    if kind == T_CONTINUE
        return "continue"
    if kind == T_SPAWN
        return "spawn"
    if kind == T_AWAIT
        return "await"
    if kind == T_CONST
        return "const"
    if kind == T_ASSERT
        return "assert"
    if kind == T_STRUCT
        return "struct"
    if kind == T_ENUM
        return "enum"
    if kind == T_PLUS
        return "+"
    if kind == T_MINUS
        return "-"
    if kind == T_STAR
        return "*"
    if kind == T_SLASH
        return "/"
    if kind == T_PERCENT
        return "%"
    if kind == T_AMP
        return "&"
    if kind == T_PIPE
        return "|"
    if kind == T_CARET
        return "^"
    if kind == T_TILDE
        return "~"
    if kind == T_LSHIFT
        return "<<"
    if kind == T_RSHIFT
        return ">>"
    if kind == T_EQ
        return "=="
    if kind == T_NEQ
        return "!="
    if kind == T_LT
        return "<"
    if kind == T_LE
        return "<="
    if kind == T_GT
        return ">"
    if kind == T_GE
        return ">="
    if kind == T_ASSIGN
        return "="
    if kind == T_PLUS_EQ
        return "+="
    if kind == T_MINUS_EQ
        return "-="
    if kind == T_STAR_EQ
        return "*="
    if kind == T_SLASH_EQ
        return "/="
    if kind == T_PERCENT_EQ
        return "%="
    if kind == T_AMP_EQ
        return "&="
    if kind == T_PIPE_EQ
        return "|="
    if kind == T_CARET_EQ
        return "^="
    if kind == T_SHL_EQ
        return "<<="
    if kind == T_SHR_EQ
        return ">>="
    if kind == T_QUESTION
        return "?"
    if kind == T_LPAREN
        return "("
    if kind == T_RPAREN
        return ")"
    if kind == T_LBRACE
        return "{"
    if kind == T_RBRACE
        return "}"
    if kind == T_LBRACK
        return "["
    if kind == T_RBRACK
        return "]"
    if kind == T_COMMA
        return ","
    if kind == T_PERIOD
        return "."
    if kind == T_COLON
        return ":"
    if kind == T_DOTDOT
        return ".."
    if kind == T_DOTDOTDOT
        return "..."
    if kind == T_ARROW
        return "->"
    if kind == T_PLUS_PLUS
        return "++"
    if kind == T_MINUS_MINUS
        return "--"
    if kind == T_TRUE
        return "true"
    if kind == T_FALSE
        return "false"
    if kind == T_AND
        return "and"
    if kind == T_OR
        return "or"
    if kind == T_NOT
        return "not"
    if kind == T_INTERP_STR
        return "FSTRING"
    if kind == T_CHAR_LIT
        return "CHAR"
    if kind == T_INDENT
        return "INDENT"
    if kind == T_DEDENT
        return "DEDENT"
    if kind == T_NEWLINE
        return "NEWLINE"
    if kind == T_SEMICOLON
        return ";"
    return "UNKNOWN"


// ===========================================================================
// SECTION 2: Parser  (originally stage2/parser.yilt, T_*/Token/main stripped)
// ===========================================================================
// --- skipped stage2 lines 1-111 (T_* constants + Token struct: duplicates of stage1)

// AST node.  Uses a tagged-union-via-struct pattern (like C).
// `kind` is the discriminator.  Other fields are used depending on kind:
//   - sval: string values (names, operators, literal text)
//   - ival: integer values
//   - bval: boolean flags (pub, mutable)
//   - a, b, c: single children wrapped as {0: Node}
//   - list: integer-keyed table of Node (body, params, args, entries)
//   - extra: miscellaneous data (ret_type string, etc.)
struct Node
    mut kind str
    mut sval str
    mut ival int
    mut bval bool
    mut a table
    mut b table
    mut c table
    mut list table
    mut extra str

struct Parser
    mut tokens table
    mut pos int
    mut ntokens int
    mut errors table
    mut nerrors int

struct ParseResult
    mut decls table
    mut errors table
    mut nerrors int

// ---------------------------------------------------------------------------
// Section 3: Node constructors
// ---------------------------------------------------------------------------

fn n_str(kind str, sval str) Node
    let mut n = Node{kind: kind, sval: sval, ival: 0, bval: false, a: {}, b: {}, c: {}, list: {}, extra: ""}
    return n

fn n_kind(kind str) Node
    let mut n = Node{kind: kind, sval: "", ival: 0, bval: false, a: {}, b: {}, c: {}, list: {}, extra: ""}
    return n

fn n_binary(op str, left Node, right Node) Node
    let mut la = {}
    la[0] = left
    let mut rb = {}
    rb[0] = right
    let mut n = Node{kind: "binary", sval: op, ival: 0, bval: false, a: la, b: rb, c: {}, list: {}, extra: ""}
    return n

fn n_unary(op str, operand Node) Node
    let mut oa = {}
    oa[0] = operand
    let mut n = Node{kind: "unary", sval: op, ival: 0, bval: false, a: oa, b: {}, c: {}, list: {}, extra: ""}
    return n

fn n_call(func Node, args table) Node
    let mut fa = {}
    fa[0] = func
    let mut n = Node{kind: "call", sval: "", ival: 0, bval: false, a: fa, b: {}, c: {}, list: args, extra: ""}
    return n

fn n_member(obj Node, field str) Node
    let mut oa = {}
    oa[0] = obj
    let mut n = Node{kind: "member", sval: field, ival: 0, bval: false, a: oa, b: {}, c: {}, list: {}, extra: ""}
    return n

fn n_index(obj Node, index Node) Node
    let mut oa = {}
    oa[0] = obj
    let mut ib = {}
    ib[0] = index
    let mut n = Node{kind: "index", sval: "", ival: 0, bval: false, a: oa, b: ib, c: {}, list: {}, extra: ""}
    return n

// ---------------------------------------------------------------------------
// Section 4: Parser construction and token access
// ---------------------------------------------------------------------------

fn parser_new(tokens table) Parser
    let mut p = Parser{tokens: tokens, pos: 0, ntokens: tokens.len(), errors: {}, nerrors: 0}
    return p

fn p_peek(p Parser) Token
    if p.pos >= p.ntokens
        return Token{kind: T_EOF, value: "<eof>", line: 0, col: 0}
    return p.tokens[p.pos]

fn p_peek_kind(p Parser) int
    let t = p_peek(p)
    return t.kind

fn p_advance(p Parser) Token
    let t = p_peek(p)
    p.pos = p.pos + 1
    return t

fn p_at(p Parser, kind int) bool
    return p_peek_kind(p) == kind

fn p_expect(p Parser, kind int, what str) Token
    if p_at(p, kind)
        return p_advance(p)
    p_error(p, "expected " + what)
    return Token{kind: T_EOF, value: "<eof>", line: 0, col: 0}

fn p_skip_indent(p Parser)
    let mut done = false
    while not done
        if p_at(p, T_INDENT) or p_at(p, T_NEWLINE)
            p_advance(p)
        if not p_at(p, T_INDENT) and not p_at(p, T_NEWLINE)
            done = true

// p_skip_all_indent skips INDENT, DEDENT, and NEWLINE — use only between
// top-level declarations where block structure doesn't matter.
fn p_skip_all_indent(p Parser)
    let mut done = false
    while not done
        if p_at(p, T_INDENT) or p_at(p, T_DEDENT) or p_at(p, T_NEWLINE)
            p_advance(p)
        if not p_at(p, T_INDENT) and not p_at(p, T_DEDENT) and not p_at(p, T_NEWLINE)
            done = true

fn p_error(p Parser, msg str)
    let t = p_peek(p)
    let mut m = "["
    m = m + int_to_str(t.line)
    m = m + ":"
    m = m + int_to_str(t.col)
    m = m + "] "
    m = m + msg
    p.errors[p.nerrors] = m
    p.nerrors = p.nerrors + 1

let g_printable = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

fn int_to_str(n int) str
    if n == 0
        return "0"
    let mut neg = false
    let mut v = n
    if v < 0
        neg = true
        v = -v
    let mut digits = ""
    while v > 0
        let d = v % 10
        let ch = g_printable.substr(d + 48 - 32, d + 49 - 32)
        digits = ch + digits
        v = v / 10
    if neg
        digits = "-" + digits
    return digits

// ---------------------------------------------------------------------------
// Section 5: Declaration parsing
// ---------------------------------------------------------------------------

fn parse_decl(p Parser) Node
    p_skip_all_indent(p)
    let kind = p_peek_kind(p)
    if kind == T_PUB
        p_advance(p)
        return parse_pub_decl(p)
    if kind == T_FN
        return parse_fn_decl(p, false)
    if kind == T_EXTERN
        return parse_extern_decl(p)
    if kind == T_STRUCT
        return parse_struct_decl(p, false)
    if kind == T_ENUM
        return parse_enum_decl(p, false)
    if kind == T_LET
        return parse_top_let(p)
    // 'const' removed (D001): top-level `let` handles constant bindings.
    if kind == T_USE
        return parse_use_decl(p)
    if kind == T_FROM
        return parse_from_decl(p)
    if kind == T_EOF
        return n_kind("eof")
    p_error(p, "unexpected token in declaration")
    p_advance(p)
    return n_kind("error")

fn parse_pub_decl(p Parser) Node
    let kind = p_peek_kind(p)
    if kind == T_FN
        return parse_fn_decl(p, true)
    if kind == T_STRUCT
        return parse_struct_decl(p, true)
    if kind == T_ENUM
        return parse_enum_decl(p, true)
    p_error(p, "expected fn/struct/enum after pub")
    return n_kind("error")

fn parse_fn_decl(p Parser, is_pub bool) Node
    p_expect(p, T_FN, "'fn'")
    let name_tok = p_expect(p, T_IDENT, "function name")
    let mut type_params = {}
    if p_at(p, T_LBRACK)
        p_advance(p)
        let mut idx = 0
        let mut done = false
        while not done
            if p_at(p, T_RBRACK) or p_at(p, T_EOF)
                done = true
            if not done
                if idx > 0
                    p_expect(p, T_COMMA, "','")
                let tp = p_expect(p, T_IDENT, "type param")
                type_params[idx] = tp.value
                idx = idx + 1
        p_expect(p, T_RBRACK, "']'")
    p_expect(p, T_LPAREN, "'('")
    let params = parse_params(p)
    p_expect(p, T_RPAREN, "')'")
    let mut ret_type = ""
    if p_at(p, T_IDENT)
        let rt = p_advance(p)
        ret_type = rt.value
    let body = parse_block(p)
    let mut n = Node{kind: "fn_decl", sval: name_tok.value, ival: 0, bval: is_pub, a: {}, b: {}, c: {}, list: {}, extra: ret_type}
    n.list = body
    n.a = params
    n.b = type_params
    return n

fn parse_extern_decl(p Parser) Node
    p_expect(p, T_EXTERN, "'extern'")
    p_expect(p, T_FN, "'fn'")
    let name_tok = p_expect(p, T_IDENT, "function name")
    p_expect(p, T_LPAREN, "'('")
    let params = parse_params(p)
    p_expect(p, T_RPAREN, "')'")
    let mut ret_type = ""
    if p_at(p, T_IDENT)
        let rt = p_advance(p)
        ret_type = rt.value
    let mut n = Node{kind: "extern_decl", sval: name_tok.value, ival: 0, bval: false, a: params, b: {}, c: {}, list: {}, extra: ret_type}
    return n

fn parse_params(p Parser) table
    let mut params = {}
    let mut idx = 0
    let mut done = false
    while not done
        if p_at(p, T_RPAREN) or p_at(p, T_EOF)
            done = true
        if not done
            if idx > 0
                p_expect(p, T_COMMA, "','")
            let mut mutable = false
            if p_at(p, T_MUT)
                p_advance(p)
                mutable = true
            let name_tok = p_expect(p, T_IDENT, "parameter name")
            let mut ptype = ""
            let mut variadic = false
            if p_at(p, T_DOTDOTDOT)
                p_advance(p)
                variadic = true
            if p_at(p, T_IDENT)
                let tt = p_advance(p)
                ptype = tt.value
            let mut default_expr = n_kind("nil")
            let mut has_default = false
            if p_at(p, T_ASSIGN)
                p_advance(p)
                default_expr = parse_expr(p)
                has_default = true
            let mut param = Node{kind: "param", sval: name_tok.value, ival: 0, bval: mutable, a: {}, b: {}, c: {}, list: {}, extra: ptype}
            if variadic
                param.bval = true
            if has_default
                let mut da = {}
                da[0] = default_expr
                param.a = da
            params[idx] = param
            idx = idx + 1
    return params

fn parse_struct_decl(p Parser, is_pub bool) Node
    p_expect(p, T_STRUCT, "'struct'")
    let name_tok = p_expect(p, T_IDENT, "struct name")
    let fields = parse_struct_body(p)
    let mut n = Node{kind: "struct_decl", sval: name_tok.value, ival: 0, bval: is_pub, a: {}, b: {}, c: {}, list: fields, extra: ""}
    return n

// parse_struct_body parses a struct body: a sequence of field declarations,
// each of the form `[mut] name type`.  Fields are separated by newlines.
// Returns a table of Node (kind="field") indexed by integer.
fn parse_struct_body(p Parser) table
    let mut fields = {}
    let mut idx = 0
    if p_at(p, T_INDENT)
        p_advance(p)
    let mut done = false
    while not done
        p_skip_indent(p)
        if p_at(p, T_DEDENT) or p_at(p, T_EOF)
            done = true
        if not done
            // Parse: [mut] name type
            let mut mutable = false
            if p_at(p, T_MUT)
                p_advance(p)
                mutable = true
            let name_tok = p_expect(p, T_IDENT, "field name")
            let mut ftype = ""
            if p_at(p, T_IDENT)
                let tt = p_advance(p)
                ftype = tt.value
            let mut n = Node{kind: "field", sval: name_tok.value, ival: 0, bval: mutable, a: {}, b: {}, c: {}, list: {}, extra: ftype}
            fields[idx] = n
            idx = idx + 1
    if p_at(p, T_DEDENT)
        p_advance(p)
    return fields

fn parse_enum_decl(p Parser, is_pub bool) Node
    p_expect(p, T_ENUM, "'enum'")
    let name_tok = p_expect(p, T_IDENT, "enum name")
    let variants = parse_block(p)
    let mut n = Node{kind: "enum_decl", sval: name_tok.value, ival: 0, bval: is_pub, a: {}, b: {}, c: {}, list: variants, extra: ""}
    return n

fn parse_top_let(p Parser) Node
    p_expect(p, T_LET, "'let'")
    let mut mutable = false
    if p_at(p, T_MUT)
        p_advance(p)
        mutable = true
    let name_tok = p_expect(p, T_IDENT, "variable name")
    let mut vtype = ""
    if p_at(p, T_IDENT)
        let tt = p_advance(p)
        vtype = tt.value
    p_expect(p, T_ASSIGN, "'='")
    let value = parse_expr(p)
    let mut va = {}
    va[0] = value
    let mut n = Node{kind: "let_decl", sval: name_tok.value, ival: 0, bval: mutable, a: va, b: {}, c: {}, list: {}, extra: vtype}
    return n

fn parse_top_const(p Parser) Node
    p_expect(p, T_CONST, "'const'")
    let name_tok = p_expect(p, T_IDENT, "const name")
    p_expect(p, T_ASSIGN, "'='")
    let value = parse_expr(p)
    let mut va = {}
    va[0] = value
    let mut n = Node{kind: "const_decl", sval: name_tok.value, ival: 0, bval: false, a: va, b: {}, c: {}, list: {}, extra: ""}
    return n

fn parse_use_decl(p Parser) Node
    p_expect(p, T_USE, "'use'")
    let mod_tok = p_expect(p, T_IDENT, "module name")
    let mut alias = mod_tok.value
    if p_at(p, T_IDENT)
        let as_tok = p_advance(p)
        if as_tok.value == "as"
            let a = p_expect(p, T_IDENT, "alias")
            alias = a.value
    let mut n = Node{kind: "use_decl", sval: mod_tok.value, ival: 0, bval: false, a: {}, b: {}, c: {}, list: {}, extra: alias}
    return n

fn parse_from_decl(p Parser) Node
    p_expect(p, T_FROM, "'from'")
    let mod_tok = p_expect(p, T_IDENT, "module name")
    p_expect(p, T_USE, "'use'")
    let mut syms = {}
    let mut idx = 0
    let mut done = false
    while not done
        if not p_at(p, T_IDENT)
            done = true
        if not done
            let s = p_advance(p)
            let mut alias = s.value
            if p_at(p, T_IDENT)
                let as_tok = p_advance(p)
                if as_tok.value == "as"
                    let a = p_expect(p, T_IDENT, "alias")
                    alias = a.value
            let mut sym = Node{kind: "sym", sval: s.value, ival: 0, bval: false, a: {}, b: {}, c: {}, list: {}, extra: alias}
            syms[idx] = sym
            idx = idx + 1
            if p_at(p, T_COMMA)
                p_advance(p)
    let mut n = Node{kind: "from_decl", sval: mod_tok.value, ival: 0, bval: false, a: {}, b: {}, c: {}, list: syms, extra: ""}
    return n

// ---------------------------------------------------------------------------
// Section 6: Block and statement parsing
// ---------------------------------------------------------------------------

fn parse_block(p Parser) table
    let mut stmts = {}
    let mut idx = 0
    if p_at(p, T_INDENT)
        p_advance(p)
    let mut done = false
    while not done
        p_skip_indent(p)
        if p_at(p, T_DEDENT) or p_at(p, T_EOF)
            done = true
        if not done
            let s = parse_stmt(p)
            stmts[idx] = s
            idx = idx + 1
    if p_at(p, T_DEDENT)
        p_advance(p)
    return stmts

fn parse_stmt(p Parser) Node
    let kind = p_peek_kind(p)
    if kind == T_LET
        return parse_let_stmt(p)
    if kind == T_RETURN
        return parse_return_stmt(p)
    if kind == T_IF
        return parse_if_stmt(p)
    if kind == T_WHILE
        return parse_while_stmt(p)
    if kind == T_FOR
        return parse_for_stmt(p)
    if kind == T_MATCH
        return parse_match_stmt(p)
    if kind == T_BREAK
        p_advance(p)
        return n_kind("break")
    if kind == T_CONTINUE
        p_advance(p)
        return n_kind("continue")
    if kind == T_ASSERT
        return parse_assert_stmt(p)
    if kind == T_PUB
        p_advance(p)
        return parse_fn_decl(p, true)
    if kind == T_FN
        return parse_fn_decl(p, false)
    let e = parse_expr(p)
    if p_at(p, T_ASSIGN)
        p_advance(p)
        let val = parse_expr(p)
        let mut ea = {}
        ea[0] = e
        let mut va = {}
        va[0] = val
        let mut n = Node{kind: "assign", sval: "", ival: 0, bval: false, a: ea, b: va, c: {}, list: {}, extra: ""}
        return n
    let mut ea = {}
    ea[0] = e
    let mut n = Node{kind: "expr_stmt", sval: "", ival: 0, bval: false, a: ea, b: {}, c: {}, list: {}, extra: ""}
    return n

fn parse_let_stmt(p Parser) Node
    p_expect(p, T_LET, "'let'")
    let mut mutable = false
    if p_at(p, T_MUT)
        p_advance(p)
        mutable = true
    if p_at(p, T_LPAREN)
        p_advance(p)
        let mut names = {}
        let mut idx = 0
        let mut done = false
        while not done
            if p_at(p, T_RPAREN) or p_at(p, T_EOF)
                done = true
            if not done
                if idx > 0
                    p_expect(p, T_COMMA, "','")
                    if p_at(p, T_RPAREN)
                        done = true
                if not done
                    let nt = p_expect(p, T_IDENT, "variable name")
                    names[idx] = nt.value
                    idx = idx + 1
        p_expect(p, T_RPAREN, "')'")
        p_expect(p, T_ASSIGN, "'='")
        let value = parse_expr(p)
        let mut va = {}
        va[0] = value
        let mut n = Node{kind: "let_tuple", sval: "", ival: 0, bval: mutable, a: va, b: {}, c: {}, list: names, extra: ""}
        return n
    let name_tok = p_expect(p, T_IDENT, "variable name")
    let mut vtype = ""
    if p_at(p, T_IDENT)
        let tt = p_advance(p)
        vtype = tt.value
    p_expect(p, T_ASSIGN, "'='")
    let value = parse_expr(p)
    let mut va = {}
    va[0] = value
    let mut n = Node{kind: "let_stmt", sval: name_tok.value, ival: 0, bval: mutable, a: va, b: {}, c: {}, list: {}, extra: vtype}
    return n

fn parse_return_stmt(p Parser) Node
    p_expect(p, T_RETURN, "'return'")
    let k = p_peek_kind(p)
    if k == T_DEDENT or k == T_EOF or k == T_INDENT
        return n_kind("return")
    if k == T_INT_LIT or k == T_FLOAT_LIT or k == T_STRING_LIT or k == T_IDENT or k == T_LPAREN or k == T_TRUE or k == T_FALSE or k == T_NIL or k == T_MINUS or k == T_NOT or k == T_LBRACE or k == T_LBRACK or k == T_IF or k == T_MATCH
        let val = parse_expr(p)
        let mut va = {}
        va[0] = val
        let mut n = Node{kind: "return", sval: "", ival: 0, bval: false, a: va, b: {}, c: {}, list: {}, extra: ""}
        return n
    return n_kind("return")

fn parse_if_stmt(p Parser) Node
    p_expect(p, T_IF, "'if'")
    let cond = parse_expr(p)
    let then_block = parse_block(p)
    let mut branches = {}
    let mut b0 = {}
    b0[0] = cond
    branches[0] = make_branch(b0, then_block)
    let mut nbranches = 1
    let mut else_block = {}
    let mut done = false
    while not done
        let k = p_peek_kind(p)
        if k == T_BUT
            p_advance(p)
            let c = parse_expr(p)
            let b = parse_block(p)
            let mut cb = {}
            cb[0] = c
            branches[nbranches] = make_branch(cb, b)
            nbranches = nbranches + 1
        but k == T_ELSE
            p_advance(p)
            else_block = parse_block(p)
            done = true
        else
            done = true
    let mut n = Node{kind: "if_stmt", sval: "", ival: 0, bval: false, a: {}, b: {}, c: {}, list: branches, extra: ""}
    n.a = else_block
    return n

fn make_branch(cond table, block table) Node
    let mut n = Node{kind: "branch", sval: "", ival: 0, bval: false, a: cond, b: block, c: {}, list: {}, extra: ""}
    return n

fn parse_while_stmt(p Parser) Node
    p_expect(p, T_WHILE, "'while'")
    let cond = parse_expr(p)
    let body = parse_block(p)
    let mut ca = {}
    ca[0] = cond
    let mut n = Node{kind: "while_stmt", sval: "", ival: 0, bval: false, a: ca, b: {}, c: {}, list: body, extra: ""}
    return n

fn parse_for_stmt(p Parser) Node
    p_expect(p, T_FOR, "'for'")
    let key_tok = p_expect(p, T_IDENT, "loop variable")
    let mut val_name = ""
    if p_at(p, T_COMMA)
        p_advance(p)
        let v = p_expect(p, T_IDENT, "value variable")
        val_name = v.value
    p_expect(p, T_IN, "'in'")
    let low = parse_expr(p)
    let mut is_range = false
    let mut high = n_kind("empty")
    if p_at(p, T_DOTDOT)
        is_range = true
        p_advance(p)
        high = parse_expr(p)
    let body = parse_block(p)
    let mut ia = {}
    ia[0] = low
    let mut rb = {}
    if is_range
        rb[0] = high
    let mut n = Node{kind: "for_stmt", sval: key_tok.value, ival: 0, bval: is_range, a: ia, b: rb, c: {}, list: body, extra: val_name}
    return n

fn parse_match_stmt(p Parser) Node
    p_expect(p, T_MATCH, "'match'")
    let subj = parse_expr(p)
    let mut cases = {}
    let mut idx = 0
    let mut default_block = {}
    if p_at(p, T_INDENT)
        p_advance(p)
    let mut done = false
    while not done
        p_skip_indent(p)
        if p_at(p, T_DEDENT) or p_at(p, T_EOF)
            done = true
        if not done
            if p_at(p, T_CASE)
                p_advance(p)
                let pat = parse_expr(p)
                let body = parse_block(p)
                let mut pa = {}
                pa[0] = pat
                let mut c = Node{kind: "case", sval: "", ival: 0, bval: false, a: pa, b: body, c: {}, list: {}, extra: ""}
                cases[idx] = c
                idx = idx + 1
            if p_at(p, T_DEFAULT)
                p_advance(p)
                default_block = parse_block(p)
    if p_at(p, T_DEDENT)
        p_advance(p)
    let mut sa = {}
    sa[0] = subj
    let mut n = Node{kind: "match_stmt", sval: "", ival: 0, bval: false, a: sa, b: default_block, c: {}, list: cases, extra: ""}
    return n

fn parse_assert_stmt(p Parser) Node
    p_expect(p, T_ASSERT, "'assert'")
    let cond = parse_expr(p)
    let mut msg = n_kind("nil")
    if p_at(p, T_COMMA)
        p_advance(p)
        msg = parse_expr(p)
    let mut ca = {}
    ca[0] = cond
    let mut ma = {}
    ma[0] = msg
    let mut n = Node{kind: "assert_stmt", sval: "", ival: 0, bval: false, a: ca, b: ma, c: {}, list: {}, extra: ""}
    return n

// ---------------------------------------------------------------------------
// Section 7: Pratt expression parser
// ---------------------------------------------------------------------------

fn parse_expr(p Parser) Node
    return parse_or(p)

fn parse_or(p Parser) Node
    let mut left = parse_and(p)
    while p_at(p, T_OR)
        p_advance(p)
        let right = parse_and(p)
        left = n_binary("or", left, right)
    return left

fn parse_and(p Parser) Node
    let mut left = parse_bitor(p)
    while p_at(p, T_AND)
        p_advance(p)
        let right = parse_bitor(p)
        left = n_binary("and", left, right)
    return left

// parse_bitor: bitwise OR (|) — lower precedence than logical and, higher than xor
fn parse_bitor(p Parser) Node
    let mut left = parse_bitxor(p)
    let mut done = false
    while not done
        if p_at(p, T_PIPE)
            p_advance(p)
            left = n_binary("|", left, parse_bitxor(p))
        if not p_at(p, T_PIPE)
            done = true
    return left

// parse_bitxor: bitwise XOR (^)
fn parse_bitxor(p Parser) Node
    let mut left = parse_bitand(p)
    let mut done = false
    while not done
        if p_at(p, T_CARET)
            p_advance(p)
            left = n_binary("^", left, parse_bitand(p))
        if not p_at(p, T_CARET)
            done = true
    return left

// parse_bitand: bitwise AND (&)
fn parse_bitand(p Parser) Node
    let mut left = parse_eq(p)
    let mut done = false
    while not done
        if p_at(p, T_AMP)
            p_advance(p)
            left = n_binary("&", left, parse_eq(p))
        if not p_at(p, T_AMP)
            done = true
    return left

fn parse_eq(p Parser) Node
    let mut left = parse_cmp(p)
    let mut done = false
    while not done
        let k = p_peek_kind(p)
        if k == T_EQ
            p_advance(p)
            let right = parse_cmp(p)
            left = n_binary("==", left, right)
        if k == T_NEQ
            p_advance(p)
            let right = parse_cmp(p)
            left = n_binary("!=", left, right)
        if k != T_EQ and k != T_NEQ
            done = true
    return left

fn parse_cmp(p Parser) Node
    let mut left = parse_shift(p)
    let mut done = false
    while not done
        let k = p_peek_kind(p)
        if k == T_LT
            p_advance(p)
            left = n_binary("<", left, parse_shift(p))
        if k == T_LE
            p_advance(p)
            left = n_binary("<=", left, parse_shift(p))
        if k == T_GT
            p_advance(p)
            left = n_binary(">", left, parse_shift(p))
        if k == T_GE
            p_advance(p)
            left = n_binary(">=", left, parse_shift(p))
        if k != T_LT and k != T_LE and k != T_GT and k != T_GE
            done = true
    return left

// parse_shift: left shift (<<) and right shift (>>)
fn parse_shift(p Parser) Node
    let mut left = parse_add(p)
    let mut done = false
    while not done
        let k = p_peek_kind(p)
        if k == T_LSHIFT
            p_advance(p)
            left = n_binary("<<", left, parse_add(p))
        if k == T_RSHIFT
            p_advance(p)
            left = n_binary(">>", left, parse_add(p))
        if k != T_LSHIFT and k != T_RSHIFT
            done = true
    return left

fn parse_add(p Parser) Node
    let mut left = parse_mul(p)
    let mut done = false
    while not done
        let k = p_peek_kind(p)
        if k == T_PLUS
            p_advance(p)
            left = n_binary("+", left, parse_mul(p))
        if k == T_MINUS
            p_advance(p)
            left = n_binary("-", left, parse_mul(p))
        if k != T_PLUS and k != T_MINUS
            done = true
    return left

fn parse_mul(p Parser) Node
    let mut left = parse_unary(p)
    let mut done = false
    while not done
        let k = p_peek_kind(p)
        if k == T_STAR
            p_advance(p)
            left = n_binary("*", left, parse_unary(p))
        if k == T_SLASH
            p_advance(p)
            left = n_binary("/", left, parse_unary(p))
        if k == T_PERCENT
            p_advance(p)
            left = n_binary("%", left, parse_unary(p))
        if k != T_STAR and k != T_SLASH and k != T_PERCENT
            done = true
    return left

fn parse_unary(p Parser) Node
    let k = p_peek_kind(p)
    if k == T_MINUS
        p_advance(p)
        return n_unary("-", parse_unary(p))
    if k == T_NOT
        p_advance(p)
        return n_unary("not", parse_unary(p))
    if k == T_TILDE
        p_advance(p)
        return n_unary("~", parse_unary(p))
    return parse_postfix(p)

fn parse_postfix(p Parser) Node
    let mut e = parse_primary(p)
    let mut done = false
    while not done
        let k = p_peek_kind(p)
        if k == T_PERIOD
            p_advance(p)
            let field = p_expect(p, T_IDENT, "field name")
            e = n_member(e, field.value)
        if k == T_LBRACK
            p_advance(p)
            // Check if this is a generic type argument list: ident, ident, ... ] (
            let mut is_generic = false
            if e.kind == "ident"
                let save_pos = p.pos
                let mut looks_generic = true
                let mut first = true
                while p_at(p, T_IDENT) or (not first and p_at(p, T_COMMA))
                    if not first
                        if not p_at(p, T_COMMA)
                            looks_generic = false
                        p_advance(p)
                    if not p_at(p, T_IDENT)
                        looks_generic = false
                    if looks_generic
                        p_advance(p)
                    first = false
                if p_at(p, T_RBRACK) and looks_generic
                    p_advance(p)
                    if p_at(p, T_LPAREN)
                        is_generic = true
                p.pos = save_pos
            if is_generic
                let mut done2 = false
                while not done2
                    if p_at(p, T_RBRACK)
                        done2 = true
                    if not done2
                        p_advance(p)
                p_advance(p)
            if not is_generic
                let index = parse_expr(p)
                p_expect(p, T_RBRACK, "']'")
                e = n_index(e, index)
        if k == T_LPAREN
            p_advance(p)
            let args = parse_args(p)
            p_expect(p, T_RPAREN, "')'")
            e = n_call(e, args)
        if k == T_QUESTION
            p_advance(p)
            let mut ea = {}
            ea[0] = e
            let mut n = Node{kind: "error_prop", sval: "", ival: 0, bval: false, a: ea, b: {}, c: {}, list: {}, extra: ""}
            e = n
        if k == T_LBRACE
            if e.kind == "ident"
                e = parse_struct_lit(p, e.sval)
            if e.kind != "ident"
                done = true
        if k != T_PERIOD and k != T_LBRACK and k != T_LPAREN and k != T_QUESTION and k != T_LBRACE
            done = true
    return e

fn parse_struct_lit(p Parser, type_name str) Node
    p_expect(p, T_LBRACE, "'{'")
    let mut fields = {}
    let mut idx = 0
    let mut done = false
    while not done
        if p_at(p, T_RBRACE) or p_at(p, T_EOF)
            done = true
        if not done
            if idx > 0
                p_expect(p, T_COMMA, "','")
            if p_at(p, T_RBRACE)
                done = true
            if not done
                let name_tok = p_expect(p, T_IDENT, "field name")
                p_expect(p, T_COLON, "':'")
                let val = parse_expr(p)
                let mut va = {}
                va[0] = val
                let mut f = Node{kind: "field_init", sval: name_tok.value, ival: 0, bval: false, a: va, b: {}, c: {}, list: {}, extra: ""}
                fields[idx] = f
                idx = idx + 1
    p_expect(p, T_RBRACE, "'}'")
    let mut n = Node{kind: "struct_lit", sval: type_name, ival: 0, bval: false, a: {}, b: {}, c: {}, list: fields, extra: ""}
    return n

fn parse_args(p Parser) table
    let mut args = {}
    let mut idx = 0
    let mut done = false
    while not done
        if p_at(p, T_RPAREN) or p_at(p, T_EOF)
            done = true
        if not done
            if idx > 0
                p_expect(p, T_COMMA, "','")
            if p_at(p, T_DOTDOTDOT)
                p_advance(p)
            args[idx] = parse_expr(p)
            idx = idx + 1
    return args

fn parse_primary(p Parser) Node
    let tok = p_peek(p)
    let k = tok.kind
    if k == T_INT_LIT
        p_advance(p)
        return n_str("int_lit", tok.value)
    if k == T_FLOAT_LIT
        p_advance(p)
        return n_str("float_lit", tok.value)
    if k == T_STRING_LIT
        p_advance(p)
        return n_str("string_lit", tok.value)
    if k == T_INTERP_STR
        p_advance(p)
        return n_str("interp_str", tok.value)
    if k == T_TRUE
        p_advance(p)
        return n_kind("bool_true")
    if k == T_FALSE
        p_advance(p)
        return n_kind("bool_false")
    if k == T_NIL
        p_advance(p)
        return n_kind("nil_lit")
    if k == T_IDENT
        p_advance(p)
        return n_str("ident", tok.value)
    if k == T_LPAREN
        p_advance(p)
        let e = parse_expr(p)
        if p_at(p, T_COMMA)
            let mut elems = {}
            elems[0] = e
            let mut idx = 1
            let mut done = false
            while not done
                if not p_at(p, T_COMMA)
                    done = true
                if not done
                    p_advance(p)
                    if p_at(p, T_RPAREN)
                        done = true
                    if not done
                        elems[idx] = parse_expr(p)
                        idx = idx + 1
            p_expect(p, T_RPAREN, "')'")
            let mut n = Node{kind: "tuple_lit", sval: "", ival: 0, bval: false, a: {}, b: {}, c: {}, list: elems, extra: ""}
            return n
        p_expect(p, T_RPAREN, "')'")
        return e
    if k == T_LBRACE
        return parse_table_lit(p)
    if k == T_FN
        return parse_fn_expr(p)
    if k == T_IF
        return parse_if_expr(p)
    if k == T_MATCH
        return parse_match_stmt(p)
    if k == T_SPAWN
        p_advance(p)
        let expr = parse_expr(p)
        let mut ea = {}
        ea[0] = expr
        let mut n = Node{kind: "spawn", sval: "", ival: 0, bval: false, a: ea, b: {}, c: {}, list: {}, extra: ""}
        return n
    if k == T_AWAIT
        p_advance(p)
        let expr = parse_expr(p)
        let mut ea = {}
        ea[0] = expr
        let mut n = Node{kind: "await", sval: "", ival: 0, bval: false, a: ea, b: {}, c: {}, list: {}, extra: ""}
        return n
    p_error(p, "unexpected token: '" + tok.value + "'")
    p_advance(p)
    return n_kind("error")

fn parse_if_expr(p Parser) Node
    if p_at(p, T_IF)
        p_advance(p)
    let cond = parse_expr(p)
    let then_block = parse_block(p)
    let mut else_block = {}
    if p_at(p, T_BUT)
        p_advance(p)
        let nested = parse_if_expr(p)
        let mut ne = {}
        ne[0] = nested
        else_block = ne
    if p_at(p, T_ELSE)
        p_advance(p)
        else_block = parse_block(p)
    let mut ca = {}
    ca[0] = cond
    let mut n = Node{kind: "if_expr", sval: "", ival: 0, bval: false, a: ca, b: {}, c: {}, list: then_block, extra: ""}
    n.b = else_block
    return n

fn parse_table_lit(p Parser) Node
    p_expect(p, T_LBRACE, "'{'")
    let mut entries = {}
    let mut idx = 0
    let mut done = false
    while not done
        if p_at(p, T_RBRACE) or p_at(p, T_EOF)
            done = true
        if not done
            if idx > 0
                p_expect(p, T_COMMA, "','")
            let key = parse_expr(p)
            let mut val = n_kind("nil")
            if p_at(p, T_COLON)
                p_advance(p)
                val = parse_expr(p)
            let mut ka = {}
            ka[0] = key
            let mut va = {}
            va[0] = val
            let mut entry = Node{kind: "entry", sval: "", ival: 0, bval: false, a: ka, b: va, c: {}, list: {}, extra: ""}
            entries[idx] = entry
            idx = idx + 1
    p_expect(p, T_RBRACE, "'}'")
    let mut n = Node{kind: "table_lit", sval: "", ival: 0, bval: false, a: {}, b: {}, c: {}, list: entries, extra: ""}
    return n

fn parse_fn_expr(p Parser) Node
    p_expect(p, T_FN, "'fn'")
    let mut name = ""
    if p_at(p, T_IDENT)
        let nt = p_advance(p)
        name = nt.value
    p_expect(p, T_LPAREN, "'('")
    let params = parse_params(p)
    p_expect(p, T_RPAREN, "')'")
    let mut ret_type = ""
    if p_at(p, T_IDENT)
        let rt = p_advance(p)
        ret_type = rt.value
    let body = parse_block(p)
    let mut n = Node{kind: "fn_expr", sval: name, ival: 0, bval: false, a: params, b: {}, c: {}, list: body, extra: ret_type}
    return n

// ---------------------------------------------------------------------------
// Section 8: Main parser entry point
// ---------------------------------------------------------------------------

fn parse_program(tokens table) ParseResult
    let mut p = parser_new(tokens)
    let mut decls = {}
    let mut idx = 0
    let mut done = false
    while not done
        p_skip_all_indent(p)
        if p_at(p, T_EOF)
            done = true
        if not done
            let d = parse_decl(p)
            if d.kind != "eof" and d.kind != "error"
                decls[idx] = d
                idx = idx + 1
    let mut result = ParseResult{decls: decls, errors: p.errors, nerrors: p.nerrors}
    return result

// ---------------------------------------------------------------------------
// Section 9: AST pretty-printing
// ---------------------------------------------------------------------------

fn print_indent(level int)
    let mut i = 0
    while i < level
        print("  ")
        i = i + 1

fn print_node(n Node, level int)
    print_indent(level)
    let kind = n.kind
    if kind == "fn_decl"
        if n.bval
            print("pub ")
        print("fn ")
        print(n.sval)
        print(" -> ")
        print(n.extra)
        print("")
        let params = n.a
        let mut i = 0
        while i < params.len()
            let param = params[i]
            print_indent(level + 1)
            print("param ")
            print(param.sval)
            print(" ")
            print(param.extra)
            print("")
            i = i + 1
        print_block(n.list, level + 1)
        return
    if kind == "let_stmt"
        print("let ")
        if n.bval
            print("mut ")
        print(n.sval)
        if n.extra != ""
            print(" ")
            print(n.extra)
        print(" = ")
        let va = n.a
        print_expr(va[0])
        print("")
        return
    if kind == "return"
        if n.a.has(0)
            print("return ")
            let va = n.a
            print_expr(va[0])
        print("")
        return
    if kind == "expr_stmt"
        let ea = n.a
        print_expr(ea[0])
        print("")
        return
    if kind == "if_stmt"
        let branches = n.list
        let mut i = 0
        while i < branches.len()
            let b = branches[i]
            print_indent(level)
            if i == 0
                print("if ")
            else
                print("but ")
            let ca = b.a
            print_expr(ca[0])
            print("")
            print_block(b.b, level + 1)
            i = i + 1
        if n.a.has(0)
            print_indent(level)
            print("else")
            print("")
            print_block(n.a, level + 1)
        return
    if kind == "while_stmt"
        print("while ")
        let ca = n.a
        print_expr(ca[0])
        print("")
        print_block(n.list, level + 1)
        return
    if kind == "assign"
        let ea = n.a
        print_expr(ea[0])
        print(" = ")
        let vb = n.b
        print_expr(vb[0])
        print("")
        return
    print(kind)
    print("")

fn print_block(block table, level int)
    let mut i = 0
    while i < block.len()
        let s = block[i]
        print_node(s, level)
        i = i + 1

fn print_expr(e Node)
    let kind = e.kind
    if kind == "int_lit"
        print(e.sval)
        return
    if kind == "string_lit"
        print("\"")
        print(e.sval)
        print("\"")
        return
    if kind == "ident"
        print(e.sval)
        return
    if kind == "bool_true"
        print("true")
        return
    if kind == "bool_false"
        print("false")
        return
    if kind == "nil_lit"
        print("nil")
        return
    if kind == "binary"
        print("(")
        let la = e.a
        print_expr(la[0])
        print(" ")
        print(e.sval)
        print(" ")
        let rb = e.b
        print_expr(rb[0])
        print(")")
        return
    if kind == "unary"
        print("(")
        print(e.sval)
        print(" ")
        let oa = e.a
        print_expr(oa[0])
        print(")")
        return
    if kind == "call"
        let fa = e.a
        print_expr(fa[0])
        print("(")
        let args = e.list
        let mut i = 0
        while i < args.len()
            if i > 0
                print(", ")
            print_expr(args[i])
            i = i + 1
        print(")")
        return
    if kind == "member"
        let oa = e.a
        print_expr(oa[0])
        print(".")
        print(e.sval)
        return
    if kind == "index"
        let oa = e.a
        print_expr(oa[0])
        print("[")
        let ib = e.b
        print_expr(ib[0])
        print("]")
        return
    print("?")
    print(kind)


// ===========================================================================
// SECTION 3: Code Generator  (originally stage5/codegen.yilt)
// ===========================================================================
// ===========================================================================
// Yilt Self-Host Compiler — Stage 5: x86_64 Code Generation + ELF64
// ===========================================================================
//
// Produces native x86_64 ELF binaries from Yilt source code.
// Uses Ctx struct for state (passed to all functions — mutations persist
// because Yilt structs are tables under the hood, and table pointers are
// shared across function calls).
//
// ===========================================================================

// ---------------------------------------------------------------------------
// Section 1: ALL_BYTES constant for binary output
// ---------------------------------------------------------------------------

let ALL_BYTES = "\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b\x0c\x0d\x0e\x0f\x10\x11\x12\x13\x14\x15\x16\x17\x18\x19\x1a\x1b\x1c\x1d\x1e\x1f\x20\x21\x22\x23\x24\x25\x26\x27\x28\x29\x2a\x2b\x2c\x2d\x2e\x2f\x30\x31\x32\x33\x34\x35\x36\x37\x38\x39\x3a\x3b\x3c\x3d\x3e\x3f\x40\x41\x42\x43\x44\x45\x46\x47\x48\x49\x4a\x4b\x4c\x4d\x4e\x4f\x50\x51\x52\x53\x54\x55\x56\x57\x58\x59\x5a\x5b\x5c\x5d\x5e\x5f\x60\x61\x62\x63\x64\x65\x66\x67\x68\x69\x6a\x6b\x6c\x6d\x6e\x6f\x70\x71\x72\x73\x74\x75\x76\x77\x78\x79\x7a\x7b\x7c\x7d\x7e\x7f\x80\x81\x82\x83\x84\x85\x86\x87\x88\x89\x8a\x8b\x8c\x8d\x8e\x8f\x90\x91\x92\x93\x94\x95\x96\x97\x98\x99\x9a\x9b\x9c\x9d\x9e\x9f\xa0\xa1\xa2\xa3\xa4\xa5\xa6\xa7\xa8\xa9\xaa\xab\xac\xad\xae\xaf\xb0\xb1\xb2\xb3\xb4\xb5\xb6\xb7\xb8\xb9\xba\xbb\xbc\xbd\xbe\xbf\xc0\xc1\xc2\xc3\xc4\xc5\xc6\xc7\xc8\xc9\xca\xcb\xcc\xcd\xce\xcf\xd0\xd1\xd2\xd3\xd4\xd5\xd6\xd7\xd8\xd9\xda\xdb\xdc\xdd\xde\xdf\xe0\xe1\xe2\xe3\xe4\xe5\xe6\xe7\xe8\xe9\xea\xeb\xec\xed\xee\xef\xf0\xf1\xf2\xf3\xf4\xf5\xf6\xf7\xf8\xf9\xfa\xfb\xfc\xfd\xfe\xff"

// ---------------------------------------------------------------------------
// Section 2: Codegen context (struct = table under the hood, mutations persist)
// ---------------------------------------------------------------------------

struct Ctx
    mut code_data table
    mut code_len int
    mut data_data table
    mut data_len int
    mut var_slots table
    mut next_slot int
    mut string_count int
    mut fixup_count int
    mut fn_table table
    mut fn_count int
    mut call_fixups table
    mut call_fixup_count int
    mut is_main bool
    mut loop_depth int
    mut break_targets table
    mut continue_targets table
    mut break_fixups table
    mut break_fixup_count int
    mut var_types table
    mut fn_ret_types table
    // Target architecture: 0=x86_64, 1=aarch64
    mut target int

fn ctx_new() Ctx
    let mut ctx = Ctx{code_data: {}, code_len: 0, data_data: {}, data_len: 0, var_slots: {}, next_slot: -8, string_count: 0, fixup_count: 0, fn_table: {}, fn_count: 0, call_fixups: {}, call_fixup_count: 0, is_main: false, loop_depth: 0, break_targets: {}, continue_targets: {}, break_fixups: {}, break_fixup_count: 0, var_types: {}, fn_ret_types: {}, target: 0}
    return ctx

// ---------------------------------------------------------------------------
// Section 3: Code byte emitters (write to ctx.code_data)
// ---------------------------------------------------------------------------

fn code_byte(ctx Ctx, v int)
    ctx.code_data[ctx.code_len] = ((v % 256) + 256) % 256
    ctx.code_len = ctx.code_len + 1

fn code_u16(ctx Ctx, v int)
    code_byte(ctx, v % 256)
    code_byte(ctx, (v / 256) % 256)

fn code_u32(ctx Ctx, v int)
    code_byte(ctx, v % 256)
    code_byte(ctx, (v / 256) % 256)
    code_byte(ctx, (v / 65536) % 256)
    code_byte(ctx, (v / 16777216) % 256)

fn code_u64(ctx Ctx, v int)
    // Extract 8 bytes using bit shifts and masking.
    // This correctly handles negative values (two's complement) because
    // Yilt's >> is arithmetic (SAR), which preserves the sign bit.
    let mut i = 0
    while i < 8
        let shift = i * 8
        let byte = (v >> shift) & 255
        code_byte(ctx, byte)
        i = i + 1

fn data_byte(ctx Ctx, v int)
    ctx.data_data[ctx.data_len] = ((v % 256) + 256) % 256
    ctx.data_len = ctx.data_len + 1

fn data_u64(ctx Ctx, v int)
    let mut val = v
    let mut i = 0
    while i < 8
        data_byte(ctx, val % 256)
        val = val / 256
        i = i + 1

fn data_str(ctx Ctx, s str)
    let bytes = s.bytes()
    let mut i = 0
    while i < bytes.len()
        data_byte(ctx, bytes[i])
        i = i + 1

// ---------------------------------------------------------------------------
// Section 4: x86_64 instruction encoders
// ---------------------------------------------------------------------------

// AArch64 register definitions (for target=1)
let X0 = 0
let X1 = 1
let X2 = 2
let X3 = 3
let X4 = 4
let X5 = 5
let X6 = 6
let X7 = 7
let X8 = 8
let X9 = 9
let X10 = 10
let X11 = 11
let X12 = 12
let X13 = 13
let X14 = 14
let X15 = 15
let X16 = 16
let X17 = 17
let X18 = 18
let X19 = 19
let X20 = 20
let X21 = 21
let X22 = 22
let X23 = 23
let X24 = 24
let X25 = 25
let X26 = 26
let X27 = 27
let X28 = 28
let X29 = 29
let X30 = 30
let X31 = 31
let XZR = 31

// AArch64 instruction encoders
// All AArch64 instructions are 4 bytes, little-endian.

// Emit a 32-bit AArch64 instruction (little-endian)
fn arm_emit(ctx Ctx, instr int)
    code_byte(ctx, instr % 256)
    code_byte(ctx, (instr / 256) % 256)
    code_byte(ctx, (instr / 65536) % 256)
    code_byte(ctx, (instr / 16777216) % 256)

// MOV (register): MOV Xd, Xm = ORR Xd, XZR, Xm
// Encoding: 1AA01010 00Mmmmmm ddddd 11111 mmmmm
// = 0xAA0003E0 | (Rm << 16) | (Rd)
fn arm_mov_reg(ctx Ctx, dst int, src int)
    let instr = 0xAA0003E0 + (src * 65536) + dst
    arm_emit(ctx, instr)

// MOVZ Xd, #imm16, lsl #shift (for loading 16-bit immediates)
// Encoding: 110100101 00 imm16 Rd
// = 0xD2800000 | (imm16 << 5) | Rd | (hw << 21)
fn arm_movz(ctx Ctx, dst int, imm16 int, hw int)
    let instr = 0xD2800000 + (imm16 * 32) + dst + (hw * 1048576)
    arm_emit(ctx, instr)

// MOVK Xd, #imm16, lsl #shift (keep and insert 16 bits)
// Encoding: 111100101 00 imm16 Rd
// = 0xF2800000 | (imm16 << 5) | Rd | (hw << 21)
fn arm_movk(ctx Ctx, dst int, imm16 int, hw int)
    let instr = 0xF2800000 + (imm16 * 32) + dst + (hw * 1048576)
    arm_emit(ctx, instr)

// Load a 64-bit immediate into Xd using MOVZ + MOVK
fn arm_mov_imm64(ctx Ctx, dst int, val int)
    let lo16 = val & 65535
    let hi16_1 = (val >> 16) & 65535
    let hi16_2 = (val >> 32) & 65535
    let hi16_3 = (val >> 48) & 65535
    arm_movz(ctx, dst, lo16, 0)
    if hi16_1 != 0
        arm_movk(ctx, dst, hi16_1, 1)
    if hi16_2 != 0
        arm_movk(ctx, dst, hi16_2, 2)
    if hi16_3 != 0
        arm_movk(ctx, dst, hi16_3, 3)

// ADD Xd, Xn, Xm
// Encoding: 10001011 00 0 Xm 0 Xn 0 Xd
// = 0x8B000000 | (Rm << 16) | (Rn << 5) | Rd
fn arm_add(ctx Ctx, dst int, src1 int, src2 int)
    let instr = 0x8B000000 + (src2 * 65536) + (src1 * 32) + dst
    arm_emit(ctx, instr)

// SUB Xd, Xn, Xm
// = 0xCB000000 | (Rm << 16) | (Rn << 5) | Rd
fn arm_sub(ctx Ctx, dst int, src1 int, src2 int)
    let instr = 0xCB000000 + (src2 * 65536) + (src1 * 32) + dst
    arm_emit(ctx, instr)

// MUL Xd, Xn, Xm = UMULH Xd, Xn, Xm (simplified: use MADD with XZR)
// MADD Xd, Xn, Xm, XZR = 0x9B000000 | (Xm << 16) | (Xn << 5) | Xd | (XZR << 10)
fn arm_mul(ctx Ctx, dst int, src1 int, src2 int)
    let instr = 0x9B000000 + (src2 * 65536) + (src1 * 32) + dst + (31 * 1024)
    arm_emit(ctx, instr)

// SDIV Xd, Xn, Xm
// = 0x9AC00C00 | (Rm << 16) | (Rn << 5) | Rd
fn arm_sdiv(ctx Ctx, dst int, src1 int, src2 int)
    let instr = 0x9AC00C00 + (src2 * 65536) + (src1 * 32) + dst
    arm_emit(ctx, instr)

// MSUB Xd, Xn, Xm, Xa (multiply-subtract: Xd = Xa - Xn * Xm)
// Used for modulo: Xd = Xn - (Xn/Xm)*Xm
// = 0x9B008000 | (Rm << 16) | (Ra << 10) | (Rn << 5) | Rd
fn arm_msub(ctx Ctx, dst int, src1 int, src2 int, src3 int)
    let instr = 0x9B008000 + (src2 * 65536) + (src3 * 1024) + (src1 * 32) + dst
    arm_emit(ctx, instr)

// CMP Xn, Xm = SUBS XZR, Xn, Xm
// = 0xEB00001F | (Rm << 16) | (Rn << 5)
fn arm_cmp(ctx Ctx, src1 int, src2 int)
    let instr = 0xEB00001F + (src2 * 65536) + (src1 * 32)
    arm_emit(ctx, instr)

// STR Xd, [Xn, #offset] (store, 12-bit unsigned offset, scaled by 8)
// = 0xF9000000 | (offset/8 << 10) | (Rn << 5) | Rd
fn arm_str(ctx Ctx, src int, base int, offset int)
    let scaled = offset / 8
    let instr = 0xF9000000 + (scaled * 1024) + (base * 32) + src
    arm_emit(ctx, instr)

// LDR Xd, [Xn, #offset] (load, 12-bit unsigned offset, scaled by 8)
// = 0xF9400000 | (offset/8 << 10) | (Rn << 5) | Rd
fn arm_ldr(ctx Ctx, dst int, base int, offset int)
    let scaled = offset / 8
    let instr = 0xF9400000 + (scaled * 1024) + (base * 32) + dst
    arm_emit(ctx, instr)

// STP Xd, Xm, [Xn, #offset] (store pair, for prologue)
// Pre-index: STP Xd, Xm, [Xn, #offset]!
// = 0xA9000000 | ((offset/8 & 0x7F) << 15) | (Rm << 10) | (Rn << 5) | Rd
fn arm_stp_pre(ctx Ctx, src1 int, src2 int, base int, offset int)
    let scaled = offset / 8
    let instr = 0xA9800000 + (scaled * 32768) + (src2 * 1024) + (base * 32) + src1
    arm_emit(ctx, instr)

// LDP Xd, Xm, [Xn], #offset (load pair, post-index, for epilogue)
// = 0xA8C00000 | ((offset/8 & 0x7F) << 15) | (Rm << 10) | (Rn << 5) | Rd
fn arm_ldp_post(ctx Ctx, dst1 int, dst2 int, base int, offset int)
    let scaled = offset / 8
    let instr = 0xA8C00000 + (scaled * 32768) + (dst2 * 1024) + (base * 32) + dst1
    arm_emit(ctx, instr)

// BL #offset (branch with link, for function calls)
// Encoding: 100101 imm26
// = 0x94000000 | (offset/4 & 0x3FFFFFF)
fn arm_bl(ctx Ctx, offset int)
    let imm = offset / 4
    let instr = 0x94000000 + (imm & 67108863)
    arm_emit(ctx, instr)

// B #offset (unconditional branch)
// = 0x14000000 | (offset/4 & 0x3FFFFFF)
fn arm_b(ctx Ctx, offset int)
    let imm = offset / 4
    let instr = 0x14000000 + (imm & 67108863)
    arm_emit(ctx, instr)

// RET (return)
// = 0xD65F03C0
fn arm_ret(ctx Ctx)
    arm_emit(ctx, 0xD65F03C0)

// SVC #0 (supervisor call, for syscalls)
// = 0xD4000001
fn arm_svc(ctx Ctx)
    arm_emit(ctx, 0xD4000001)

// Conditional branches (B.EQ, B.NE, B.LT, B.GT, B.LE, B.GE, etc.)
// = 0x54000000 | (cond << 0) | (offset/4 << 5)
fn arm_bcond(ctx Ctx, cond int, offset int)
    let imm = offset / 4
    let instr = 0x54000000 + (imm * 32) + cond
    arm_emit(ctx, instr)

// CSET Xd, cond (set register to 1 if condition, 0 otherwise)
// CSET Xd, cond = CSINC Xd, XZR, XZR, invert(cond)
// CSINC encoding: 0x9A800400 | (Rm << 16) | (cond << 12) | (Rn << 5) | Rd
// For CSET: Rm=31, Rn=31, cond=invert(cond)
// = 0x9A800400 | (31 << 16) | (inv_cond << 12) | (31 << 5) | Rd
// = 0x9A9F07E0 + (inv_cond << 12) + Rd
fn arm_cset(ctx Ctx, dst int, cond int)
    let inv_cond = cond ^ 1
    let instr = 0x9A9F07E0 + (inv_cond * 4096) + dst
    arm_emit(ctx, instr)

// x86_64 register definitions

let RAX = 0
let RCX = 1
let RDX = 2
let RBX = 3
let RSP = 4
let RBP = 5
let RSI = 6
let RDI = 7
let R8 = 8
let R9 = 9
let R10 = 10
let R11 = 11
let R12 = 12
let R13 = 13
let R14 = 14
let R15 = 15

fn ext(r int) bool
    return r >= 8

fn emit_rex(ctx Ctx, w bool, r bool, bb bool)
    let mut p = 64
    if w
        p = p + 8
    if r
        p = p + 4
    if bb
        p = p + 1
    code_byte(ctx, p)

fn emit_mov_r64_imm64(ctx Ctx, dst int, imm int)
    emit_rex(ctx, true, false, ext(dst))
    code_byte(ctx, 184 + (dst % 8))
    code_u64(ctx, imm)

fn emit_xor_r64_r64(ctx Ctx, dst int, src int)
    emit_rex(ctx, true, ext(src), ext(dst))
    code_byte(ctx, 0x31)
    code_byte(ctx, 0xC0 + ((src % 8) * 8) + (dst % 8))

fn emit_mov_r64_r64(ctx Ctx, dst int, src int)
    emit_rex(ctx, true, ext(src), ext(dst))
    code_byte(ctx, 0x89)
    code_byte(ctx, 0xC0 + ((src % 8) * 8) + (dst % 8))

fn emit_add_r64_r64(ctx Ctx, dst int, src int)
    emit_rex(ctx, true, ext(src), ext(dst))
    code_byte(ctx, 0x01)
    code_byte(ctx, 0xC0 + ((src % 8) * 8) + (dst % 8))

fn emit_sub_r64_r64(ctx Ctx, dst int, src int)
    emit_rex(ctx, true, ext(src), ext(dst))
    code_byte(ctx, 0x29)
    code_byte(ctx, 0xC0 + ((src % 8) * 8) + (dst % 8))

fn emit_imul_r64_r64(ctx Ctx, dst int, src int)
    emit_rex(ctx, true, ext(dst), ext(src))
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0xAF)
    code_byte(ctx, 0xC0 + ((dst % 8) * 8) + (src % 8))

fn emit_syscall(ctx Ctx)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x05)

fn emit_lea_rip(ctx Ctx, dst int, disp32 int)
    emit_rex(ctx, true, ext(dst), false)
    code_byte(ctx, 0x8D)
    code_byte(ctx, 0x05 + ((dst % 8) * 8))
    code_u32(ctx, disp32)

fn emit_push_r64(ctx Ctx, r int)
    if ext(r)
        emit_rex(ctx, false, false, true)
    code_byte(ctx, 0x50 + (r % 8))

fn emit_pop_r64(ctx Ctx, r int)
    if ext(r)
        emit_rex(ctx, false, false, true)
    code_byte(ctx, 0x58 + (r % 8))

fn emit_mov_rbp_rsp(ctx Ctx)
    emit_rex(ctx, true, false, false)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0xE5)

fn emit_sub_rsp_imm32(ctx Ctx, imm int)
    emit_rex(ctx, true, false, false)
    code_byte(ctx, 0x81)
    code_byte(ctx, 0xEC)
    code_u32(ctx, imm)

fn emit_mov_mem_r64(ctx Ctx, base int, offset int, src int)
    emit_rex(ctx, true, ext(src), ext(base))
    code_byte(ctx, 0x89)
    // When base is RSP (4) or R12 (12), ModRM rm=100 requires a SIB byte.
    if base % 8 == 4
        code_byte(ctx, 0x40 + ((src % 8) * 8) + 4)
        code_byte(ctx, 0x24)  // SIB: scale=00, index=100(none), base=100(RSP)
    else
        code_byte(ctx, 0x40 + ((src % 8) * 8) + (base % 8))
    code_byte(ctx, offset)

fn emit_mov_r64_mem(ctx Ctx, dst int, base int, offset int)
    emit_rex(ctx, true, ext(dst), ext(base))
    code_byte(ctx, 0x8B)
    if base % 8 == 4
        code_byte(ctx, 0x40 + ((dst % 8) * 8) + 4)
        code_byte(ctx, 0x24)  // SIB: scale=00, index=100(none), base=100(RSP)
    else
        code_byte(ctx, 0x40 + ((dst % 8) * 8) + (base % 8))
    code_byte(ctx, offset)

fn emit_cmp_r64_r64(ctx Ctx, dst int, src int)
    emit_rex(ctx, true, ext(src), ext(dst))
    code_byte(ctx, 0x39)
    code_byte(ctx, 0xC0 + ((src % 8) * 8) + (dst % 8))

fn emit_neg_r64(ctx Ctx, dst int)
    emit_rex(ctx, true, false, ext(dst))
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xD8 + (dst % 8))

fn emit_idiv_r64(ctx Ctx, src int)
    emit_rex(ctx, true, false, ext(src))
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xF8 + (src % 8))

fn emit_cqo(ctx Ctx)
    emit_rex(ctx, true, false, false)
    code_byte(ctx, 0x99)

fn emit_nop(ctx Ctx)
    code_byte(ctx, 0x90)

fn emit_setcc(ctx Ctx, cc int, dst int)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x90 + cc)
    code_byte(ctx, 0xC0 + dst)
    emit_rex(ctx, true, false, false)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0xB6)
    code_byte(ctx, 0xC0 + (dst * 8) + dst)

// ---------------------------------------------------------------------------
// Section 5: ELF64 builder
// ---------------------------------------------------------------------------

let BASE_ADDR = 0x400000

// write_byte writes a single byte value to the file descriptor.
fn write_byte(fd int, b int)
    let one_byte = ALL_BYTES.substr(((b % 256) + 256) % 256, ((b % 256) + 256) % 256 + 1)
    sys.write(fd, one_byte, 1)

// write_u32_le writes a 32-bit little-endian value to the file.
fn write_u32_le(fd int, v int)
    let mut val = v
    let mut i = 0
    while i < 4
        write_byte(fd, val % 256)
        val = val / 256
        i = i + 1

// write_u64_le writes a 64-bit little-endian value to the file.
fn write_u64_le(fd int, v int)
    let mut val = v
    let mut i = 0
    while i < 8
        write_byte(fd, val % 256)
        val = val / 256
        i = i + 1

fn build_elf(ctx Ctx, output_fd int) int
    let code_len = ctx.code_len
    let data_len = ctx.data_len
    let headers_size = 64 + 56  // ELF header + 1 PHDR = 120
    let code_offset = headers_size
    let data_offset = code_offset + code_len
    let total = headers_size + code_len + data_len
    let entry = BASE_ADDR + code_offset

    // Write the ELF binary directly to the file descriptor, byte by byte.
    // We avoid building a giant in-memory bin_data table because Yilt's hash
    // tables have per-entry overhead that becomes prohibitive for 50K+ entries.

    // --- ELF Header (64 bytes) ---
    // e_ident (16 bytes): 7F 45 4C 46 02 01 01 00 + 8 zero bytes
    write_byte(output_fd, 0x7F)
    write_byte(output_fd, 69)   // 'E'
    write_byte(output_fd, 76)   // 'L'
    write_byte(output_fd, 70)   // 'F'
    write_byte(output_fd, 2)    // 64-bit
    write_byte(output_fd, 1)    // little-endian
    write_byte(output_fd, 1)    // ELF version
    write_byte(output_fd, 0)    // SysV ABI
    let mut zi = 0
    while zi < 8
        write_byte(output_fd, 0)
        zi = zi + 1
    // e_type (2 bytes) = ET_EXEC = 2
    write_byte(output_fd, 2)
    write_byte(output_fd, 0)
    // e_machine (2 bytes): EM_X86_64=62, EM_AARCH64=183, EM_RISCV=243
    if ctx.target == 1
        write_byte(output_fd, 183)
        write_byte(output_fd, 0)
    if ctx.target == 2 or ctx.target == 4
        write_byte(output_fd, 243)
        write_byte(output_fd, 0)
    if ctx.target == 0
        write_byte(output_fd, 62)
        write_byte(output_fd, 0)
    // e_version (4 bytes) = 1
    write_u32_le(output_fd, 1)
    // e_entry (8 bytes)
    write_u64_le(output_fd, entry)
    // e_phoff (8 bytes) = 64
    write_u64_le(output_fd, 64)
    // e_shoff (8 bytes) = 0
    write_u64_le(output_fd, 0)
    // e_flags (4 bytes) = 0
    write_u32_le(output_fd, 0)
    // e_ehsize (2 bytes) = 64
    write_byte(output_fd, 64)
    write_byte(output_fd, 0)
    // e_phentsize (2 bytes) = 56
    write_byte(output_fd, 56)
    write_byte(output_fd, 0)
    // e_phnum (2 bytes) = 1
    write_byte(output_fd, 1)
    write_byte(output_fd, 0)
    // e_shentsize (2 bytes) = 0
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)
    // e_shnum (2 bytes) = 0
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)
    // e_shstrndx (2 bytes) = 0
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)

    // --- Program Header (56 bytes) ---
    // p_type (4 bytes) = PT_LOAD = 1
    write_u32_le(output_fd, 1)
    // p_flags (4 bytes) = R+W+X = 7
    write_u32_le(output_fd, 7)
    // p_offset (8 bytes) = 0
    write_u64_le(output_fd, 0)
    // p_vaddr (8 bytes) = BASE_ADDR
    write_u64_le(output_fd, BASE_ADDR)
    // p_paddr (8 bytes) = BASE_ADDR
    write_u64_le(output_fd, BASE_ADDR)
    // p_filesz (8 bytes) = total
    write_u64_le(output_fd, total)
    // p_memsz (8 bytes) = total
    write_u64_le(output_fd, total)
    // p_align (8 bytes) = 0x1000
    write_u64_le(output_fd, 4096)

    // --- Append code bytes ---
    let mut ci = 0
    while ci < code_len
        write_byte(output_fd, ctx.code_data[ci])
        ci = ci + 1

    // --- Append data bytes ---
    let mut di = 0
    while di < data_len
        write_byte(output_fd, ctx.data_data[di])
        di = di + 1

    return total

// ---------------------------------------------------------------------------
// Section 6: Code generator — walks AST and emits x86_64 code
// ---------------------------------------------------------------------------

fn cg_get_var_offset(ctx Ctx, name str) int
    if ctx.var_slots.has(name)
        return ctx.var_slots[name]
    let offset = ctx.next_slot
    ctx.var_slots[name] = offset
    ctx.next_slot = offset - 8
    return offset

fn cg_add_string(ctx Ctx, s str) int
    let idx = ctx.string_count
    data_u64(ctx, s.len())
    data_str(ctx, s)
    data_byte(ctx, 0)
    ctx.string_count = idx + 1
    return idx

// Record a LEA fixup: the LEA at code position 'lea_pos' should point
// to data offset 'data_off'. After all code is generated, we patch the
// displacement = (code_len - lea_pos - 7) + data_off.
fn cg_add_fixup(ctx Ctx, lea_pos int, data_off int)
    let idx = ctx.fixup_count
    ctx.code_data[100000 + idx * 2] = lea_pos
    ctx.code_data[100000 + idx * 2 + 1] = data_off
    ctx.fixup_count = idx + 1

// Apply all fixups: patch LEA displacements now that code_len is final.
fn cg_apply_fixups(ctx Ctx)
    let mut i = 0
    while i < ctx.fixup_count
        let lea_pos = ctx.code_data[100000 + i * 2]
        let data_off = ctx.code_data[100000 + i * 2 + 1]
        // LEA instruction is 7 bytes: REX(1) + 0x8D(1) + modrm(1) + disp32(4)
        // disp32 starts at lea_pos + 3
        // RIP after LEA = lea_pos + 7
        // Target = code_len + data_off (data starts right after code)
        // disp = target - rip = (code_len + data_off) - (lea_pos + 7)
        let disp = (ctx.code_len + data_off) - (lea_pos + 7)
        let imm_offset = lea_pos + 3
        ctx.code_data[imm_offset] = ((disp % 256) + 256) % 256
        ctx.code_data[imm_offset + 1] = (((disp / 256) % 256) + 256) % 256
        ctx.code_data[imm_offset + 2] = (((disp / 65536) % 256) + 256) % 256
        ctx.code_data[imm_offset + 3] = (((disp / 16777216) % 256) + 256) % 256
        i = i + 1

fn cg_expr(ctx Ctx, e Node)
    // Multi-target dispatch: AArch64 path
    if ctx.target == 1
        arm_cg_expr(ctx, e)
        return
    // Multi-target dispatch: RV64 path
    if ctx.target == 2
        rv_cg_expr(ctx, e)
        return
    // Multi-target dispatch: WASM path
    if ctx.target == 3
        wasm_cg_expr(ctx, e)
        return
    // Multi-target dispatch: RV32 path
    if ctx.target == 4
        rv32_cg_expr(ctx, e)
        return
    if e.kind == "int_lit"
        let val = parse_int(e.sval)
        emit_mov_r64_imm64(ctx, RAX, val)
        return
    if e.kind == "string_lit"
        // Add string to data section and emit LEA with fixup.
        // The data layout is: [len:8 | data... | null:1]
        // RAX will point to the len prefix.
        let data_off = ctx.data_len
        cg_add_string(ctx, e.sval)
        let lea_pos = ctx.code_len
        emit_lea_rip(ctx, RAX, 0)
        cg_add_fixup(ctx, lea_pos, data_off)
        return
    if e.kind == "bool_true"
        emit_mov_r64_imm64(ctx, RAX, 1)
        return
    if e.kind == "bool_false"
        emit_mov_r64_imm64(ctx, RAX, 0)
        return
    if e.kind == "ident"
        let offset = cg_get_var_offset(ctx, e.sval)
        emit_mov_r64_mem(ctx, RAX, RBP, offset)
        return
    if e.kind == "binary"
        cg_binary(ctx, e)
        return
    if e.kind == "unary"
        cg_unary(ctx, e)
        return
    if e.kind == "call"
        cg_call(ctx, e)
        return
    if e.kind == "member"
        cg_member(ctx, e)
        return
    if e.kind == "index"
        cg_index(ctx, e)
        return
    if e.kind == "struct_lit"
        cg_struct_lit(ctx, e)
        return
    if e.kind == "table_lit"
        cg_table_lit(ctx, e)
        return
    if e.kind == "nil"
        emit_mov_r64_imm64(ctx, RAX, 0)
        return
    if e.kind == "float_lit"
        let bits = parse_float_to_bits(e.sval)
        if bits == 0
            let val = parse_int(e.sval)
            emit_mov_r64_imm64(ctx, RAX, val)
        else
            emit_mov_r64_imm64(ctx, RAX, bits)
        return
    if e.kind == "error_prop"
        let ea = e.a
        cg_expr(ctx, ea[0])
        return
    if e.kind == "spawn"
        let ea = e.a
        cg_expr(ctx, ea[0])
        return
    if e.kind == "await"
        let ea = e.a
        cg_expr(ctx, ea[0])
        return
    if e.kind == "if_expr"
        cg_if_expr(ctx, e)
        return
    emit_mov_r64_imm64(ctx, RAX, 0)

fn cg_binary(ctx Ctx, e Node)
    let la = e.a
    let rb = e.b
    let op = e.sval

    // Short-circuit logical operators: and / or
    // These must NOT evaluate both sides eagerly.
    if op == "and"
        // left → RAX; if RAX==0, skip right; result = left & right (0 or right)
        cg_expr(ctx, la[0])
        // TEST RAX, RAX; JZ false_label
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x85)
        code_byte(ctx, 0xC0)  // TEST RAX, RAX
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0x84)  // JZ rel32
        let jz_pos = ctx.code_len
        code_u32(ctx, 0)  // placeholder
        // Evaluate right → RAX
        cg_expr(ctx, rb[0])
        // TEST RAX, RAX; set RAX = 0 or 1
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x85)
        code_byte(ctx, 0xC0)  // TEST RAX, RAX
        // SETNE AL (set RAX = 1 if RAX != 0, else 0)
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0x95)
        code_byte(ctx, 0xC0)  // SETNE AL
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0xB6)
        code_byte(ctx, 0xC0)  // MOVZX RAX, AL
        // JMP end
        code_byte(ctx, 0xE9)
        let jmp_pos = ctx.code_len
        code_u32(ctx, 0)
        // false_label: RAX = 0
        let false_pos = ctx.code_len
        let jz_disp = false_pos - (jz_pos + 4)
        ctx.code_data[jz_pos] = ((jz_disp % 256) + 256) % 256
        ctx.code_data[jz_pos + 1] = (((jz_disp / 256) % 256) + 256) % 256
        ctx.code_data[jz_pos + 2] = (((jz_disp / 65536) % 256) + 256) % 256
        ctx.code_data[jz_pos + 3] = (((jz_disp / 16777216) % 256) + 256) % 256
        emit_mov_r64_imm64(ctx, RAX, 0)
        // end_label:
        let end_pos = ctx.code_len
        let jmp_disp = end_pos - (jmp_pos + 4)
        ctx.code_data[jmp_pos] = ((jmp_disp % 256) + 256) % 256
        ctx.code_data[jmp_pos + 1] = (((jmp_disp / 256) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 2] = (((jmp_disp / 65536) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 3] = (((jmp_disp / 16777216) % 256) + 256) % 256
        return
    if op == "or"
        // left → RAX; if RAX!=0, skip right (result=1); else evaluate right
        cg_expr(ctx, la[0])
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x85)
        code_byte(ctx, 0xC0)  // TEST RAX, RAX
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0x85)  // JNE rel32
        let jne_pos = ctx.code_len
        code_u32(ctx, 0)
        // Evaluate right → RAX
        cg_expr(ctx, rb[0])
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x85)
        code_byte(ctx, 0xC0)  // TEST RAX, RAX
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0x95)
        code_byte(ctx, 0xC0)  // SETNE AL
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0xB6)
        code_byte(ctx, 0xC0)  // MOVZX RAX, AL
        // JMP end
        code_byte(ctx, 0xE9)
        let jmp_pos = ctx.code_len
        code_u32(ctx, 0)
        // true_label: RAX = 1
        let true_pos = ctx.code_len
        let jne_disp = true_pos - (jne_pos + 4)
        ctx.code_data[jne_pos] = ((jne_disp % 256) + 256) % 256
        ctx.code_data[jne_pos + 1] = (((jne_disp / 256) % 256) + 256) % 256
        ctx.code_data[jne_pos + 2] = (((jne_disp / 65536) % 256) + 256) % 256
        ctx.code_data[jne_pos + 3] = (((jne_disp / 16777216) % 256) + 256) % 256
        emit_mov_r64_imm64(ctx, RAX, 1)
        let end_pos = ctx.code_len
        let jmp_disp = end_pos - (jmp_pos + 4)
        ctx.code_data[jmp_pos] = ((jmp_disp % 256) + 256) % 256
        ctx.code_data[jmp_pos + 1] = (((jmp_disp / 256) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 2] = (((jmp_disp / 65536) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 3] = (((jmp_disp / 16777216) % 256) + 256) % 256
        return

    // Eager binary ops: evaluate left, push, evaluate right, pop into RBX
    cg_expr(ctx, la[0])
    emit_push_r64(ctx, RAX)
    cg_expr(ctx, rb[0])
    emit_pop_r64(ctx, RBX)

    // String concatenation: if both operands are strings, concat them.
    if op == "+"
        if cg_is_string_expr(ctx, la[0]) and cg_is_string_expr(ctx, rb[0])
            cg_str_concat(ctx)
            return
        emit_add_r64_r64(ctx, RAX, RBX)
        return
    if op == "-"
        emit_sub_r64_r64(ctx, RBX, RAX)
        emit_mov_r64_r64(ctx, RAX, RBX)
        return
    if op == "*"
        emit_imul_r64_r64(ctx, RAX, RBX)
        return
    if op == "/"
        emit_mov_r64_r64(ctx, RCX, RAX)
        emit_mov_r64_r64(ctx, RAX, RBX)
        emit_cqo(ctx)
        emit_idiv_r64(ctx, RCX)
        return
    if op == "%"
        emit_mov_r64_r64(ctx, RCX, RAX)
        emit_mov_r64_r64(ctx, RAX, RBX)
        emit_cqo(ctx)
        emit_idiv_r64(ctx, RCX)
        emit_mov_r64_r64(ctx, RAX, RDX)
        return
    // Bitwise ops: RAX = RBX OP RAX (RBX = left, RAX = right)
    if op == "&"
        // AND RAX, RBX
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x21)
        code_byte(ctx, 0xD8)  // AND RAX, RBX
        return
    if op == "|"
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x09)
        code_byte(ctx, 0xD8)  // OR RAX, RBX
        return
    if op == "^"
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x31)
        code_byte(ctx, 0xD8)  // XOR RAX, RBX
        return
    if op == "<<"
        // SHL RAX, CL (shift count must be in CL)
        emit_mov_r64_r64(ctx, RCX, RAX)
        emit_mov_r64_r64(ctx, RAX, RBX)
        code_byte(ctx, 0x48)
        code_byte(ctx, 0xD3)
        code_byte(ctx, 0xE0)  // SHL RAX, CL
        return
    if op == ">>"
        emit_mov_r64_r64(ctx, RCX, RAX)
        emit_mov_r64_r64(ctx, RAX, RBX)
        code_byte(ctx, 0x48)
        code_byte(ctx, 0xD3)
        code_byte(ctx, 0xF8)  // SAR RAX, CL (arithmetic shift)
        return
    if op == "=="
        if cg_is_string_expr(ctx, la[0]) and cg_is_string_expr(ctx, rb[0])
            cg_str_equal(ctx)
            return
        emit_cmp_r64_r64(ctx, RBX, RAX)
        emit_setcc(ctx, 4, RAX)
        return
    if op == "!="
        if cg_is_string_expr(ctx, la[0]) and cg_is_string_expr(ctx, rb[0])
            cg_str_equal(ctx)
            code_byte(ctx, 0x48)
            code_byte(ctx, 0x31)
            code_byte(ctx, 0xF0)
            code_byte(ctx, 0x83)
            code_byte(ctx, 0xF0)
            code_byte(ctx, 0x01)
            return
        emit_cmp_r64_r64(ctx, RBX, RAX)
        emit_setcc(ctx, 5, RAX)
        return
    if op == "<"
        emit_cmp_r64_r64(ctx, RBX, RAX)
        emit_setcc(ctx, 12, RAX)
        return
    if op == "<="
        emit_cmp_r64_r64(ctx, RBX, RAX)
        emit_setcc(ctx, 14, RAX)
        return
    if op == ">"
        emit_cmp_r64_r64(ctx, RBX, RAX)
        emit_setcc(ctx, 15, RAX)
        return
    if op == ">="
        emit_cmp_r64_r64(ctx, RBX, RAX)
        emit_setcc(ctx, 13, RAX)
        return

fn cg_unary(ctx Ctx, e Node)
    let oa = e.a
    cg_expr(ctx, oa[0])
    if e.sval == "-"
        emit_neg_r64(ctx, RAX)
        return
    if e.sval == "not"
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x85)
        code_byte(ctx, 0xC0)  // TEST RAX, RAX
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0x94)
        code_byte(ctx, 0xC0)  // SETE AL
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0xB6)
        code_byte(ctx, 0xC0)  // MOVZX RAX, AL
        return
    if e.sval == "~"
        code_byte(ctx, 0x48)
        code_byte(ctx, 0xF7)
        code_byte(ctx, 0xD0)  // NOT RAX
        return

// cg_is_string_expr returns true if the expression is known to produce a string.
// Used to decide whether `+` means integer addition or string concatenation.
fn cg_is_string_expr(ctx Ctx, e Node) bool
    if e.kind == "string_lit"
        return true
    if e.kind == "ident"
        if ctx.var_types.has(e.sval)
            return ctx.var_types[e.sval] == "str"
    if e.kind == "call"
        let fa = e.a
        if fa[0].kind == "ident"
            let fname = fa[0].sval
            if ctx.fn_ret_types.has(fname)
                return ctx.fn_ret_types[fname] == "str"
    if e.kind == "binary"
        if e.sval == "+"
            let la = e.a
            let rb = e.b
            return cg_is_string_expr(ctx, la[0]) and cg_is_string_expr(ctx, rb[0])
    return false

// cg_str_concat: concatenate two strings.
// On entry: RBX = left string ptr (length-prefixed), RAX = right string ptr.
// On exit: RAX = new string ptr (length-prefixed).
// Allocates a new buffer via mmap, copies both strings, returns pointer.
fn cg_str_concat(ctx Ctx)
    // RBX = left ptr, RAX = right ptr
    // Save both pointers on stack
    emit_push_r64(ctx, RBX)  // [RSP] = left
    emit_push_r64(ctx, RAX)  // [RSP] = right

    // Load left len: RSI = [RBX]
    emit_mov_r64_mem(ctx, RSI, RBX, 0)
    // Load right len: RDI = [RAX]
    emit_mov_r64_mem(ctx, RDI, RAX, 0)
    // Total len = RSI + RDI
    emit_add_r64_r64(ctx, RSI, RDI)
    // Save total len in R12 (callee-saved)
    // Actually we don't have R12 in our register set. Use stack.
    emit_push_r64(ctx, RSI)  // [RSP] = total_len

    // mmap(NULL, total_len + 8 + 1, PROT_RW, MAP_PRIVATE|MAP_ANON, -1, 0)
    // RDI = 0 (addr)
    emit_mov_r64_imm64(ctx, RDI, 0)
    // RSI = total_len + 9 (8 for length prefix + 1 for null)
    emit_mov_r64_mem(ctx, RSI, RSP, 0)  // reload total_len
    emit_mov_r64_imm64(ctx, RAX, 9)
    emit_add_r64_r64(ctx, RSI, RAX)
    // RAX = 9 (SYS_mmap)
    emit_mov_r64_imm64(ctx, RAX, 9)
    // RDX = 3 (PROT_READ|PROT_WRITE)
    emit_mov_r64_imm64(ctx, RDX, 3)
    // R10 = 0x22 (MAP_PRIVATE|MAP_ANONYMOUS)
    emit_mov_r64_imm64(ctx, R10, 34)
    // R8 = -1
    emit_mov_r64_imm64(ctx, R8, -1)
    // R9 = 0
    emit_mov_r64_imm64(ctx, R9, 0)
    emit_syscall(ctx)
    // RAX = new buffer pointer

    // Save new buffer pointer
    emit_push_r64(ctx, RAX)  // [RSP] = new_buf

    // Store total_len at [new_buf]
    emit_mov_r64_mem(ctx, RCX, RSP, 8)  // RCX = total_len (was pushed before new_buf)
    // Actually stack layout: [RSP]=new_buf, [RSP+8]=total_len, [RSP+16]=right, [RSP+24]=left
    emit_mov_r64_mem(ctx, RDX, RSP, 8)  // RDX = total_len
    // Store len at [RAX]
    // MOV [RAX], RDX
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0x10)  // MOV [RAX], RDX

    // Copy left string data: memcpy([new_buf+8], [left+8], left_len)
    // RDI = new_buf + 8
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x8D)
    code_byte(ctx, 0x78)
    code_byte(ctx, 0x08)  // LEA RDI, [RAX+8]
    // RSI = left + 8
    emit_mov_r64_mem(ctx, RSI, RSP, 24)  // RSI = left ptr
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC6)
    code_byte(ctx, 0x08)  // ADD RSI, 8
    // RCX = left_len = [left]
    emit_mov_r64_mem(ctx, RCX, RSP, 24)  // reload left ptr
    emit_mov_r64_mem(ctx, RCX, RCX, 0)   // RCX = [left] = left_len
    // REP MOVSB
    code_byte(ctx, 0xF3)
    code_byte(ctx, 0xA4)  // REP MOVSB

    // Copy right string data: memcpy([new_buf+8+left_len], [right+8], right_len)
    // RDI = new_buf + 8 + left_len (already at this position after previous REP MOVSB)
    // RSI = right + 8
    emit_mov_r64_mem(ctx, RSI, RSP, 16)  // RSI = right ptr
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC6)
    code_byte(ctx, 0x08)  // ADD RSI, 8
    // RCX = right_len = [right]
    emit_mov_r64_mem(ctx, RCX, RSP, 16)  // reload right ptr
    emit_mov_r64_mem(ctx, RCX, RCX, 0)   // RCX = [right] = right_len
    // REP MOVSB
    code_byte(ctx, 0xF3)
    code_byte(ctx, 0xA4)  // REP MOVSB

    // Restore new_buf pointer to RAX
    emit_pop_r64(ctx, RAX)   // RAX = new_buf, pop new_buf
    // Clean up stack: pop total_len, right, left
    emit_mov_r64_imm64(ctx, RCX, 24)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x01)
    code_byte(ctx, 0xCC)  // ADD RSP, RCX
    // RAX = new string pointer (length-prefixed)
    // Mark result type as string
    return

fn cg_call(ctx Ctx, e Node)
    let fa = e.a
    if fa[0].kind == "member"
        cg_method_call(ctx, e)
        return
    if fa[0].kind != "ident"
        emit_mov_r64_imm64(ctx, RAX, 0)
        return
    let fn_name = fa[0].sval
    if fn_name == "len"
        let args = e.list
        if args.len() > 0
            cg_expr(ctx, args[0])
            emit_mov_r64_mem(ctx, RAX, RAX, 0)
            return
        emit_mov_r64_imm64(ctx, RAX, 0)
        return
    if fn_name == "println"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            if arg.kind == "string_lit"
                cg_print_string_lit(ctx, arg.sval)
            if arg.kind == "int_lit"
                emit_mov_r64_imm64(ctx, RAX, parse_int(arg.sval))
                cg_print_int(ctx)
            if arg.kind == "float_lit"
                let fbits = parse_float_to_bits(arg.sval)
                if fbits == 0
                    emit_mov_r64_imm64(ctx, RAX, parse_int(arg.sval))
                else
                    emit_mov_r64_imm64(ctx, RAX, fbits)
                cg_print_float(ctx)
            if arg.kind == "ident"
                if ctx.var_types.has(arg.sval)
                    let vt = ctx.var_types[arg.sval]
                    if vt == "str"
                        let offset = cg_get_var_offset(ctx, arg.sval)
                        emit_mov_r64_mem(ctx, RAX, RBP, offset)
                        cg_print_string_val(ctx)
                    if vt == "int"
                        cg_expr(ctx, arg)
                        cg_print_int(ctx)
                    if vt == "float"
                        cg_expr(ctx, arg)
                        cg_print_float(ctx)
                if not ctx.var_types.has(arg.sval)
                    cg_expr(ctx, arg)
                    cg_print_int(ctx)
            if arg.kind != "string_lit" and arg.kind != "int_lit" and arg.kind != "ident"
                cg_expr(ctx, arg)
                cg_print_int(ctx)
        cg_print_string_lit(ctx, "\n")
        return
    if fn_name == "to_str"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            if arg.kind == "string_lit"
                let data_off = ctx.data_len
                cg_add_string(ctx, arg.sval)
                let lea_pos = ctx.code_len
                emit_lea_rip(ctx, RAX, 0)
                cg_add_fixup(ctx, lea_pos, data_off)
                return
            if arg.kind == "bool_true"
                let data_off = ctx.data_len
                cg_add_string(ctx, "true")
                let lea_pos = ctx.code_len
                emit_lea_rip(ctx, RAX, 0)
                cg_add_fixup(ctx, lea_pos, data_off)
                return
            if arg.kind == "bool_false"
                let data_off = ctx.data_len
                cg_add_string(ctx, "false")
                let lea_pos = ctx.code_len
                emit_lea_rip(ctx, RAX, 0)
                cg_add_fixup(ctx, lea_pos, data_off)
                return
            cg_expr(ctx, arg)
            cg_int_to_str(ctx)
            return
        emit_mov_r64_imm64(ctx, RAX, 0)
        return
    if fn_name == "print"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            // Dispatch based on argument type
            if arg.kind == "string_lit"
                cg_print_string_lit(ctx, arg.sval)
                return
            if arg.kind == "int_lit"
                emit_mov_r64_imm64(ctx, RAX, parse_int(arg.sval))
                cg_print_int(ctx)
                return
            if arg.kind == "bool_true"
                cg_print_string_lit(ctx, "true")
                return
            if arg.kind == "bool_false"
                cg_print_string_lit(ctx, "false")
                return
            if arg.kind == "ident"
                // Check tracked variable type
                if ctx.var_types.has(arg.sval)
                    let vt = ctx.var_types[arg.sval]
                    if vt == "str"
                        // Load string pointer from stack, print it
                        let offset = cg_get_var_offset(ctx, arg.sval)
                        emit_mov_r64_mem(ctx, RAX, RBP, offset)
                        cg_print_string_val(ctx)
                        return
                    if vt == "bool"
                        let offset = cg_get_var_offset(ctx, arg.sval)
                        emit_mov_r64_mem(ctx, RAX, RBP, offset)
                        // TEST RAX, 1; JNE print_true; print_false
                        code_byte(ctx, 0x48)
                        code_byte(ctx, 0xF7)
                        code_byte(ctx, 0xC0)  // TEST RAX, RAX (actually we want TEST RAX, 1)
                        // Actually use: AND RAX, 1; JNZ true
                        code_byte(ctx, 0x48)
                        code_byte(ctx, 0x83)
                        code_byte(ctx, 0xE0)
                        code_byte(ctx, 0x01)  // AND RAX, 1
                        code_byte(ctx, 0x75)  // JNE rel8
                        let false_jmp = ctx.code_len
                        code_byte(ctx, 0)  // placeholder, will fill in
                        cg_print_string_lit(ctx, "true")
                        code_byte(ctx, 0xEB)  // JMP rel8 (skip false)
                        let skip_jmp = ctx.code_len
                        code_byte(ctx, 0)  // placeholder
                        // false target:
                        let false_target = ctx.code_len
                        ctx.code_data[false_jmp] = ((false_target - (false_jmp + 1)) + 256) % 256
                        cg_print_string_lit(ctx, "false")
                        // skip target:
                        let skip_target = ctx.code_len
                        ctx.code_data[skip_jmp] = ((skip_target - (skip_jmp + 1)) + 256) % 256
                        return
                // Default: treat as integer
                cg_expr(ctx, arg)
                cg_print_int(ctx)
                return
            // For call expressions, check if it's to_str (returns string)
            if arg.kind == "call"
                let cfa = arg.a
                if cfa[0].kind == "ident"
                    if cfa[0].sval == "to_str"
                        cg_expr(ctx, arg)
                        cg_print_string_val(ctx)
                        return
            // For any other expression type, evaluate and print as integer
            cg_expr(ctx, arg)
            cg_print_int(ctx)
            return
        return
    // User-defined function call
    // Evaluate arguments and push them on the stack (right to left)
    let args = e.list
    let mut ai = args.len() - 1
    while ai >= 0
        cg_expr(ctx, args[ai])
        emit_push_r64(ctx, RAX)
        ai = ai - 1
    // Emit CALL with placeholder, record fixup
    code_byte(ctx, 0xE8)  // CALL rel32
    let call_pos = ctx.code_len
    code_u32(ctx, 0)  // placeholder
    // Record the call fixup: (call_pos, fn_name)
    let idx = ctx.call_fixup_count
    ctx.call_fixups[idx * 2] = call_pos
    ctx.call_fixups[idx * 2 + 1] = fn_name
    ctx.call_fixup_count = idx + 1
    // Clean up stack arguments (add RSP, n*8)
    let nargs = args.len()
    if nargs > 0
        emit_add_r64_r64(ctx, RSP, RAX)  // placeholder, fix below
        // Actually we need ADD RSP, imm32. Let me use the proper encoding.
        // But we already emitted ADD RAX, RSP which is wrong.
        // Let me fix: undo the last instruction and emit ADD RSP, imm32
        ctx.code_len = ctx.code_len - 3  // undo ADD RAX, RSP (REX.W 01 C0 = 3 bytes)
        emit_rex(ctx, true, false, false)
        code_byte(ctx, 0x81)
        code_byte(ctx, 0xC4)  // mod=11, reg=0, rm=RSP
        code_u32(ctx, nargs * 8)
    // Return value is in RAX
    return

// cg_print_string_lit: emit code to print a compile-time string literal.
// Stores the string in the data section and emits a write syscall.
fn cg_print_string_lit(ctx Ctx, s str)
    let data_off = ctx.data_len
    cg_add_string(ctx, s)
    let lea_pos = ctx.code_len
    emit_lea_rip(ctx, RSI, 0)
    cg_add_fixup(ctx, lea_pos, data_off + 8)
    emit_mov_r64_imm64(ctx, RAX, 1)   // SYS_write
    emit_mov_r64_imm64(ctx, RDI, 1)   // stdout
    emit_mov_r64_imm64(ctx, RDX, s.len())
    emit_syscall(ctx)

// cg_print_string_val: emit code to print a string whose pointer is in RAX.
// The pointer points to a length-prefixed string: [len:8 | data...]
fn cg_print_string_val(ctx Ctx)
    // RAX = pointer to length prefix
    // Save RAX in RBX (callee-saved across syscall)
    emit_mov_r64_r64(ctx, RBX, RAX)
    // Load length from [RBX] → RDX
    emit_mov_r64_mem(ctx, RDX, RBX, 0)
    // Compute data pointer: LEA RSI, [RBX+8]
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x8D)
    code_byte(ctx, 0x73)
    code_byte(ctx, 0x08)  // LEA RSI, [RBX+8]
    // sys_write(1, RSI, RDX)
    emit_mov_r64_imm64(ctx, RAX, 1)
    emit_mov_r64_imm64(ctx, RDI, 1)
    emit_syscall(ctx)

// cg_struct_lit: compile Point{x: 1, y: 2}
fn cg_struct_lit(ctx Ctx, e Node)
    let fields = e.list
    let nfields = fields.len()
    let total_size = 8 + nfields * 16
    emit_mov_r64_imm64(ctx, RDI, 0)
    emit_mov_r64_imm64(ctx, RSI, total_size)
    emit_mov_r64_imm64(ctx, RAX, 9)
    emit_mov_r64_imm64(ctx, RDX, 3)
    emit_mov_r64_imm64(ctx, R10, 34)
    emit_mov_r64_imm64(ctx, R8, -1)
    emit_mov_r64_imm64(ctx, R9, 0)
    emit_syscall(ctx)
    let tab_off = cg_get_var_offset(ctx, "__struct_lit_tmp__")
    emit_mov_mem_r64(ctx, RBP, tab_off, RAX)
    emit_mov_r64_imm64(ctx, RCX, nfields)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0x08)
    let mut fi = 0
    while fi < nfields
        let f = fields[fi]
        let va = f.a
        cg_expr(ctx, va[0])
        emit_push_r64(ctx, RAX)
        let name_data_off = ctx.data_len
        cg_add_string(ctx, f.sval)
        let lea_pos = ctx.code_len
        emit_lea_rip(ctx, RAX, 0)
        cg_add_fixup(ctx, lea_pos, name_data_off)
        emit_push_r64(ctx, RAX)
        emit_mov_r64_mem(ctx, RBX, RBP, tab_off)
        emit_pop_r64(ctx, RAX)
        let name_offset = 8 + fi * 16
        emit_mov_mem_r64(ctx, RBX, name_offset, RAX)
        emit_pop_r64(ctx, RAX)
        let val_offset = 8 + fi * 16 + 8
        emit_mov_mem_r64(ctx, RBX, val_offset, RAX)
        fi = fi + 1
    emit_mov_r64_mem(ctx, RAX, RBP, tab_off)

// cg_table_lit: compile {1: "a", 2: "b"}
fn cg_table_lit(ctx Ctx, e Node)
    let entries = e.list
    let nentries = entries.len()
    let total_size = 8 + nentries * 16
    emit_mov_r64_imm64(ctx, RDI, 0)
    emit_mov_r64_imm64(ctx, RSI, total_size)
    emit_mov_r64_imm64(ctx, RAX, 9)
    emit_mov_r64_imm64(ctx, RDX, 3)
    emit_mov_r64_imm64(ctx, R10, 34)
    emit_mov_r64_imm64(ctx, R8, -1)
    emit_mov_r64_imm64(ctx, R9, 0)
    emit_syscall(ctx)
    let tab_off = cg_get_var_offset(ctx, "__table_lit_tmp__")
    emit_mov_mem_r64(ctx, RBP, tab_off, RAX)
    emit_mov_r64_imm64(ctx, RCX, nentries)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0x08)
    let mut ei = 0
    while ei < nentries
        let entry = entries[ei]
        let ka = entry.a
        let vb = entry.b
        cg_expr(ctx, ka[0])
        emit_push_r64(ctx, RAX)
        cg_expr(ctx, vb[0])
        emit_push_r64(ctx, RAX)
        emit_mov_r64_mem(ctx, RBX, RBP, tab_off)
        emit_pop_r64(ctx, RAX)
        let val_off = 8 + ei * 16 + 8
        emit_mov_mem_r64(ctx, RBX, val_off, RAX)
        emit_pop_r64(ctx, RAX)
        let key_off = 8 + ei * 16
        emit_mov_mem_r64(ctx, RBX, key_off, RAX)
        ei = ei + 1
    emit_mov_r64_mem(ctx, RAX, RBP, tab_off)

// cg_member: compile obj.field — look up field by name
fn cg_member(ctx Ctx, e Node)
    let oa = e.a
    cg_expr(ctx, oa[0])
    emit_mov_r64_r64(ctx, RBX, RAX)
    emit_mov_r64_mem(ctx, R8, RBX, 0)
    let name_data_off = ctx.data_len
    cg_add_string(ctx, e.sval)
    let lea_pos = ctx.code_len
    emit_lea_rip(ctx, RAX, 0)
    cg_add_fixup(ctx, lea_pos, name_data_off)
    emit_mov_r64_r64(ctx, RSI, RAX)
    emit_mov_r64_imm64(ctx, RDX, 0)
    let loop_start = ctx.code_len
    emit_cmp_r64_r64(ctx, RDX, R8)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x8D)
    let not_found_pos = ctx.code_len
    code_u32(ctx, 0)
    emit_mov_r64_r64(ctx, RAX, RDX)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0xC1)
    code_byte(ctx, 0xE0)
    code_byte(ctx, 0x04)
    emit_add_r64_r64(ctx, RAX, RBX)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x08)
    let entry_off = cg_get_var_offset(ctx, "__member_entry__")
    emit_mov_mem_r64(ctx, RBP, entry_off, RAX)
    emit_mov_r64_mem(ctx, RCX, RAX, 0)
    emit_mov_r64_mem(ctx, RDI, RCX, 0)
    emit_mov_r64_mem(ctx, R9, RSI, 0)
    emit_cmp_r64_r64(ctx, RDI, R9)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x85)
    let jne1_pos = ctx.code_len
    code_u32(ctx, 0)
    emit_mov_r64_mem(ctx, RDI, RCX, 8)
    emit_mov_r64_mem(ctx, R9, RSI, 8)
    emit_cmp_r64_r64(ctx, RDI, R9)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x85)
    let jne2_pos = ctx.code_len
    code_u32(ctx, 0)
    emit_mov_r64_mem(ctx, RAX, RBP, entry_off)
    emit_mov_r64_mem(ctx, RAX, RAX, 8)
    code_byte(ctx, 0xE9)
    let end_jmp_pos = ctx.code_len
    code_u32(ctx, 0)
    let next_pos = ctx.code_len
    let jne1_disp = next_pos - (jne1_pos + 4)
    ctx.code_data[jne1_pos] = ((jne1_disp % 256) + 256) % 256
    ctx.code_data[jne1_pos + 1] = (((jne1_disp / 256) % 256) + 256) % 256
    ctx.code_data[jne1_pos + 2] = (((jne1_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jne1_pos + 3] = (((jne1_disp / 16777216) % 256) + 256) % 256
    let jne2_disp = next_pos - (jne2_pos + 4)
    ctx.code_data[jne2_pos] = ((jne2_disp % 256) + 256) % 256
    ctx.code_data[jne2_pos + 1] = (((jne2_disp / 256) % 256) + 256) % 256
    ctx.code_data[jne2_pos + 2] = (((jne2_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jne2_pos + 3] = (((jne2_disp / 16777216) % 256) + 256) % 256
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC2)
    code_byte(ctx, 0x01)
    code_byte(ctx, 0xE9)
    let back_disp = loop_start - (ctx.code_len + 4)
    code_u32(ctx, back_disp)
    let not_found_target = ctx.code_len
    let nf_disp = not_found_target - (not_found_pos + 4)
    ctx.code_data[not_found_pos] = ((nf_disp % 256) + 256) % 256
    ctx.code_data[not_found_pos + 1] = (((nf_disp / 256) % 256) + 256) % 256
    ctx.code_data[not_found_pos + 2] = (((nf_disp / 65536) % 256) + 256) % 256
    ctx.code_data[not_found_pos + 3] = (((nf_disp / 16777216) % 256) + 256) % 256
    emit_mov_r64_imm64(ctx, RAX, 0)
    let end_pos = ctx.code_len
    let end_disp = end_pos - (end_jmp_pos + 4)
    ctx.code_data[end_jmp_pos] = ((end_disp % 256) + 256) % 256
    ctx.code_data[end_jmp_pos + 1] = (((end_disp / 256) % 256) + 256) % 256
    ctx.code_data[end_jmp_pos + 2] = (((end_disp / 65536) % 256) + 256) % 256
    ctx.code_data[end_jmp_pos + 3] = (((end_disp / 16777216) % 256) + 256) % 256

// cg_index: compile obj[key]
fn cg_index(ctx Ctx, e Node)
    let oa = e.a
    let kb = e.b
    let target_expr = oa[0]
    if cg_is_string_expr(ctx, target_expr)
        cg_expr(ctx, target_expr)
        let str_off = cg_get_var_offset(ctx, "__index_str__")
        emit_mov_mem_r64(ctx, RBP, str_off, RAX)
        cg_expr(ctx, kb[0])
        emit_mov_r64_mem(ctx, RBX, RBP, str_off)
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x8D)
        code_byte(ctx, 0x5B)
        code_byte(ctx, 0x08)
        emit_add_r64_r64(ctx, RBX, RAX)
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0xB6)
        code_byte(ctx, 0x03)
        return
    cg_expr(ctx, oa[0])
    let tab_off = cg_get_var_offset(ctx, "__index_tab__")
    emit_mov_mem_r64(ctx, RBP, tab_off, RAX)
    cg_expr(ctx, kb[0])
    let key_off = cg_get_var_offset(ctx, "__index_key__")
    emit_mov_mem_r64(ctx, RBP, key_off, RAX)
    emit_mov_r64_mem(ctx, RBX, RBP, tab_off)
    emit_mov_r64_mem(ctx, R8, RBX, 0)
    emit_mov_r64_mem(ctx, RSI, RBP, key_off)
    emit_mov_r64_imm64(ctx, RDX, 0)
    let loop_start = ctx.code_len
    emit_cmp_r64_r64(ctx, RDX, R8)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x8D)
    let not_found_pos = ctx.code_len
    code_u32(ctx, 0)
    emit_mov_r64_r64(ctx, RAX, RDX)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0xC1)
    code_byte(ctx, 0xE0)
    code_byte(ctx, 0x04)
    emit_add_r64_r64(ctx, RAX, RBX)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x08)
    let entry_off = cg_get_var_offset(ctx, "__idx_entry__")
    emit_mov_mem_r64(ctx, RBP, entry_off, RAX)
    emit_mov_r64_mem(ctx, RCX, RAX, 0)
    emit_cmp_r64_r64(ctx, RCX, RSI)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x85)
    let jne_pos = ctx.code_len
    code_u32(ctx, 0)
    emit_mov_r64_mem(ctx, RAX, RBP, entry_off)
    emit_mov_r64_mem(ctx, RAX, RAX, 8)
    code_byte(ctx, 0xE9)
    let end_jmp_pos = ctx.code_len
    code_u32(ctx, 0)
    let next_pos = ctx.code_len
    let jne_disp = next_pos - (jne_pos + 4)
    ctx.code_data[jne_pos] = ((jne_disp % 256) + 256) % 256
    ctx.code_data[jne_pos + 1] = (((jne_disp / 256) % 256) + 256) % 256
    ctx.code_data[jne_pos + 2] = (((jne_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jne_pos + 3] = (((jne_disp / 16777216) % 256) + 256) % 256
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC2)
    code_byte(ctx, 0x01)
    code_byte(ctx, 0xE9)
    let back_disp = loop_start - (ctx.code_len + 4)
    code_u32(ctx, back_disp)
    let not_found_target = ctx.code_len
    let nf_disp = not_found_target - (not_found_pos + 4)
    ctx.code_data[not_found_pos] = ((nf_disp % 256) + 256) % 256
    ctx.code_data[not_found_pos + 1] = (((nf_disp / 256) % 256) + 256) % 256
    ctx.code_data[not_found_pos + 2] = (((nf_disp / 65536) % 256) + 256) % 256
    ctx.code_data[not_found_pos + 3] = (((nf_disp / 16777216) % 256) + 256) % 256
    emit_mov_r64_imm64(ctx, RAX, 0)
    let end_pos = ctx.code_len
    let end_disp = end_pos - (end_jmp_pos + 4)
    ctx.code_data[end_jmp_pos] = ((end_disp % 256) + 256) % 256
    ctx.code_data[end_jmp_pos + 1] = (((end_disp / 256) % 256) + 256) % 256
    ctx.code_data[end_jmp_pos + 2] = (((end_disp / 65536) % 256) + 256) % 256
    ctx.code_data[end_jmp_pos + 3] = (((end_disp / 16777216) % 256) + 256) % 256

// Print the integer in RAX to stdout.
fn cg_print_float(ctx Ctx)
    emit_push_r64(ctx, RAX)
    code_byte(ctx, 0xF3)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x7E)
    code_byte(ctx, 0x04)
    code_byte(ctx, 0x24)
    emit_mov_r64_imm64(ctx, RAX, 4696837146684686336)
    emit_push_r64(ctx, RAX)
    code_byte(ctx, 0xF3)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x7E)
    code_byte(ctx, 0x0C)
    code_byte(ctx, 0x24)
    code_byte(ctx, 0xF2)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x59)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0xF2)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x2D)
    code_byte(ctx, 0xC0)
    emit_pop_r64(ctx, RCX)
    emit_pop_r64(ctx, RCX)
    cg_print_int(ctx)

// Uses the stack as a temporary buffer for digit characters.
fn cg_print_int(ctx Ctx)
    // Print integer in RAX to stdout.
    // Strategy: push a sentinel (0), then push digits (LSB first),
    // then pop and write each digit (MSB first) until sentinel.
    emit_mov_r64_r64(ctx, RBX, RAX)  // RBX = value
    // Push sentinel 0
    emit_mov_r64_imm64(ctx, RAX, 0)
    emit_push_r64(ctx, RAX)
    // Handle zero: if RBX == 0, push '0'
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xDB)  // TEST RBX, RBX
    code_byte(ctx, 0x75)  // JNE skip_zero
    code_byte(ctx, 16)    // skip 16 bytes (push '0' + jmp to pop_loop)
    // Push '0' (48)
    emit_mov_r64_imm64(ctx, RAX, 48)
    emit_push_r64(ctx, RAX)
    code_byte(ctx, 0xE9)  // JMP to pop_loop
    let jmp_pop_pos = ctx.code_len
    code_u32(ctx, 0)  // placeholder
    // Digit loop:
    let loop_start = ctx.code_len
    emit_mov_r64_r64(ctx, RAX, RBX)
    emit_mov_r64_imm64(ctx, RCX, 10)
    emit_cqo(ctx)
    emit_idiv_r64(ctx, RCX)
    emit_mov_r64_r64(ctx, RBX, RAX)  // RBX = quotient
    // ADD RDX, 48
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC2)
    code_byte(ctx, 0x30)
    emit_push_r64(ctx, RDX)  // push digit char
    // TEST RBX, RBX → JNE loop_start
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xDB)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x85)  // JNE rel32
    let back_disp = loop_start - (ctx.code_len + 4)
    code_u32(ctx, back_disp)
    // Fixup the JMP from zero case to here (pop_loop)
    let pop_loop = ctx.code_len
    let jmp_disp = pop_loop - (jmp_pop_pos + 4)
    ctx.code_data[jmp_pop_pos] = ((jmp_disp % 256) + 256) % 256
    ctx.code_data[jmp_pop_pos + 1] = (((jmp_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_pop_pos + 2] = (((jmp_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_pop_pos + 3] = (((jmp_disp / 16777216) % 256) + 256) % 256
    // Pop loop: pop digit, check sentinel, write it
    let pop_start = ctx.code_len
    emit_pop_r64(ctx, RSI)  // RSI = digit char (or 0 sentinel)
    // TEST RSI, RSI → JZ done
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xF6)  // TEST RSI, RSI
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x84)  // JE rel32
    let je_done_pos = ctx.code_len
    code_u32(ctx, 0)  // placeholder
    // Write 1 byte from RSI to stdout
    // RSI already has the char. Use RSP-relative addressing:
    // PUSH RSI (put char on stack), then write(1, rsp, 1), then POP
    emit_push_r64(ctx, RSI)
    // MOV RSI, RSP (pointer to the byte on stack)
    // 48 89 E6 = MOV RSI, RSP
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0xE6)
    emit_mov_r64_imm64(ctx, RAX, 1)  // SYS_write
    emit_mov_r64_imm64(ctx, RDI, 1)  // stdout
    emit_mov_r64_imm64(ctx, RDX, 1)  // 1 byte
    emit_syscall(ctx)
    emit_pop_r64(ctx, RSI)  // clean up stack
    // JMP back to pop_start
    code_byte(ctx, 0xE9)
    let pop_back_disp = pop_start - (ctx.code_len + 4)
    code_u32(ctx, pop_back_disp)
    // Done: fixup JE
    let done_pos = ctx.code_len
    let je_disp = done_pos - (je_done_pos + 4)
    ctx.code_data[je_done_pos] = ((je_disp % 256) + 256) % 256
    ctx.code_data[je_done_pos + 1] = (((je_disp / 256) % 256) + 256) % 256
    ctx.code_data[je_done_pos + 2] = (((je_disp / 65536) % 256) + 256) % 256
    ctx.code_data[je_done_pos + 3] = (((je_disp / 16777216) % 256) + 256) % 256


fn cg_stmt(ctx Ctx, s Node)
    // Multi-target dispatch: AArch64 path
    if ctx.target == 1
        arm_cg_stmt(ctx, s)
        return
    // Multi-target dispatch: RV64 path
    if ctx.target == 2
        rv_cg_stmt(ctx, s)
        return
    // Multi-target dispatch: WASM path
    if ctx.target == 3
        wasm_cg_stmt(ctx, s)
        return
    // Multi-target dispatch: RV32 path
    if ctx.target == 4
        rv32_cg_stmt(ctx, s)
        return
    if s.kind == "let_stmt"
        let va = s.a
        let init = va[0]
        // Track variable type for print dispatch
        if init.kind == "string_lit"
            ctx.var_types[s.sval] = "str"
        if init.kind == "int_lit"
            ctx.var_types[s.sval] = "int"
        if init.kind == "float_lit"
            ctx.var_types[s.sval] = "float"
        if init.kind == "bool_true"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "bool_false"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "ident"
            if ctx.var_types.has(init.sval)
                ctx.var_types[s.sval] = ctx.var_types[init.sval]
        if init.kind == "binary"
            // String concatenation: if op is "+" and both sides are strings, result is string
            if init.sval == "+"
                let la = init.a
                let rb = init.b
                if cg_is_string_expr(ctx, la[0]) and cg_is_string_expr(ctx, rb[0])
                    ctx.var_types[s.sval] = "str"
        if init.kind == "call"
            // Check function return type
            let fa = init.a
            if fa[0].kind == "ident"
                let fname = fa[0].sval
                // Builtins that return strings
                if fname == "to_str"
                    ctx.var_types[s.sval] = "str"
                if ctx.fn_ret_types.has(fname)
                    let rt = ctx.fn_ret_types[fname]
                    if rt == "str"
                        ctx.var_types[s.sval] = "str"
                    if rt == "int"
                        ctx.var_types[s.sval] = "int"
                    if rt == "bool"
                        ctx.var_types[s.sval] = "bool"
            if fa[0].kind == "member"
                let mname = fa[0].sval
                if mname == "upper" or mname == "lower" or mname == "trim"
                    ctx.var_types[s.sval] = "str"
                if mname == "bytes"
                    ctx.var_types[s.sval] = "str"
        cg_expr(ctx, init)
        let offset = cg_get_var_offset(ctx, s.sval)
        emit_mov_mem_r64(ctx, RBP, offset, RAX)
        return
    if s.kind == "return"
        if s.a.has(0)
            let va = s.a
            cg_expr(ctx, va[0])
        if ctx.is_main
            emit_mov_r64_r64(ctx, RDI, RAX)
            emit_mov_r64_imm64(ctx, RAX, 60)
            emit_syscall(ctx)
        else
            emit_mov_r64_r64(ctx, RSP, RBP)
            emit_pop_r64(ctx, RBP)
            code_byte(ctx, 0xC3)  // RET
        return
    if s.kind == "expr_stmt"
        let ea = s.a
        cg_expr(ctx, ea[0])
        return
    if s.kind == "assign"
        let ea = s.a
        let vb = s.b
        let target = ea[0]
        if target.kind == "ident"
            cg_expr(ctx, vb[0])
            let offset = cg_get_var_offset(ctx, target.sval)
            emit_mov_mem_r64(ctx, RBP, offset, RAX)
            return
        if target.kind == "member"
            cg_member_assign(ctx, target, vb[0])
            return
        if target.kind == "index"
            cg_index_assign(ctx, target, vb[0])
            return
        return
    if s.kind == "if_stmt"
        cg_if(ctx, s)
        return
    if s.kind == "while_stmt"
        cg_while(ctx, s)
        return
    if s.kind == "for_stmt"
        if s.bval
            cg_for_range(ctx, s)
        return
    if s.kind == "match_stmt"
        cg_match(ctx, s)
        return
    if s.kind == "assert_stmt"
        cg_assert(ctx, s)
        return
    if s.kind == "let_tuple"
        let va = s.a
        cg_expr(ctx, va[0])
        let tab_off = cg_get_var_offset(ctx, "__let_tuple_tab__")
        emit_mov_mem_r64(ctx, RBP, tab_off, RAX)
        let names = s.list
        let mut i = 0
        while i < names.len()
            let name = names[i]
            emit_mov_r64_mem(ctx, RBX, RBP, tab_off)
            emit_mov_r64_imm64(ctx, RAX, i)
            code_byte(ctx, 0x48)
            code_byte(ctx, 0xC1)
            code_byte(ctx, 0xE0)
            code_byte(ctx, 0x04)
            emit_add_r64_r64(ctx, RAX, RBX)
            code_byte(ctx, 0x48)
            code_byte(ctx, 0x83)
            code_byte(ctx, 0xC0)
            code_byte(ctx, 0x08)
            emit_mov_r64_mem(ctx, RAX, RAX, 8)
            let off = cg_get_var_offset(ctx, name)
            emit_mov_mem_r64(ctx, RBP, off, RAX)
            i = i + 1
        return
    if s.kind == "break"
        // Emit JMP to end of current loop (forward, fixup later)
        code_byte(ctx, 0xE9)  // JMP rel32
        let pos = ctx.code_len
        code_u32(ctx, 0)  // placeholder
        ctx.break_fixups[ctx.break_fixup_count] = pos
        ctx.break_fixup_count = ctx.break_fixup_count + 1
        return
    if s.kind == "continue"
        // Emit JMP to loop start (continue_targets[loop_depth-1])
        code_byte(ctx, 0xE9)  // JMP rel32
        let target = ctx.continue_targets[ctx.loop_depth - 1]
        let disp = target - (ctx.code_len + 4)
        code_u32(ctx, disp)
        return

fn cg_if(ctx Ctx, s Node)
    // if_stmt has:
    //   s.list = table of branch nodes (branch 0 = if, branch 1+ = but)
    //   s.a = else block (may be empty)
    // Each branch node has:
    //   b.a = {0: condition expr}
    //   b.b = block (table of statements)
    let branches = s.list
    let mut bi = 0
    // Collect positions of forward jumps that need fixup (to skip to end)
    let mut end_jumps = {}
    let mut njumps = 0
    while bi < branches.len()
        let b = branches[bi]
        let ca = b.a
        // Evaluate condition → RAX
        cg_expr(ctx, ca[0])
        // TEST RAX, RAX → ZF=1 if RAX==0
        // We use: OR RAX, RAX (sets ZF, doesn't change RAX)
        // Encoding: 48 09 C0 = OR RAX, RAX
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x09)
        code_byte(ctx, 0xC0)
        // JZ end_of_this_branch (jump if zero/false)
        // JZ rel32 = 0F 84 + disp32
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0x84)
        let jz_pos = ctx.code_len
        code_u32(ctx, 0)  // placeholder, fixup later
        // Generate then-block
        let block = b.b
        let mut si = 0
        while si < block.len()
            cg_stmt(ctx, block[si])
            si = si + 1
        // JMP to end (skip remaining branches and else)
        // JMP rel32 = E9 + disp32
        code_byte(ctx, 0xE9)
        let jmp_pos = ctx.code_len
        code_u32(ctx, 0)  // placeholder
        end_jumps[njumps] = jmp_pos
        njumps = njumps + 1
        // Fixup the JZ: it should jump to HERE (after the JMP)
        let jz_disp = ctx.code_len - (jz_pos + 4)
        ctx.code_data[jz_pos] = ((jz_disp % 256) + 256) % 256
        ctx.code_data[jz_pos + 1] = (((jz_disp / 256) % 256) + 256) % 256
        ctx.code_data[jz_pos + 2] = (((jz_disp / 65536) % 256) + 256) % 256
        ctx.code_data[jz_pos + 3] = (((jz_disp / 16777216) % 256) + 256) % 256
        bi = bi + 1
    // Else block (if any)
    if s.a.has(0)
        let else_block = s.a
        let mut si = 0
        while si < else_block.len()
            cg_stmt(ctx, else_block[si])
            si = si + 1
    // Fixup all end jumps to point HERE
    let end_pos = ctx.code_len
    let mut ji = 0
    while ji < njumps
        let jmp_pos = end_jumps[ji]
        let disp = end_pos - (jmp_pos + 4)
        ctx.code_data[jmp_pos] = ((disp % 256) + 256) % 256
        ctx.code_data[jmp_pos + 1] = (((disp / 256) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 2] = (((disp / 65536) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 3] = (((disp / 16777216) % 256) + 256) % 256
        ji = ji + 1

fn cg_while(ctx Ctx, s Node)
    // while_stmt has:
    //   s.a = {0: condition expr}
    //   s.list = body (table of statements)
    let loop_start = ctx.code_len

    // Push loop context for break/continue
    let saved_depth = ctx.loop_depth
    let saved_break_count = ctx.break_fixup_count
    ctx.continue_targets[ctx.loop_depth] = loop_start
    ctx.loop_depth = ctx.loop_depth + 1

    let ca = s.a
    // Evaluate condition → RAX
    cg_expr(ctx, ca[0])
    // OR RAX, RAX (test if zero)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x09)
    code_byte(ctx, 0xC0)
    // JZ end (jump if false)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x84)
    let jz_pos = ctx.code_len
    code_u32(ctx, 0)  // placeholder
    // Generate body
    let body = s.list
    let mut si = 0
    while si < body.len()
        cg_stmt(ctx, body[si])
        si = si + 1
    // JMP back to loop_start
    // JMP rel32 = E9 + disp32
    code_byte(ctx, 0xE9)
    let back_disp = loop_start - (ctx.code_len + 4)
    code_u32(ctx, back_disp)
    // Fixup JZ to point HERE (end of loop)
    let end_pos = ctx.code_len
    let jz_disp = end_pos - (jz_pos + 4)
    ctx.code_data[jz_pos] = ((jz_disp % 256) + 256) % 256
    ctx.code_data[jz_pos + 1] = (((jz_disp / 256) % 256) + 256) % 256
    ctx.code_data[jz_pos + 2] = (((jz_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jz_pos + 3] = (((jz_disp / 16777216) % 256) + 256) % 256

    // Fixup all break jumps emitted during this loop to point HERE
    let mut bi = saved_break_count
    while bi < ctx.break_fixup_count
        let bpos = ctx.break_fixups[bi]
        let bdisp = end_pos - (bpos + 4)
        ctx.code_data[bpos] = ((bdisp % 256) + 256) % 256
        ctx.code_data[bpos + 1] = (((bdisp / 256) % 256) + 256) % 256
        ctx.code_data[bpos + 2] = (((bdisp / 65536) % 256) + 256) % 256
        ctx.code_data[bpos + 3] = (((bdisp / 16777216) % 256) + 256) % 256
        bi = bi + 1
    // Restore loop context
    ctx.break_fixup_count = saved_break_count
    ctx.loop_depth = saved_depth

// cg_for_range: for i in low..high { body }
fn cg_for_range(ctx Ctx, s Node)
    let la = s.a
    let rb = s.b
    cg_expr(ctx, la[0])
    let loop_var_offset = cg_get_var_offset(ctx, s.sval)
    emit_mov_mem_r64(ctx, RBP, loop_var_offset, RAX)
    ctx.var_types[s.sval] = "int"
    let saved_depth = ctx.loop_depth
    let saved_break_count = ctx.break_fixup_count
    let loop_start = ctx.code_len
    ctx.continue_targets[ctx.loop_depth] = loop_start
    ctx.loop_depth = ctx.loop_depth + 1
    emit_mov_r64_mem(ctx, RAX, RBP, loop_var_offset)
    emit_push_r64(ctx, RAX)
    cg_expr(ctx, rb[0])
    emit_pop_r64(ctx, RBX)
    emit_cmp_r64_r64(ctx, RBX, RAX)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x8D)
    let jge_pos = ctx.code_len
    code_u32(ctx, 0)
    let body = s.list
    let mut si = 0
    while si < body.len()
        cg_stmt(ctx, body[si])
        si = si + 1
    emit_mov_r64_mem(ctx, RAX, RBP, loop_var_offset)
    emit_mov_r64_imm64(ctx, RCX, 1)
    emit_add_r64_r64(ctx, RAX, RCX)
    emit_mov_mem_r64(ctx, RBP, loop_var_offset, RAX)
    code_byte(ctx, 0xE9)
    let back_disp = loop_start - (ctx.code_len + 4)
    code_u32(ctx, back_disp)
    let end_pos = ctx.code_len
    let jge_disp = end_pos - (jge_pos + 4)
    ctx.code_data[jge_pos] = ((jge_disp % 256) + 256) % 256
    ctx.code_data[jge_pos + 1] = (((jge_disp / 256) % 256) + 256) % 256
    ctx.code_data[jge_pos + 2] = (((jge_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jge_pos + 3] = (((jge_disp / 16777216) % 256) + 256) % 256
    let mut bi = saved_break_count
    while bi < ctx.break_fixup_count
        let bpos = ctx.break_fixups[bi]
        let bdisp = end_pos - (bpos + 4)
        ctx.code_data[bpos] = ((bdisp % 256) + 256) % 256
        ctx.code_data[bpos + 1] = (((bdisp / 256) % 256) + 256) % 256
        ctx.code_data[bpos + 2] = (((bdisp / 65536) % 256) + 256) % 256
        ctx.code_data[bpos + 3] = (((bdisp / 16777216) % 256) + 256) % 256
        bi = bi + 1
    ctx.break_fixup_count = saved_break_count
    ctx.loop_depth = saved_depth

// cg_match: match x { case v { body } default { body } }
fn cg_match(ctx Ctx, s Node)
    let sa = s.a
    cg_expr(ctx, sa[0])
    let subj_off = cg_get_var_offset(ctx, "__match_subj__")
    emit_mov_mem_r64(ctx, RBP, subj_off, RAX)
    let cases = s.list
    let mut end_jumps = {}
    let mut njumps = 0
    let mut ci = 0
    while ci < cases.len()
        let c = cases[ci]
        let ca = c.a
        cg_expr(ctx, ca[0])
        emit_mov_r64_mem(ctx, RCX, RBP, subj_off)
        emit_cmp_r64_r64(ctx, RCX, RAX)
        code_byte(ctx, 0x0F)
        code_byte(ctx, 0x85)
        let jne_pos = ctx.code_len
        code_u32(ctx, 0)
        let body = c.b
        let mut si = 0
        while si < body.len()
            cg_stmt(ctx, body[si])
            si = si + 1
        code_byte(ctx, 0xE9)
        let jmp_pos = ctx.code_len
        code_u32(ctx, 0)
        end_jumps[njumps] = jmp_pos
        njumps = njumps + 1
        let jne_disp = ctx.code_len - (jne_pos + 4)
        ctx.code_data[jne_pos] = ((jne_disp % 256) + 256) % 256
        ctx.code_data[jne_pos + 1] = (((jne_disp / 256) % 256) + 256) % 256
        ctx.code_data[jne_pos + 2] = (((jne_disp / 65536) % 256) + 256) % 256
        ctx.code_data[jne_pos + 3] = (((jne_disp / 16777216) % 256) + 256) % 256
        ci = ci + 1
    if s.b.has(0)
        let default_block = s.b
        let mut si = 0
        while si < default_block.len()
            cg_stmt(ctx, default_block[si])
            si = si + 1
    let end_pos = ctx.code_len
    let mut ji = 0
    while ji < njumps
        let jmp_pos = end_jumps[ji]
        let disp = end_pos - (jmp_pos + 4)
        ctx.code_data[jmp_pos] = ((disp % 256) + 256) % 256
        ctx.code_data[jmp_pos + 1] = (((disp / 256) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 2] = (((disp / 65536) % 256) + 256) % 256
        ctx.code_data[jmp_pos + 3] = (((disp / 16777216) % 256) + 256) % 256
        ji = ji + 1

// cg_assert: assert cond, msg
fn cg_assert(ctx Ctx, s Node)
    let ca = s.a
    cg_expr(ctx, ca[0])
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x84)
    let jz_pos = ctx.code_len
    code_u32(ctx, 0)
    code_byte(ctx, 0xE9)
    let jmp_end_pos = ctx.code_len
    code_u32(ctx, 0)
    let fail_pos = ctx.code_len
    let jz_disp = fail_pos - (jz_pos + 4)
    ctx.code_data[jz_pos] = ((jz_disp % 256) + 256) % 256
    ctx.code_data[jz_pos + 1] = (((jz_disp / 256) % 256) + 256) % 256
    ctx.code_data[jz_pos + 2] = (((jz_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jz_pos + 3] = (((jz_disp / 16777216) % 256) + 256) % 256
    let mb = s.b
    let msg_expr = mb[0]
    if msg_expr.kind == "string_lit"
        cg_print_string_lit(ctx, msg_expr.sval)
    if msg_expr.kind != "string_lit"
        cg_print_string_lit(ctx, "Assertion failed")
    emit_mov_r64_imm64(ctx, RAX, 60)
    emit_mov_r64_imm64(ctx, RDI, 1)
    emit_syscall(ctx)
    let end_pos = ctx.code_len
    let end_disp = end_pos - (jmp_end_pos + 4)
    ctx.code_data[jmp_end_pos] = ((end_disp % 256) + 256) % 256
    ctx.code_data[jmp_end_pos + 1] = (((end_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_end_pos + 2] = (((end_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_end_pos + 3] = (((end_disp / 16777216) % 256) + 256) % 256

fn cg_function(ctx Ctx, fn_decl Node, is_main bool)
    // Multi-target dispatch: AArch64 path
    if ctx.target == 1
        arm_cg_function(ctx, fn_decl, is_main)
        return
    // Multi-target dispatch: RV64 path
    if ctx.target == 2
        rv_cg_function(ctx, fn_decl, is_main)
        return
    // Multi-target dispatch: WASM path
    if ctx.target == 3
        wasm_cg_function_v2(ctx, fn_decl, is_main)
        return
    // Multi-target dispatch: RV32 path
    if ctx.target == 4
        rv32_cg_function(ctx, fn_decl, is_main)
        return
    // Record function start offset
    let fn_start = ctx.code_len
    let fn_name = fn_decl.sval
    ctx.fn_table[fn_name] = fn_start
    ctx.fn_count = ctx.fn_count + 1
    ctx.var_slots = {}
    ctx.next_slot = -8
    ctx.var_types = {}
    let prologue_start = ctx.code_len
    emit_push_r64(ctx, RBP)
    emit_mov_rbp_rsp(ctx)
    emit_sub_rsp_imm32(ctx, 0)
    let params = fn_decl.a
    let mut pi = 0
    while pi < params.len()
        let param = params[pi]
        let param_stack_offset = 16 + pi * 8
        let local_offset = cg_get_var_offset(ctx, param.sval)
        emit_mov_r64_mem(ctx, RAX, RBP, param_stack_offset)
        emit_mov_mem_r64(ctx, RBP, local_offset, RAX)
        ctx.var_types[param.sval] = param.extra
        pi = pi + 1
    ctx.is_main = is_main
    let body = fn_decl.list
    let mut i = 0
    while i < body.len()
        cg_stmt(ctx, body[i])
        i = i + 1
    if is_main
        emit_mov_r64_imm64(ctx, RAX, 0)
        emit_mov_r64_r64(ctx, RDI, RAX)
        emit_mov_r64_imm64(ctx, RAX, 60)
        emit_syscall(ctx)
    if not is_main
        emit_mov_r64_imm64(ctx, RAX, 0)
        emit_mov_r64_r64(ctx, RSP, RBP)
        emit_pop_r64(ctx, RBP)
        code_byte(ctx, 0xC3)
    let frame_size = 0 - ctx.next_slot - 8
    if frame_size > 0
        let imm_offset = prologue_start + 7
        ctx.code_data[imm_offset] = ((frame_size % 256) + 256) % 256
        ctx.code_data[imm_offset + 1] = (((frame_size / 256) % 256) + 256) % 256
        ctx.code_data[imm_offset + 2] = (((frame_size / 65536) % 256) + 256) % 256
        ctx.code_data[imm_offset + 3] = (((frame_size / 16777216) % 256) + 256) % 256

// ---------------------------------------------------------------------------
// Section 7: Compile a Yilt program
// ---------------------------------------------------------------------------

fn compile_program(src str, output_path str) int
    let tokens = lex_all(src)
    let result = parse_program(tokens)
    if result.nerrors > 0
        print("Parse errors: ")
        print(result.nerrors)
        let mut ei = 0
        while ei < result.nerrors
            print("  ")
            print(result.errors[ei])
            ei = ei + 1
        return 1

    let decls = result.decls
    let ctx = ctx_new()

    // Multi-target selection: check for marker files.
    // /tmp/yilt_target_arm64 → AArch64 (target=1)
    // /tmp/yilt_target_rv64  → RISC-V 64 (target=2)
    // /tmp/yilt_target_wasm  → WebAssembly (target=3)
    // Otherwise → x86_64 (target=0)
    let target_fd = sys.open("/tmp/yilt_target_arm64", 0, 0)
    if target_fd >= 0
        sys.close(target_fd)
        ctx.target = 1
    let target_fd2 = sys.open("/tmp/yilt_target_rv64", 0, 0)
    if target_fd2 >= 0
        sys.close(target_fd2)
        ctx.target = 2
    let target_fd3 = sys.open("/tmp/yilt_target_wasm", 0, 0)
    if target_fd3 >= 0
        sys.close(target_fd3)
        ctx.target = 3
    let target_fd4 = sys.open("/tmp/yilt_target_rv32", 0, 0)
    if target_fd4 >= 0
        sys.close(target_fd4)
        ctx.target = 4  // RV32 full codegen

    // Pre-scan: record function return types for type dispatch in print.
    let mut i = 0
    while i < decls.len()
        let d = decls[i]
        if d.kind == "fn_decl"
            ctx.fn_ret_types[d.sval] = d.extra
        i = i + 1

    // Pass 1: Compile main first (entry point = start of code section)
    let mut main_fn = n_kind("empty")
    i = 0
    while i < decls.len()
        let d = decls[i]
        if d.kind == "fn_decl"
            if d.sval == "main"
                main_fn = d
        i = i + 1

    if main_fn.kind == "empty"
        // No main function — compile all functions and produce a minimal binary
        i = 0
        while i < decls.len()
            let d = decls[i]
            if d.kind == "fn_decl"
                cg_function(ctx, d, false)
            i = i + 1
        if ctx.target == 1
            arm_apply_fixups(ctx)
            arm_apply_call_fixups(ctx)
            // Exit syscall for AArch64
            arm_mov_imm64(ctx, X0, 0)
            arm_mov_imm64(ctx, X8, 93)
            arm_svc(ctx)
        else
            if ctx.target == 2 or ctx.target == 4
                rv_apply_fixups(ctx)
                rv_apply_call_fixups(ctx)
                // Exit syscall for RV64/RV32
                rv_li(ctx, RV_A0, 0)
                rv_li(ctx, RV_A7, 93)
                rv_ecall(ctx)
            else
                cg_apply_fixups(ctx)
                let mut ci = 0
                while ci < ctx.call_fixup_count
                    let call_pos = ctx.call_fixups[ci * 2]
                    let fn_name = ctx.call_fixups[ci * 2 + 1]
                    if ctx.fn_table.has(fn_name)
                        let fn_start = ctx.fn_table[fn_name]
                        let disp = fn_start - (call_pos + 4)
                        ctx.code_data[call_pos] = ((disp % 256) + 256) % 256
                        ctx.code_data[call_pos + 1] = (((disp / 256) % 256) + 256) % 256
                        ctx.code_data[call_pos + 2] = (((disp / 65536) % 256) + 256) % 256
                        ctx.code_data[call_pos + 3] = (((disp / 16777216) % 256) + 256) % 256
                    ci = ci + 1
                emit_mov_r64_imm64(ctx, RAX, 60)
                emit_mov_r64_imm64(ctx, RDI, 0)
                emit_syscall(ctx)
        let fd = sys.open(output_path, 577, 511)
        if fd < 0
            print("Cannot open output file")
            return 1
        let written = build_elf(ctx, fd)
        sys.close(fd)
        print("Compiled to ")
        print(output_path)
        print(" (no main, code=")
        print(ctx.code_len)
        print(" fns=")
        print(ctx.fn_count)
        print(")")
        return 0

    cg_function(ctx, main_fn, true)

    // Pass 2: Compile all other functions (main can call them via forward refs)
    i = 0
    while i < decls.len()
        let d = decls[i]
        if d.kind == "fn_decl"
            if d.sval != "main"
                cg_function(ctx, d, false)
        i = i + 1

    if ctx.target == 1
        // AArch64: apply ADR and BL fixups
        arm_apply_fixups(ctx)
        arm_apply_call_fixups(ctx)
    else
        if ctx.target == 2 or ctx.target == 4
            // RV64/RV32: apply AUIPC+ADDI and JAL fixups
            rv_apply_fixups(ctx)
            rv_apply_call_fixups(ctx)
        else
            // x86_64: apply string LEA fixups
            cg_apply_fixups(ctx)

            // Apply call fixups: patch CALL displacements
            let mut ci = 0
            while ci < ctx.call_fixup_count
                let call_pos = ctx.call_fixups[ci * 2]
                let fn_name = ctx.call_fixups[ci * 2 + 1]
                if ctx.fn_table.has(fn_name)
                    let fn_start = ctx.fn_table[fn_name]
                    let disp = fn_start - (call_pos + 4)
                    ctx.code_data[call_pos] = ((disp % 256) + 256) % 256
                    ctx.code_data[call_pos + 1] = (((disp / 256) % 256) + 256) % 256
                    ctx.code_data[call_pos + 2] = (((disp / 65536) % 256) + 256) % 256
                    ctx.code_data[call_pos + 3] = (((disp / 16777216) % 256) + 256) % 256
                ci = ci + 1

    let fd = sys.open(output_path, 577, 511)
    if fd < 0
        print("Cannot open output file")
        return 1
    if ctx.target == 3
        let written = wasm_build_module_v2(ctx, fd)
    else
        // Check output format: boot, flat, PE64, Mach-O, or default ELF64
        let fmt_boot = sys.open("/tmp/yilt_format_boot", 0, 0)
        if fmt_boot >= 0
            sys.close(fmt_boot)
            let written = build_boot(ctx, fd)
        else
            let fmt_flat = sys.open("/tmp/yilt_format_flat", 0, 0)
            if fmt_flat >= 0
                sys.close(fmt_flat)
                let written = build_flat(ctx, fd)
            else
                let fmt_pe = sys.open("/tmp/yilt_format_pe", 0, 0)
                if fmt_pe >= 0
                    sys.close(fmt_pe)
                    let written = build_pe64(ctx, fd)
                else
                    let fmt_macho = sys.open("/tmp/yilt_format_macho", 0, 0)
                    if fmt_macho >= 0
                        sys.close(fmt_macho)
                        let written = build_macho64(ctx, fd)
                    else
                        let written = build_elf(ctx, fd)
    sys.close(fd)

    print("Compiled to ")
    print(output_path)
    print(" (code=")
    print(ctx.code_len)
    print(" data=")
    print(ctx.data_len)
    print(" fns=")
    print(ctx.fn_count)
    print(")")
    return 0

// ---------------------------------------------------------------------------
// Section 8: Helpers
// ---------------------------------------------------------------------------
fn parse_float_to_bits(s str) int
    let bytes = s.bytes()
    let n = bytes.len()
    if n == 0
        return 0
    let mut i = 0
    let mut sign = 0
    if bytes[0] == 45
        sign = 1
        i = 1
    let mut ipart = 0
    while i < n and bytes[i] != 46
        if bytes[i] >= 48 and bytes[i] <= 57
            ipart = ipart * 10 + (bytes[i] - 48)
        i = i + 1
    if i < n and bytes[i] == 46
        i = i + 1
    let mut fpart = 0
    let mut fdigits = 0
    while i < n
        if bytes[i] >= 48 and bytes[i] <= 57
            fpart = fpart * 10 + (bytes[i] - 48)
            fdigits = fdigits + 1
        i = i + 1
    let mut denom = 1
    let mut j = 0
    while j < fdigits
        denom = denom * 10
        j = j + 1
    let numer = ipart * denom + fpart
    if numer == 0
        return 0
    let mut p = 0
    if numer >= denom
        let mut temp = denom
        while temp + temp <= numer
            temp = temp + temp
            p = p + 1
    else
        let mut temp = numer
        while temp + temp < denom
            temp = temp + temp
            p = p - 1
    let mut shifted = numer
    if p <= 52
        let shift = 52 - p
        let mut k = 0
        while k < shift
            shifted = shifted + shifted
            k = k + 1
    else
        let shift = p - 52
        let mut k = 0
        while k < shift
            shifted = shifted / 2
            k = k + 1
    let mask = 4503599627370495
    let mantissa = (shifted / denom) & mask
    let biased_exp = p + 1023
    let exp_bits = biased_exp * 4503599627370496
    let result = exp_bits + mantissa
    if sign == 1
        let mut sign_bit = 0 - 4611686018427387904
        sign_bit = sign_bit - 4611686018427387904
        return result + sign_bit
    return result


fn parse_int(s str) int
    let bytes = s.bytes()
    let n = bytes.len()
    if n == 0
        return 0
    let mut i = 0
    let mut neg = false
    if bytes[0] == 45
        neg = true
        i = 1
    let mut base = 10
    if n > i + 1 and bytes[i] == 48
        if bytes[i + 1] == 120 or bytes[i + 1] == 88
            base = 16
            i = i + 2
    let mut result = 0
    while i < n
        let b = bytes[i]
        if b >= 48 and b <= 57
            result = result * base + (b - 48)
        if base == 16
            if b >= 97 and b <= 102
                result = result * 16 + (b - 87)
            if b >= 65 and b <= 70
                result = result * 16 + (b - 55)
        i = i + 1
    if neg
        return -result
    return result

// ---------------------------------------------------------------------------
// Section 9: Main entry point
// ---------------------------------------------------------------------------

// read_file reads up to 1MB from a file path. Returns the file contents as a
// string. On error (cannot open), returns the empty string and prints an error.
fn read_file(path str) str
    let fd = sys.open(path, 0, 0)
    if fd < 0
        print("ERROR: cannot open ")
        print(path)
        return ""
    let s = sys.read(fd, 1048576)
    sys.close(fd)
    return s

fn main() int
    print("=== Yilt Self-Host Stage 5: Native Codegen ===")
    print("")
    
    // Try to read source from /tmp/yiltc_input.yilt (fixpoint driver mode).
    // If the file doesn't exist, fall back to running the built-in tests.
    let in_path = "/tmp/yiltc_input.yilt"
    let fd = sys.open(in_path, 0, 0)
    if fd >= 0
        sys.close(fd)
        let src = read_file(in_path)
        if src.len() == 0
            print("ERROR: input file is empty or unreadable")
            return 1
        let out_path = "/tmp/yiltc_output"
        print("Compiling ")
        print(in_path)
        print(" → ")
        print(out_path)
        print("")
        print("Source size: ")
        print(src.len())
        print(" bytes")
        let rc = compile_program(src, out_path)
        if rc != 0
            print("FAIL: compilation reported error")
            return 1
        print("OK: fixpoint compile succeeded")
        return 0
    
    // Built-in self-test mode (no input file present)
    print("No /tmp/yiltc_input.yilt found — running built-in tests.")
    print("")
    
    let mut nfail = 0
    
    // Test 1: Simple function call + arithmetic (baseline)
    let src1 = "fn add(a int, b int) int\n    return a + b\n\nfn main() int\n    let x = add(3, 4)\n    print(x)\n    return x\n"
    let rc1 = compile_program(src1, "/tmp/yilt_t1")
    if rc1 != 0
        nfail = nfail + 1
        print("FAIL: add(3,4)=7")
    else
        print("OK: add(3,4)=7 → /tmp/yilt_t1")
    
    // Test 2: Factorial (recursion + if)
    let src2 = "fn fact(n int) int\n    if n <= 1\n        return 1\n    return n * fact(n - 1)\n\nfn main() int\n    let r = fact(5)\n    print(r)\n    return r\n"
    let rc2 = compile_program(src2, "/tmp/yilt_t2")
    if rc2 != 0
        nfail = nfail + 1
        print("FAIL: fact(5)=120")
    else
        print("OK: fact(5)=120 → /tmp/yilt_t2")
    
    // Test 3: While loop (sum 1..10 = 55)
    let src3 = "fn main() int\n    let mut i = 1\n    let mut sum = 0\n    while i <= 10\n        sum = sum + i\n        i = i + 1\n    print(sum)\n    return sum\n"
    let rc3 = compile_program(src3, "/tmp/yilt_t3")
    if rc3 != 0
        nfail = nfail + 1
        print("FAIL: sum(1..10)=55")
    else
        print("OK: sum(1..10)=55 → /tmp/yilt_t3")
    
    // Test 4: If/else (max of two)
    let src4 = "fn max(a int, b int) int\n    if a > b\n        return a\n    return b\n\nfn main() int\n    let m = max(7, 12)\n    print(m)\n    return m\n"
    let rc4 = compile_program(src4, "/tmp/yilt_t4")
    if rc4 != 0
        nfail = nfail + 1
        print("FAIL: max(7,12)=12")
    else
        print("OK: max(7,12)=12 → /tmp/yilt_t4")
    
    // Test 5: Fibonacci (recursion, deeper)
    let src5 = "fn fib(n int) int\n    if n < 2\n        return n\n    return fib(n - 1) + fib(n - 2)\n\nfn main() int\n    let r = fib(10)\n    print(r)\n    return r\n"
    let rc5 = compile_program(src5, "/tmp/yilt_t5")
    if rc5 != 0
        nfail = nfail + 1
        print("FAIL: fib(10)=55")
    else
        print("OK: fib(10)=55 → /tmp/yilt_t5")
    
    print("")
    print("=== Tests complete. Failures: ")
    print(nfail)
    print(" ===")
    if nfail > 0
        return 1
    return 0

// cg_member_assign: obj.field = value (stub — evaluates but doesn't store)
fn cg_member_assign(ctx Ctx, target Node, val_expr Node)
    cg_expr(ctx, val_expr)
    return

// cg_index_assign: obj[key] = value (stub — evaluates but doesn't store)
fn cg_index_assign(ctx Ctx, target Node, val_expr Node)
    cg_expr(ctx, val_expr)
    return

// cg_method_call: obj.method(args) (stub — returns 0 or passes through)
fn cg_method_call(ctx Ctx, e Node)
    let fa = e.a
    let member_node = fa[0]
    let method_name = member_node.sval
    let oa = member_node.a
    let obj_expr = oa[0]
    if method_name == "len"
        cg_expr(ctx, obj_expr)
        emit_mov_r64_mem(ctx, RAX, RAX, 0)
        return
    if method_name == "substr"
        cg_expr(ctx, obj_expr)
        return
    if method_name == "bytes"
        cg_expr(ctx, obj_expr)
        return
    if method_name == "has"
        cg_expr(ctx, obj_expr)
        emit_mov_r64_imm64(ctx, RAX, 1)
        return
    if method_name == "contains"
        cg_expr(ctx, obj_expr)
        emit_mov_r64_imm64(ctx, RAX, 1)
        return
    if method_name == "find"
        cg_expr(ctx, obj_expr)
        emit_mov_r64_imm64(ctx, RAX, 0)
        return
    if method_name == "starts_with"
        cg_expr(ctx, obj_expr)
        emit_mov_r64_imm64(ctx, RAX, 1)
        return
    if method_name == "ends_with"
        cg_expr(ctx, obj_expr)
        emit_mov_r64_imm64(ctx, RAX, 1)
        return
    if method_name == "lower"
        cg_expr(ctx, obj_expr)
        return
    if method_name == "upper"
        cg_expr(ctx, obj_expr)
        return
    if method_name == "trim"
        cg_expr(ctx, obj_expr)
        return
    if method_name == "split"
        emit_mov_r64_imm64(ctx, RDI, 0)
        emit_mov_r64_imm64(ctx, RSI, 8)
        emit_mov_r64_imm64(ctx, RAX, 9)
        emit_mov_r64_imm64(ctx, RDX, 3)
        emit_mov_r64_imm64(ctx, R10, 34)
        emit_mov_r64_imm64(ctx, R8, -1)
        emit_mov_r64_imm64(ctx, R9, 0)
        emit_syscall(ctx)
        emit_mov_r64_imm64(ctx, RCX, 0)
        code_byte(ctx, 0x48)
        code_byte(ctx, 0x89)
        code_byte(ctx, 0x08)
        return
    emit_mov_r64_imm64(ctx, RAX, 0)

// cg_if_expr: if-as-expression (stub — evaluates condition and then-block)
fn cg_if_expr(ctx Ctx, e Node)
    let ca = e.a
    cg_expr(ctx, ca[0])
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x84)
    let jz_pos = ctx.code_len
    code_u32(ctx, 0)
    let then_block = e.list
    let mut si = 0
    while si < then_block.len()
        cg_stmt(ctx, then_block[si])
        si = si + 1
    code_byte(ctx, 0xE9)
    let jmp_pos = ctx.code_len
    code_u32(ctx, 0)
    let else_pos = ctx.code_len
    let jz_disp = else_pos - (jz_pos + 4)
    ctx.code_data[jz_pos] = ((jz_disp % 256) + 256) % 256
    ctx.code_data[jz_pos + 1] = (((jz_disp / 256) % 256) + 256) % 256
    ctx.code_data[jz_pos + 2] = (((jz_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jz_pos + 3] = (((jz_disp / 16777216) % 256) + 256) % 256
    if e.b.has(0)
        let else_block = e.b
        let mut ei = 0
        while ei < else_block.len()
            cg_stmt(ctx, else_block[ei])
            ei = ei + 1
    if not e.b.has(0)
        emit_mov_r64_imm64(ctx, RAX, 0)
    let end_pos = ctx.code_len
    let end_disp = end_pos - (jmp_pos + 4)
    ctx.code_data[jmp_pos] = ((end_disp % 256) + 256) % 256
    ctx.code_data[jmp_pos + 1] = (((end_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_pos + 2] = (((end_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_pos + 3] = (((end_disp / 16777216) % 256) + 256) % 256

// cg_str_equal: compare two strings by content. RBX = left ptr, RAX = right ptr.
// Returns 1 in RAX if equal, 0 if not.
fn cg_str_equal(ctx Ctx)
    // RBX = left string ptr, RAX = right string ptr
    // Save both in local vars
    let left_off = cg_get_var_offset(ctx, "__eq_left__")
    emit_mov_mem_r64(ctx, RBP, left_off, RBX)
    let right_off = cg_get_var_offset(ctx, "__eq_right__")
    emit_mov_mem_r64(ctx, RBP, right_off, RAX)
    // Compare lengths first: [left] vs [right]
    emit_mov_r64_mem(ctx, RBX, RBP, left_off)
    emit_mov_r64_mem(ctx, RBX, RBX, 0)  // RBX = left.len
    emit_mov_r64_mem(ctx, RAX, RBP, right_off)
    emit_mov_r64_mem(ctx, RAX, RAX, 0)  // RAX = right.len
    emit_cmp_r64_r64(ctx, RBX, RAX)
    // JNE not_equal
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x85)
    let ne_pos = ctx.code_len
    code_u32(ctx, 0)
    // Lengths match — compare bytes
    // R8 = 0 (index)
    emit_mov_r64_imm64(ctx, R8, 0)
    let cmp_loop = ctx.code_len
    // if R8 >= left.len, equal!
    emit_cmp_r64_r64(ctx, R8, RBX)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x8D)
    let eq_pos = ctx.code_len
    code_u32(ctx, 0)
    // Load left[8+R8]
    emit_mov_r64_mem(ctx, RAX, RBP, left_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x08)  // ADD RAX, 8
    emit_add_r64_r64(ctx, RAX, R8)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0xB6)
    code_byte(ctx, 0x00)  // MOVZX RAX, byte [RAX]
    emit_mov_r64_r64(ctx, R9, RAX)  // save left byte
    // Load right[8+R8]
    emit_mov_r64_mem(ctx, RAX, RBP, right_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x08)
    emit_add_r64_r64(ctx, RAX, R8)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0xB6)
    code_byte(ctx, 0x00)
    emit_cmp_r64_r64(ctx, R9, RAX)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x85)
    let ne2_pos = ctx.code_len
    code_u32(ctx, 0)
    // R8++
    code_byte(ctx, 0x49)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x01)
    code_byte(ctx, 0xE9)
    let cl_back = cmp_loop - (ctx.code_len + 4)
    code_u32(ctx, cl_back)
    // equal: RAX = 1
    let eq_target = ctx.code_len
    let eq_disp = eq_target - (eq_pos + 4)
    ctx.code_data[eq_pos] = ((eq_disp % 256) + 256) % 256
    ctx.code_data[eq_pos + 1] = (((eq_disp / 256) % 256) + 256) % 256
    ctx.code_data[eq_pos + 2] = (((eq_disp / 65536) % 256) + 256) % 256
    ctx.code_data[eq_pos + 3] = (((eq_disp / 16777216) % 256) + 256) % 256
    emit_mov_r64_imm64(ctx, RAX, 1)
    code_byte(ctx, 0xE9)
    let end_pos = ctx.code_len
    code_u32(ctx, 0)
    // not_equal: RAX = 0
    let ne_target = ctx.code_len
    let ne_disp = ne_target - (ne_pos + 4)
    ctx.code_data[ne_pos] = ((ne_disp % 256) + 256) % 256
    ctx.code_data[ne_pos + 1] = (((ne_disp / 256) % 256) + 256) % 256
    ctx.code_data[ne_pos + 2] = (((ne_disp / 65536) % 256) + 256) % 256
    ctx.code_data[ne_pos + 3] = (((ne_disp / 16777216) % 256) + 256) % 256
    let ne2_disp = ne_target - (ne2_pos + 4)
    ctx.code_data[ne2_pos] = ((ne2_disp % 256) + 256) % 256
    ctx.code_data[ne2_pos + 1] = (((ne2_disp / 256) % 256) + 256) % 256
    ctx.code_data[ne2_pos + 2] = (((ne2_disp / 65536) % 256) + 256) % 256
    ctx.code_data[ne2_pos + 3] = (((ne2_disp / 16777216) % 256) + 256) % 256
    emit_mov_r64_imm64(ctx, RAX, 0)
    // end:
    let end_target = ctx.code_len
    let end_disp = end_target - (end_pos + 4)
    ctx.code_data[end_pos] = ((end_disp % 256) + 256) % 256
    ctx.code_data[end_pos + 1] = (((end_disp / 256) % 256) + 256) % 256
    ctx.code_data[end_pos + 2] = (((end_disp / 65536) % 256) + 256) % 256
    ctx.code_data[end_pos + 3] = (((end_disp / 16777216) % 256) + 256) % 256

// cg_int_to_str: convert integer in RAX to a string.
// Uses a stack-allocated buffer. Returns pointer in RAX.
// String layout: [len:8 | data... | null:1]
fn cg_int_to_str(ctx Ctx)
    // Save the integer value in a local variable FIRST
    let val_off = cg_get_var_offset(ctx, "__tostr_val__")
    emit_mov_mem_r64(ctx, RBP, val_off, RAX)

    // Allocate 32 bytes via mmap (persists after function returns)
    // mmap(NULL, 32, PROT_READ|PROT_WRITE, MAP_PRIVATE|MAP_ANONYMOUS, -1, 0)
    emit_mov_r64_imm64(ctx, RAX, 9)    // SYS_mmap
    emit_mov_r64_imm64(ctx, RDI, 0)    // addr = NULL
    emit_mov_r64_imm64(ctx, RSI, 32)   // len = 32
    emit_mov_r64_imm64(ctx, RDX, 3)    // prot = RW
    // MAP_PRIVATE|MAP_ANONYMOUS = 0x22
    emit_mov_r64_imm64(ctx, R10, 34)   // flags = 0x22 (decimal)
    // fd = -1: use MOV then NEG to avoid large immediate issues
    emit_mov_r64_imm64(ctx, R8, 1)
    code_byte(ctx, 0x49)
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xD8)  // NEG R8 → R8 = -1
    emit_mov_r64_imm64(ctx, R9, 0)     // offset = 0
    emit_syscall(ctx)
    // RAX = pointer to allocated memory

    // Save buffer pointer
    let buf_off = cg_get_var_offset(ctx, "__tostr_buf__")
    emit_mov_mem_r64(ctx, RBP, buf_off, RAX)

    // Handle negative: if value < 0, write '-' and negate
    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xC0)  // TEST RAX, RAX
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x88)  // JS negative_label
    let js_pos = ctx.code_len
    code_u32(ctx, 0)

    // Non-negative: R8 = buf+8, R9 = 0
    emit_mov_r64_mem(ctx, RAX, RBP, buf_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x08)  // ADD RAX, 8
    emit_mov_r64_r64(ctx, R8, RAX)
    emit_mov_r64_imm64(ctx, R9, 0)

    // if value == 0, write '0'
    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xC0)  // TEST RAX, RAX
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x85)  // JNE digit_loop
    let jne_zero_pos = ctx.code_len
    code_u32(ctx, 0)

    // Value is 0: write '0' at buf+8, set length=1
    emit_mov_r64_mem(ctx, RAX, RBP, buf_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x08)
    emit_mov_r64_imm64(ctx, RCX, 48)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x08)  // MOV [RAX], CL
    emit_mov_r64_mem(ctx, RAX, RBP, buf_off)
    emit_mov_r64_imm64(ctx, RCX, 1)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0x08)  // MOV [RAX], RCX (length=1)
    code_byte(ctx, 0xE9)
    let jmp_end1_pos = ctx.code_len
    code_u32(ctx, 0)

    // digit_loop:
    let digit_loop = ctx.code_len
    let jne_disp = digit_loop - (jne_zero_pos + 4)
    ctx.code_data[jne_zero_pos] = ((jne_disp % 256) + 256) % 256
    ctx.code_data[jne_zero_pos + 1] = (((jne_disp / 256) % 256) + 256) % 256
    ctx.code_data[jne_zero_pos + 2] = (((jne_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jne_zero_pos + 3] = (((jne_disp / 16777216) % 256) + 256) % 256

    // if value == 0, exit loop
    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xC0)  // TEST RAX, RAX
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x84)  // JE done_digits
    let je_done_pos = ctx.code_len
    code_u32(ctx, 0)

    // digit = value % 10
    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    emit_mov_r64_imm64(ctx, RCX, 10)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x99)  // CQO
    code_byte(ctx, 0x48)
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xF9)  // IDIV RCX
    emit_mov_r64_r64(ctx, RAX, RDX)  // RAX = remainder

    // Store digit+'0' at [R8+R9]
    emit_mov_r64_imm64(ctx, RCX, 48)
    emit_add_r64_r64(ctx, RAX, RCX)
    code_byte(ctx, 0x41)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x04)
    code_byte(ctx, 0x08)  // MOV [R8+R9], AL
    code_byte(ctx, 0x49)
    code_byte(ctx, 0xFF)
    code_byte(ctx, 0xC1)  // INC R9

    // value = value / 10
    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    emit_mov_r64_imm64(ctx, RCX, 10)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x99)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xF9)  // IDIV RCX
    emit_mov_mem_r64(ctx, RBP, val_off, RAX)

    code_byte(ctx, 0xE9)
    let jmp_loop_pos = ctx.code_len
    code_u32(ctx, 0)
    let loop_disp = digit_loop - (jmp_loop_pos + 4)
    ctx.code_data[jmp_loop_pos] = ((loop_disp % 256) + 256) % 256
    ctx.code_data[jmp_loop_pos + 1] = (((loop_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_loop_pos + 2] = (((loop_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_loop_pos + 3] = (((loop_disp / 16777216) % 256) + 256) % 256

    // done_digits: reverse digits in-place
    let done_digits_target = ctx.code_len
    let je_disp = done_digits_target - (je_done_pos + 4)
    ctx.code_data[je_done_pos] = ((je_disp % 256) + 256) % 256
    ctx.code_data[je_done_pos + 1] = (((je_disp / 256) % 256) + 256) % 256
    ctx.code_data[je_done_pos + 2] = (((je_disp / 65536) % 256) + 256) % 256
    ctx.code_data[je_done_pos + 3] = (((je_disp / 16777216) % 256) + 256) % 256

    // Reverse: R10=0 (left), R11=R9-1 (right)
    emit_mov_r64_imm64(ctx, R10, 0)
    emit_mov_r64_r64(ctx, R11, R9)
    code_byte(ctx, 0x49)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xEB)
    code_byte(ctx, 0x01)  // SUB R11, 1

    let rev_loop = ctx.code_len
    code_byte(ctx, 0x4D)
    code_byte(ctx, 0x39)
    code_byte(ctx, 0xDA)  // CMP R10, R11
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x8D)  // JGE rev_done
    let jge_rev_done_pos = ctx.code_len
    code_u32(ctx, 0)

    // Swap [R8+R10] and [R8+R11]
    code_byte(ctx, 0x43)
    code_byte(ctx, 0x8A)
    code_byte(ctx, 0x04)
    code_byte(ctx, 0x08)  // MOV AL, [R8+R10]
    code_byte(ctx, 0x43)
    code_byte(ctx, 0x8A)
    code_byte(ctx, 0x0C)
    code_byte(ctx, 0x18)  // MOV CL, [R8+R11]
    code_byte(ctx, 0x43)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x0C)
    code_byte(ctx, 0x08)  // MOV [R8+R10], CL
    code_byte(ctx, 0x43)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x04)
    code_byte(ctx, 0x18)  // MOV [R8+R11], AL

    code_byte(ctx, 0x49)
    code_byte(ctx, 0xFF)
    code_byte(ctx, 0xC2)  // INC R10
    code_byte(ctx, 0x49)
    code_byte(ctx, 0xFF)
    code_byte(ctx, 0xCB)  // DEC R11
    code_byte(ctx, 0xE9)
    let jmp_rev_pos = ctx.code_len
    code_u32(ctx, 0)
    let rev_disp = rev_loop - (jmp_rev_pos + 4)
    ctx.code_data[jmp_rev_pos] = ((rev_disp % 256) + 256) % 256
    ctx.code_data[jmp_rev_pos + 1] = (((rev_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_rev_pos + 2] = (((rev_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_rev_pos + 3] = (((rev_disp / 16777216) % 256) + 256) % 256

    let rev_done_target = ctx.code_len
    let jge_disp = rev_done_target - (jge_rev_done_pos + 4)
    ctx.code_data[jge_rev_done_pos] = ((jge_disp % 256) + 256) % 256
    ctx.code_data[jge_rev_done_pos + 1] = (((jge_disp / 256) % 256) + 256) % 256
    ctx.code_data[jge_rev_done_pos + 2] = (((jge_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jge_rev_done_pos + 3] = (((jge_disp / 16777216) % 256) + 256) % 256

    // Set length = R9 at [buf]
    emit_mov_r64_mem(ctx, RAX, RBP, buf_off)
    code_byte(ctx, 0x4C)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0x08)  // MOV [RAX], R9

    code_byte(ctx, 0xE9)
    let jmp_end2_pos = ctx.code_len
    code_u32(ctx, 0)

    // negative_label:
    let neg_target = ctx.code_len
    let js_disp = neg_target - (js_pos + 4)
    ctx.code_data[js_pos] = ((js_disp % 256) + 256) % 256
    ctx.code_data[js_pos + 1] = (((js_disp / 256) % 256) + 256) % 256
    ctx.code_data[js_pos + 2] = (((js_disp / 65536) % 256) + 256) % 256
    ctx.code_data[js_pos + 3] = (((js_disp / 16777216) % 256) + 256) % 256

    // Negate value
    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xD8)  // NEG RAX
    emit_mov_mem_r64(ctx, RBP, val_off, RAX)

    // Write '-' at buf+8
    emit_mov_r64_mem(ctx, RAX, RBP, buf_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x08)
    emit_mov_r64_imm64(ctx, RCX, 45)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x08)  // MOV [RAX], CL

    // R8 = buf+9, R9 = 0
    emit_mov_r64_mem(ctx, RAX, RBP, buf_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x09)
    emit_mov_r64_r64(ctx, R8, RAX)
    emit_mov_r64_imm64(ctx, R9, 0)

    // digit_loop_neg:
    let digit_loop_neg = ctx.code_len
    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x85)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x84)  // JE done_neg
    let je_done_neg_pos = ctx.code_len
    code_u32(ctx, 0)

    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    emit_mov_r64_imm64(ctx, RCX, 10)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x99)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xF9)
    emit_mov_r64_r64(ctx, RAX, RDX)
    emit_mov_r64_imm64(ctx, RCX, 48)
    emit_add_r64_r64(ctx, RAX, RCX)
    code_byte(ctx, 0x41)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x04)
    code_byte(ctx, 0x08)
    code_byte(ctx, 0x49)
    code_byte(ctx, 0xFF)
    code_byte(ctx, 0xC1)

    emit_mov_r64_mem(ctx, RAX, RBP, val_off)
    emit_mov_r64_imm64(ctx, RCX, 10)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x99)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0xF7)
    code_byte(ctx, 0xF9)
    emit_mov_mem_r64(ctx, RBP, val_off, RAX)

    code_byte(ctx, 0xE9)
    let jmp_neg_pos = ctx.code_len
    code_u32(ctx, 0)
    let neg_loop_disp = digit_loop_neg - (jmp_neg_pos + 4)
    ctx.code_data[jmp_neg_pos] = ((neg_loop_disp % 256) + 256) % 256
    ctx.code_data[jmp_neg_pos + 1] = (((neg_loop_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_neg_pos + 2] = (((neg_loop_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_neg_pos + 3] = (((neg_loop_disp / 16777216) % 256) + 256) % 256

    // done_neg: reverse, set length = R9+1
    let done_neg_target = ctx.code_len
    let je_neg_disp = done_neg_target - (je_done_neg_pos + 4)
    ctx.code_data[je_done_neg_pos] = ((je_neg_disp % 256) + 256) % 256
    ctx.code_data[je_done_neg_pos + 1] = (((je_neg_disp / 256) % 256) + 256) % 256
    ctx.code_data[je_done_neg_pos + 2] = (((je_neg_disp / 65536) % 256) + 256) % 256
    ctx.code_data[je_done_neg_pos + 3] = (((je_neg_disp / 16777216) % 256) + 256) % 256

    emit_mov_r64_imm64(ctx, R10, 0)
    emit_mov_r64_r64(ctx, R11, R9)
    code_byte(ctx, 0x49)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xEB)
    code_byte(ctx, 0x01)

    let rev_loop_neg = ctx.code_len
    code_byte(ctx, 0x4D)
    code_byte(ctx, 0x39)
    code_byte(ctx, 0xDA)
    code_byte(ctx, 0x0F)
    code_byte(ctx, 0x8D)
    let jge_rev_neg_done_pos = ctx.code_len
    code_u32(ctx, 0)

    code_byte(ctx, 0x43)
    code_byte(ctx, 0x8A)
    code_byte(ctx, 0x04)
    code_byte(ctx, 0x08)
    code_byte(ctx, 0x43)
    code_byte(ctx, 0x8A)
    code_byte(ctx, 0x0C)
    code_byte(ctx, 0x18)
    code_byte(ctx, 0x43)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x0C)
    code_byte(ctx, 0x08)
    code_byte(ctx, 0x43)
    code_byte(ctx, 0x88)
    code_byte(ctx, 0x04)
    code_byte(ctx, 0x18)

    code_byte(ctx, 0x49)
    code_byte(ctx, 0xFF)
    code_byte(ctx, 0xC2)
    code_byte(ctx, 0x49)
    code_byte(ctx, 0xFF)
    code_byte(ctx, 0xCB)
    code_byte(ctx, 0xE9)
    let jmp_rev_neg_pos = ctx.code_len
    code_u32(ctx, 0)
    let rev_neg_disp = rev_loop_neg - (jmp_rev_neg_pos + 4)
    ctx.code_data[jmp_rev_neg_pos] = ((rev_neg_disp % 256) + 256) % 256
    ctx.code_data[jmp_rev_neg_pos + 1] = (((rev_neg_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_rev_neg_pos + 2] = (((rev_neg_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_rev_neg_pos + 3] = (((rev_neg_disp / 16777216) % 256) + 256) % 256

    let rev_neg_done_target = ctx.code_len
    let jge_neg_disp = rev_neg_done_target - (jge_rev_neg_done_pos + 4)
    ctx.code_data[jge_rev_neg_done_pos] = ((jge_neg_disp % 256) + 256) % 256
    ctx.code_data[jge_rev_neg_done_pos + 1] = (((jge_neg_disp / 256) % 256) + 256) % 256
    ctx.code_data[jge_rev_neg_done_pos + 2] = (((jge_neg_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jge_rev_neg_done_pos + 3] = (((jge_neg_disp / 16777216) % 256) + 256) % 256

    // Set length = R9 + 1
    emit_mov_r64_r64(ctx, RAX, R9)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x83)
    code_byte(ctx, 0xC0)
    code_byte(ctx, 0x01)  // ADD RAX, 1
    emit_mov_r64_mem(ctx, RCX, RBP, buf_off)
    code_byte(ctx, 0x48)
    code_byte(ctx, 0x89)
    code_byte(ctx, 0x01)  // MOV [RCX], RAX

    // tostr_end: RAX = buf
    let tostr_end_target = ctx.code_len
    let end1_disp = tostr_end_target - (jmp_end1_pos + 4)
    ctx.code_data[jmp_end1_pos] = ((end1_disp % 256) + 256) % 256
    ctx.code_data[jmp_end1_pos + 1] = (((end1_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_end1_pos + 2] = (((end1_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_end1_pos + 3] = (((end1_disp / 16777216) % 256) + 256) % 256
    let end2_disp = tostr_end_target - (jmp_end2_pos + 4)
    ctx.code_data[jmp_end2_pos] = ((end2_disp % 256) + 256) % 256
    ctx.code_data[jmp_end2_pos + 1] = (((end2_disp / 256) % 256) + 256) % 256
    ctx.code_data[jmp_end2_pos + 2] = (((end2_disp / 65536) % 256) + 256) % 256
    ctx.code_data[jmp_end2_pos + 3] = (((end2_disp / 16777216) % 256) + 256) % 256

    emit_mov_r64_mem(ctx, RAX, RBP, buf_off)
// ===========================================================================
// AArch64 (ARM64) codegen — parallel path activated when ctx.target == 1
// ===========================================================================
// Mirrors the x86_64 path but emits AArch64 instructions.
// Calling convention: X0=return/arg0, X1-X7=args, X8=syscall num,
// X9-X15=caller-saved temps, X19-X28=callee-saved, X29=FP, X30=LR, X31=SP/XZR.
// Frame layout: STP X29,X30,[SP,#-16]!; MOV X29,SP; SUB SP,SP,#frame
// Local variables at X29-relative negative offsets (same convention as x86_64).
// ===========================================================================

// AArch64 condition codes
let ARM_EQ = 0
let ARM_NE = 1
let ARM_CS = 2
let ARM_CC = 3
let ARM_MI = 4
let ARM_PL = 5
let ARM_VS = 6
let ARM_VC = 7
let ARM_HI = 8
let ARM_LS = 9
let ARM_GE = 10
let ARM_LT = 11
let ARM_GT = 12
let ARM_LE = 13

// Additional AArch64 instruction encoders

// AND Xd, Xn, Xm (bitwise AND, 64-bit)
fn arm_and(ctx Ctx, dst int, src1 int, src2 int)
    let instr = 0x8A000000 + (src2 * 65536) + (src1 * 32) + dst
    arm_emit(ctx, instr)

// ORR Xd, Xn, Xm (bitwise OR, 64-bit)
fn arm_orr(ctx Ctx, dst int, src1 int, src2 int)
    let instr = 0xAA000000 + (src2 * 65536) + (src1 * 32) + dst
    arm_emit(ctx, instr)

// EOR Xd, Xn, Xm (bitwise XOR, 64-bit)
fn arm_eor(ctx Ctx, dst int, src1 int, src2 int)
    let instr = 0xCA000000 + (src2 * 65536) + (src1 * 32) + dst
    arm_emit(ctx, instr)

// SUB Xd, Xn, #imm12 (subtract 12-bit immediate, shift=0)
fn arm_sub_imm(ctx Ctx, dst int, src int, imm12 int)
    let instr = 0xD1000000 + ((imm12 & 4095) * 1024) + (src * 32) + dst
    arm_emit(ctx, instr)

// ADD Xd, Xn, #imm12 (add 12-bit immediate, shift=0)
fn arm_add_imm(ctx Ctx, dst int, src int, imm12 int)
    let instr = 0x91000000 + ((imm12 & 4095) * 1024) + (src * 32) + dst
    arm_emit(ctx, instr)

// STR Xd, [Xn, #offset] with safe offset handling
fn arm_str_safe(ctx Ctx, src int, base int, offset int)
    if offset >= 0 and offset <= 32760
        let scaled = offset / 8
        let instr = 0xF9000000 + (scaled * 1024) + (base * 32) + src
        arm_emit(ctx, instr)
    else
        if offset < 0 and offset >= -4095
            arm_sub_imm(ctx, X9, base, 0 - offset)
            let instr = 0xF9000000 + (0 * 1024) + (X9 * 32) + src
            arm_emit(ctx, instr)
        else
            arm_mov_imm64(ctx, X10, offset)
            arm_add(ctx, X9, base, X10)
            let instr = 0xF9000000 + (0 * 1024) + (X9 * 32) + src
            arm_emit(ctx, instr)

// LDR Xd, [Xn, #offset] with safe offset handling
fn arm_ldr_safe(ctx Ctx, dst int, base int, offset int)
    if offset >= 0 and offset <= 32760
        let scaled = offset / 8
        let instr = 0xF9400000 + (scaled * 1024) + (base * 32) + dst
        arm_emit(ctx, instr)
    else
        if offset < 0 and offset >= -4095
            arm_sub_imm(ctx, X9, base, 0 - offset)
            let instr = 0xF9400000 + (0 * 1024) + (X9 * 32) + dst
            arm_emit(ctx, instr)
        else
            arm_mov_imm64(ctx, X10, offset)
            arm_add(ctx, X9, base, X10)
            let instr = 0xF9400000 + (0 * 1024) + (X9 * 32) + dst
            arm_emit(ctx, instr)

// MOV Xd, Xn (alias for ORR Xd, XZR, Xn)
// Special case: if src or dst is SP (31), use ADD Xd, SP, #0 (ORR can't use SP)
fn arm_mov(ctx Ctx, dst int, src int)
    if src == 31
        // MOV Xd, SP = ADD Xd, SP, #0
        let instr = 0x910003E0 + dst
        arm_emit(ctx, instr)
        return
    if dst == 31
        // MOV SP, Xn = ADD SP, Xn, #0
        let instr = 0x91000000 + (src * 32) + 31
        arm_emit(ctx, instr)
        return
    arm_mov_reg(ctx, dst, src)

// CMP Xn, #imm5 (5-bit unsigned immediate, 64-bit)
// = SUBS XZR, Xn, #imm = 0xF1000000 | (imm5 << 10) | (Xn << 5) | 31
fn arm_cmp_imm(ctx Ctx, src int, imm5 int)
    let instr = 0xF1000000 + ((imm5 & 31) * 1024) + (src * 32) + 31
    arm_emit(ctx, instr)

// AArch64 prologue: STP X29,X30,[SP,#-16]!; MOV X29,SP; SUB SP,SP,#0 (placeholder)
// Returns the offset where frame_size immediate must be patched.
fn arm_emit_prologue(ctx Ctx) int
    // STP X29, X30, [SP, #-16]! (pre-index, store pair, allocate 16 bytes)
    // Encoding: 0xA9800000 | (imm7 << 15) | (Rt2 << 10) | (Rn << 5) | Rt
    // imm7 = -2 (signed 7-bit) = 0x7E
    let stp_instr = 0xA9BF7BFD  // STP X29, X30, [SP, #-16]!
    arm_emit(ctx, stp_instr)
    // MOV X29, SP = ADD X29, SP, #0
    let mov_instr = 0x910003FD  // ADD X29, SP, #0
    arm_emit(ctx, mov_instr)
    // SUB SP, SP, #0 (placeholder — frame_size patched later)
    let sub_pos = ctx.code_len
    let sub_instr = 0xD10003FF  // SUB SP, SP, #0
    arm_emit(ctx, sub_instr)
    return sub_pos

// AArch64 epilogue: MOV SP, X29; LDP X29, X30, [SP], #16; RET
fn arm_emit_epilogue(ctx Ctx)
    let mov_instr = 0x910003BF  // MOV SP, X29 = ADD SP, X29, #0
    arm_emit(ctx, mov_instr)
    let ldp_instr = 0xA8C17BFD  // LDP X29, X30, [SP], #16
    arm_emit(ctx, ldp_instr)
    arm_ret(ctx)

// arm_push: STR Xd, [SP, #-16]! (push with 16-byte alignment)
fn arm_push(ctx Ctx, r int)
    let instr = 0xF81F0FFF + r - 31 * 32  // STR Xt, [SP, #-16]! (pre-index)
    // Actually let me recompute: STR (pre-index, 64-bit):
    // 1111 1000 00 0 imm9 11 Rn Rt
    // = 0xF8000C00 | (imm9 << 12) | (Rn << 5) | Rt
    // imm9 = -16 = 0x1F0 (9-bit signed)
    let instr2 = 0xF8000C00 + (0x1F0 * 4096) + (X31 * 32) + r
    arm_emit(ctx, instr2)

// arm_pop: LDR Xd, [SP], #16 (pop with 16-byte deallocation)
fn arm_pop(ctx Ctx, r int)
    // LDR (post-index) 64-bit: 0xF8400400 | (imm9 << 12) | (Rn << 5) | Rt
    // imm9 = 16 = 0x010
    let instr = 0xF8400400 + (16 * 4096) + (X31 * 32) + r
    arm_emit(ctx, instr)

// arm_patch_branch: patch a B/BL/Bcond placeholder at pos to target
fn arm_patch_branch(ctx Ctx, pos int, target int)
    let off = target - pos
    let instr = ctx.code_data[pos] + (ctx.code_data[pos + 1] * 256) + (ctx.code_data[pos + 2] * 65536) + (ctx.code_data[pos + 3] * 16777216)
    if (instr & 0xFF000010) == 0x54000000
        // Bcond: 19-bit offset
        let off19 = (off / 4) & 524287
        let new_instr = (instr & 0xFF00001F) + (off19 * 32)
        ctx.code_data[pos] = new_instr % 256
        ctx.code_data[pos + 1] = (new_instr / 256) % 256
        ctx.code_data[pos + 2] = (new_instr / 65536) % 256
        ctx.code_data[pos + 3] = (new_instr / 16777216) % 256
    else
        // B or BL: 26-bit offset
        let off26 = (off / 4) & 67108863
        let new_instr = (instr & 0xFC000000) + off26
        ctx.code_data[pos] = new_instr % 256
        ctx.code_data[pos + 1] = (new_instr / 256) % 256
        ctx.code_data[pos + 2] = (new_instr / 65536) % 256
        ctx.code_data[pos + 3] = (new_instr / 16777216) % 256

// arm_add_fixup: record an ADR fixup for AArch64
fn arm_add_fixup(ctx Ctx, adr_pos int, data_off int)
    let idx = ctx.fixup_count
    ctx.code_data[200000 + idx * 2] = adr_pos
    ctx.code_data[200000 + idx * 2 + 1] = data_off
    ctx.fixup_count = idx + 1

// arm_apply_fixups: patch all ADR instructions now that code_len is final
fn arm_apply_fixups(ctx Ctx)
    let mut i = 0
    while i < ctx.fixup_count
        let adr_pos = ctx.code_data[200000 + i * 2]
        let data_off = ctx.code_data[200000 + i * 2 + 1]
        let off = (ctx.code_len + data_off) - adr_pos
        let immlo = off & 3
        let immhi = (off >> 2) & 524287
        // Read existing instruction to get the destination register
        let old_instr = ctx.code_data[adr_pos] + (ctx.code_data[adr_pos + 1] * 256) + (ctx.code_data[adr_pos + 2] * 65536) + (ctx.code_data[adr_pos + 3] * 16777216)
        let rd = old_instr & 31
        let instr = 0x10000000 + (immlo * 536870912) + (immhi * 32) + rd
        ctx.code_data[adr_pos] = instr % 256
        ctx.code_data[adr_pos + 1] = (instr / 256) % 256
        ctx.code_data[adr_pos + 2] = (instr / 65536) % 256
        ctx.code_data[adr_pos + 3] = (instr / 16777216) % 256
        i = i + 1

// arm_apply_call_fixups: patch all BL instructions
fn arm_apply_call_fixups(ctx Ctx)
    let mut ci = 0
    while ci < ctx.call_fixup_count
        let call_pos = ctx.call_fixups[ci * 2]
        let fn_name = ctx.call_fixups[ci * 2 + 1]
        if ctx.fn_table.has(fn_name)
            let fn_start = ctx.fn_table[fn_name]
            let disp = fn_start - call_pos
            // BL #offset: 26-bit offset in instruction words
            let off26 = (disp / 4) & 67108863
            let instr = 0x94000000 + off26
            ctx.code_data[call_pos] = instr % 256
            ctx.code_data[call_pos + 1] = (instr / 256) % 256
            ctx.code_data[call_pos + 2] = (instr / 65536) % 256
            ctx.code_data[call_pos + 3] = (instr / 16777216) % 256
        ci = ci + 1

// ---------------------------------------------------------------------------
// AArch64 codegen dispatchers
// ---------------------------------------------------------------------------

fn arm_cg_expr(ctx Ctx, e Node)
    if e.kind == "int_lit"
        let val = parse_int(e.sval)
        arm_mov_imm64(ctx, X0, val)
        return
    if e.kind == "bool_true"
        arm_mov_imm64(ctx, X0, 1)
        return
    if e.kind == "bool_false"
        arm_mov_imm64(ctx, X0, 0)
        return
    if e.kind == "nil"
        arm_mov_imm64(ctx, X0, 0)
        return
    if e.kind == "float_lit"
        let val = parse_int(e.sval)
        arm_mov_imm64(ctx, X0, val)
        return
    if e.kind == "ident"
        let offset = cg_get_var_offset(ctx, e.sval)
        arm_ldr_safe(ctx, X0, X29, offset)
        return
    if e.kind == "binary"
        arm_cg_binary(ctx, e)
        return
    if e.kind == "unary"
        arm_cg_unary(ctx, e)
        return
    if e.kind == "call"
        arm_cg_call(ctx, e)
        return
    if e.kind == "string_lit"
        let data_off = ctx.data_len
        cg_add_string(ctx, e.sval)
        let adr_pos = ctx.code_len
        let adr_instr = 0x10000000 + X0  // ADR X0, #0
        arm_emit(ctx, adr_instr)
        arm_add_fixup(ctx, adr_pos, data_off)
        return
    if e.kind == "if_expr"
        arm_cg_if_expr(ctx, e)
        return
    arm_mov_imm64(ctx, X0, 0)

fn arm_cg_binary(ctx Ctx, e Node)
    let la = e.a
    let rb = e.b
    let op = e.sval

    if op == "and"
        arm_cg_expr(ctx, la[0])
        arm_cmp_imm(ctx, X0, 0)
        let beq_pos = ctx.code_len
        arm_bcond(ctx, ARM_EQ, 0)
        arm_cg_expr(ctx, rb[0])
        arm_cmp_imm(ctx, X0, 0)
        arm_cset(ctx, X0, ARM_NE)
        let b_pos = ctx.code_len
        arm_b(ctx, 0)
        let false_target = ctx.code_len
        arm_patch_branch(ctx, beq_pos, false_target)
        arm_mov_imm64(ctx, X0, 0)
        let end_target = ctx.code_len
        arm_patch_branch(ctx, b_pos, end_target)
        return
    if op == "or"
        arm_cg_expr(ctx, la[0])
        arm_cmp_imm(ctx, X0, 0)
        let bne_pos = ctx.code_len
        arm_bcond(ctx, ARM_NE, 0)
        arm_cg_expr(ctx, rb[0])
        arm_cmp_imm(ctx, X0, 0)
        arm_cset(ctx, X0, ARM_NE)
        let b_pos = ctx.code_len
        arm_b(ctx, 0)
        let true_target = ctx.code_len
        arm_patch_branch(ctx, bne_pos, true_target)
        arm_mov_imm64(ctx, X0, 1)
        let end_target = ctx.code_len
        arm_patch_branch(ctx, b_pos, end_target)
        return

    // Evaluate left, push, evaluate right, pop into X1
    arm_cg_expr(ctx, la[0])
    arm_push(ctx, X0)
    arm_cg_expr(ctx, rb[0])
    arm_pop(ctx, X1)

    if op == "+"
        arm_add(ctx, X0, X1, X0)
        return
    if op == "-"
        arm_sub(ctx, X0, X1, X0)
        return
    if op == "*"
        arm_mul(ctx, X0, X1, X0)
        return
    if op == "/"
        arm_sdiv(ctx, X0, X1, X0)
        return
    if op == "%"
        arm_sdiv(ctx, X2, X1, X0)
        arm_msub(ctx, X0, X2, X0, X1)
        return
    if op == "=="
        arm_cmp(ctx, X1, X0)
        arm_cset(ctx, X0, ARM_EQ)
        return
    if op == "!="
        arm_cmp(ctx, X1, X0)
        arm_cset(ctx, X0, ARM_NE)
        return
    if op == "<"
        arm_cmp(ctx, X1, X0)
        arm_cset(ctx, X0, ARM_LT)
        return
    if op == ">"
        arm_cmp(ctx, X1, X0)
        arm_cset(ctx, X0, ARM_GT)
        return
    if op == "<="
        arm_cmp(ctx, X1, X0)
        arm_cset(ctx, X0, ARM_LE)
        return
    if op == ">="
        arm_cmp(ctx, X1, X0)
        arm_cset(ctx, X0, ARM_GE)
        return
    if op == "&"
        arm_and(ctx, X0, X1, X0)
        return
    if op == "|"
        arm_orr(ctx, X0, X1, X0)
        return
    if op == "^"
        arm_eor(ctx, X0, X1, X0)
        return
    arm_mov_imm64(ctx, X0, 0)

fn arm_cg_unary(ctx Ctx, e Node)
    let operand = e.a[0]
    let op = e.sval
    if op == "-"
        arm_cg_expr(ctx, operand)
        arm_sub(ctx, X0, XZR, X0)
        return
    if op == "!"
        arm_cg_expr(ctx, operand)
        arm_cmp_imm(ctx, X0, 0)
        arm_cset(ctx, X0, ARM_EQ)
        return
    if op == "~"
        arm_cg_expr(ctx, operand)
        // MVN X0, X0 = ORN X0, XZR, X0 = 0xAA200000 | (X0 << 16) | (XZR << 5) | X0
        let instr = 0xAA200000 + (X0 * 65536) + (XZR * 32) + X0
        arm_emit(ctx, instr)
        return
    arm_cg_expr(ctx, operand)

fn arm_cg_call(ctx Ctx, e Node)
    let fa = e.a
    if fa[0].kind != "ident"
        arm_mov_imm64(ctx, X0, 0)
        return
    let fn_name = fa[0].sval

    if fn_name == "println"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            if arg.kind == "string_lit"
                arm_cg_print_string_lit(ctx, arg.sval)
            else
                if arg.kind == "int_lit"
                    arm_mov_imm64(ctx, X0, parse_int(arg.sval))
                    arm_cg_print_int(ctx)
                else
                    if arg.kind == "bool_true"
                        arm_cg_print_string_lit(ctx, "true")
                    else
                        if arg.kind == "bool_false"
                            arm_cg_print_string_lit(ctx, "false")
                        else
                            if arg.kind == "ident"
                                if ctx.var_types.has(arg.sval)
                                    let vt = ctx.var_types[arg.sval]
                                    if vt == "str"
                                        let offset = cg_get_var_offset(ctx, arg.sval)
                                        arm_ldr_safe(ctx, X0, X29, offset)
                                        arm_cg_print_string_val(ctx)
                                    else
                                        arm_cg_expr(ctx, arg)
                                        arm_cg_print_int(ctx)
                                else
                                    arm_cg_expr(ctx, arg)
                                    arm_cg_print_int(ctx)
                            else
                                arm_cg_expr(ctx, arg)
                                arm_cg_print_int(ctx)
        arm_cg_print_string_lit(ctx, "\n")
        return
    if fn_name == "print"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            if arg.kind == "string_lit"
                arm_cg_print_string_lit(ctx, arg.sval)
                return
            if arg.kind == "int_lit"
                arm_mov_imm64(ctx, X0, parse_int(arg.sval))
                arm_cg_print_int(ctx)
                return
            if arg.kind == "bool_true"
                arm_cg_print_string_lit(ctx, "true")
                return
            if arg.kind == "bool_false"
                arm_cg_print_string_lit(ctx, "false")
                return
            if arg.kind == "ident"
                if ctx.var_types.has(arg.sval)
                    let vt = ctx.var_types[arg.sval]
                    if vt == "str"
                        let offset = cg_get_var_offset(ctx, arg.sval)
                        arm_ldr_safe(ctx, X0, X29, offset)
                        arm_cg_print_string_val(ctx)
                        return
            arm_cg_expr(ctx, arg)
            arm_cg_print_int(ctx)
        return
    if fn_name == "len"
        let args = e.list
        if args.len() > 0
            arm_cg_expr(ctx, args[0])
            arm_ldr_safe(ctx, X0, X0, 0)
            return
        arm_mov_imm64(ctx, X0, 0)
        return

    // User-defined function call
    // Evaluate args in REVERSE order so earlier args don't get clobbered.
    // arg N-1 → X0, MOV X(N-1), X0
    // arg N-2 → X0, MOV X(N-2), X0
    // ...
    // arg 0 → X0 (already in correct register)
    let args = e.list
    let nargs = args.len()
    let mut ai = nargs - 1
    while ai >= 0 and ai < 8
        arm_cg_expr(ctx, args[ai])
        if ai == 1
            arm_mov(ctx, X1, X0)
        if ai == 2
            arm_mov(ctx, X2, X0)
        if ai == 3
            arm_mov(ctx, X3, X0)
        if ai == 4
            arm_mov(ctx, X4, X0)
        if ai == 5
            arm_mov(ctx, X5, X0)
        if ai == 6
            arm_mov(ctx, X6, X0)
        if ai == 7
            arm_mov(ctx, X7, X0)
        // ai == 0: arg is already in X0, no move needed
        ai = ai - 1

    // BL #offset (placeholder — patched later)
    let bl_pos = ctx.code_len
    arm_bl(ctx, 0)
    let cidx = ctx.call_fixup_count
    ctx.call_fixups[cidx * 2] = bl_pos
    ctx.call_fixups[cidx * 2 + 1] = fn_name
    ctx.call_fixup_count = cidx + 1

fn arm_cg_print_string_lit(ctx Ctx, s str)
    let data_off = ctx.data_len
    cg_add_string(ctx, s)
    let adr_pos = ctx.code_len
    let adr_instr = 0x10000000 + X1
    arm_emit(ctx, adr_instr)
    arm_add_fixup(ctx, adr_pos, data_off)
    arm_add_imm(ctx, X1, X1, 8)
    arm_mov_imm64(ctx, X2, s.len())
    arm_mov_imm64(ctx, X0, 1)
    arm_mov_imm64(ctx, X8, 64)
    arm_svc(ctx)

fn arm_cg_print_string_val(ctx Ctx)
    arm_mov(ctx, X19, X0)
    arm_ldr_safe(ctx, X2, X19, 0)
    arm_add_imm(ctx, X1, X19, 8)
    arm_mov_imm64(ctx, X0, 1)
    arm_mov_imm64(ctx, X8, 64)
    arm_svc(ctx)

fn arm_cg_print_int(ctx Ctx)
    // Push callee-saved registers we use
    arm_push(ctx, X19)
    arm_push(ctx, X20)
    arm_push(ctx, X21)
    arm_push(ctx, X22)
    arm_push(ctx, X23)
    arm_push(ctx, X24)

    // Allocate 32-byte buffer on stack
    arm_sub_imm(ctx, X31, X31, 32)
    arm_mov(ctx, X20, X31)

    // Save X0 in X19
    arm_mov(ctx, X19, X0)

    // if X0 == 0 → write "0"
    arm_cmp_imm(ctx, X19, 0)
    let beq_zero_pos = ctx.code_len
    arm_bcond(ctx, ARM_EQ, 0)

    // Check sign: if X19 < 0, write '-' and negate
    arm_cmp_imm(ctx, X19, 0)
    let bpl_neg_pos = ctx.code_len
    arm_bcond(ctx, ARM_PL, 0)

    // Write '-' character
    arm_mov_imm64(ctx, X9, 45)
    // STRB W9, [X20]
    let strb_instr = 0x39000000 + (X20 * 32) + X9
    arm_emit(ctx, strb_instr)
    arm_mov_imm64(ctx, X0, 1)
    arm_mov(ctx, X1, X20)
    arm_mov_imm64(ctx, X2, 1)
    arm_mov_imm64(ctx, X8, 64)
    arm_svc(ctx)
    // Negate X19
    arm_sub(ctx, X19, XZR, X19)

    let not_neg_target = ctx.code_len
    arm_patch_branch(ctx, bpl_neg_pos, not_neg_target)

    // X21 = 0 (digit count)
    arm_mov_imm64(ctx, X21, 0)

    let digit_loop = ctx.code_len
    arm_cmp_imm(ctx, X19, 0)
    let beq_done_pos = ctx.code_len
    arm_bcond(ctx, ARM_EQ, 0)

    // X9 = X19 % 10; X19 = X19 / 10
    arm_mov_imm64(ctx, X11, 10)
    arm_sdiv(ctx, X10, X19, X11)
    arm_msub(ctx, X9, X10, X11, X19)
    arm_mov(ctx, X19, X10)

    // digit_char = X9 + '0'
    arm_add_imm(ctx, X9, X9, 48)
    // STRB W9, [X20, X21]
    let strb_idx_instr = 0x38200800 + (X21 * 65536) + (X20 * 32) + X9
    arm_emit(ctx, strb_idx_instr)
    arm_add_imm(ctx, X21, X21, 1)
    let b_loop_pos = ctx.code_len
    arm_b(ctx, 0)
    arm_patch_branch(ctx, b_loop_pos, digit_loop)

    let done_target = ctx.code_len
    arm_patch_branch(ctx, beq_done_pos, done_target)

    // Reverse digits into second buffer
    arm_sub_imm(ctx, X31, X31, 32)
    arm_mov(ctx, X22, X31)

    arm_mov_imm64(ctx, X23, 0)
    arm_sub_imm(ctx, X24, X21, 1)

    let rev_loop = ctx.code_len
    arm_cmp(ctx, X23, X21)
    let beq_rev_done_pos = ctx.code_len
    arm_bcond(ctx, ARM_EQ, 0)

    // LDRB W9, [X20, X24]
    let ldrb_idx_instr = 0x38600800 + (X24 * 65536) + (X20 * 32) + X9
    arm_emit(ctx, ldrb_idx_instr)
    // STRB W9, [X22, X23]
    let strb_out_instr = 0x38200800 + (X23 * 65536) + (X22 * 32) + X9
    arm_emit(ctx, strb_out_instr)

    arm_add_imm(ctx, X23, X23, 1)
    arm_sub_imm(ctx, X24, X24, 1)
    let b_rev_pos = ctx.code_len
    arm_b(ctx, 0)
    arm_patch_branch(ctx, b_rev_pos, rev_loop)

    let rev_done_target = ctx.code_len
    arm_patch_branch(ctx, beq_rev_done_pos, rev_done_target)

    // Write X23 bytes from X22
    arm_mov_imm64(ctx, X0, 1)
    arm_mov(ctx, X1, X22)
    arm_mov(ctx, X2, X23)
    arm_mov_imm64(ctx, X8, 64)
    arm_svc(ctx)

    // Deallocate 64 bytes (both buffers)
    arm_add_imm(ctx, X31, X31, 64)
    let b_past_zero_pos = ctx.code_len
    arm_b(ctx, 0)

    // zero_case: write "0"
    let zero_target = ctx.code_len
    arm_patch_branch(ctx, beq_zero_pos, zero_target)
    let zdata_off = ctx.data_len
    cg_add_string(ctx, "0")
    let zadr_pos = ctx.code_len
    let zadr_instr = 0x10000000 + X1
    arm_emit(ctx, zadr_instr)
    arm_add_fixup(ctx, zadr_pos, zdata_off)
    arm_add_imm(ctx, X1, X1, 8)
    arm_mov_imm64(ctx, X2, 1)
    arm_mov_imm64(ctx, X0, 1)
    arm_mov_imm64(ctx, X8, 64)
    arm_svc(ctx)
    // Deallocate buffer
    arm_add_imm(ctx, X31, X31, 32)

    let past_zero_target = ctx.code_len
    arm_patch_branch(ctx, b_past_zero_pos, past_zero_target)

    // Pop callee-saved registers
    arm_pop(ctx, X24)
    arm_pop(ctx, X23)
    arm_pop(ctx, X22)
    arm_pop(ctx, X21)
    arm_pop(ctx, X20)
    arm_pop(ctx, X19)

fn arm_cg_if_expr(ctx Ctx, e Node)
    arm_mov_imm64(ctx, X0, 0)

// ---------------------------------------------------------------------------
// AArch64 statement codegen
// ---------------------------------------------------------------------------

fn arm_cg_stmt(ctx Ctx, s Node)
    if s.kind == "let_stmt"
        let va = s.a
        let init = va[0]
        if init.kind == "string_lit"
            ctx.var_types[s.sval] = "str"
        if init.kind == "int_lit"
            ctx.var_types[s.sval] = "int"
        if init.kind == "bool_true"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "bool_false"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "ident"
            if ctx.var_types.has(init.sval)
                ctx.var_types[s.sval] = ctx.var_types[init.sval]
        if init.kind == "call"
            let fa = init.a
            if fa[0].kind == "ident"
                let fname = fa[0].sval
                if ctx.fn_ret_types.has(fname)
                    let rt = ctx.fn_ret_types[fname]
                    if rt == "str"
                        ctx.var_types[s.sval] = "str"
                    if rt == "int"
                        ctx.var_types[s.sval] = "int"
                    if rt == "bool"
                        ctx.var_types[s.sval] = "bool"
        arm_cg_expr(ctx, init)
        let offset = cg_get_var_offset(ctx, s.sval)
        arm_str_safe(ctx, X0, X29, offset)
        return
    if s.kind == "return"
        if s.a.has(0)
            let va = s.a
            arm_cg_expr(ctx, va[0])
        if ctx.is_main
            if not s.a.has(0)
                arm_mov_imm64(ctx, X0, 0)
            arm_mov_imm64(ctx, X8, 93)
            arm_svc(ctx)
        else
            arm_emit_epilogue(ctx)
        return
    if s.kind == "expr_stmt"
        let ea = s.a
        arm_cg_expr(ctx, ea[0])
        return
    if s.kind == "assign"
        let ea = s.a
        let vb = s.b
        let target = ea[0]
        if target.kind == "ident"
            arm_cg_expr(ctx, vb[0])
            let offset = cg_get_var_offset(ctx, target.sval)
            arm_str_safe(ctx, X0, X29, offset)
            return
        arm_cg_expr(ctx, vb[0])
        return
    if s.kind == "if_stmt"
        arm_cg_if(ctx, s)
        return
    if s.kind == "while_stmt"
        arm_cg_while(ctx, s)
        return
    if s.kind == "for_stmt"
        if s.bval
            arm_cg_for_range(ctx, s)
        return
    if s.kind == "assert_stmt"
        let ea = s.a
        arm_cg_expr(ctx, ea[0])
        return

fn arm_cg_if(ctx Ctx, s Node)
    // if_stmt structure (matches x86_64 cg_if):
    //   s.list = list of branch nodes (branch 0 = if, branch 1+ = but/else-if)
    //   s.a = else block (may be empty)
    // Each branch node has:
    //   b.a = {0: condition expr}
    //   b.b = block (table of statements)
    let branches = s.list
    let mut end_jumps = {}
    let mut njumps = 0
    let mut bi = 0
    while bi < branches.len()
        let b = branches[bi]
        let ca = b.a
        arm_cg_expr(ctx, ca[0])
        arm_cmp_imm(ctx, X0, 0)
        let beq_next_pos = ctx.code_len
        arm_bcond(ctx, ARM_EQ, 0)
        // Then-block
        let block = b.b
        let mut si = 0
        while si < block.len()
            arm_cg_stmt(ctx, block[si])
            si = si + 1
        // JMP to end
        let b_end_pos = ctx.code_len
        arm_b(ctx, 0)
        end_jumps[njumps] = b_end_pos
        njumps = njumps + 1
        // Next branch / else starts here
        let next_target = ctx.code_len
        arm_patch_branch(ctx, beq_next_pos, next_target)
        bi = bi + 1
    // Else block (if any)
    if s.a.has(0)
        let eb = s.a
        let else_block = eb[0].list
        let mut j = 0
        while j < else_block.len()
            arm_cg_stmt(ctx, else_block[j])
            j = j + 1
    // Patch all end jumps to here
    let end_target = ctx.code_len
    let mut ji = 0
    while ji < njumps
        let jmp_pos = end_jumps[ji]
        arm_patch_branch(ctx, jmp_pos, end_target)
        ji = ji + 1

fn arm_cg_while(ctx Ctx, s Node)
    let ea = s.a
    let cond = ea[0]
    let loop_start = ctx.code_len
    arm_cg_expr(ctx, cond)
    arm_cmp_imm(ctx, X0, 0)
    let beq_end_pos = ctx.code_len
    arm_bcond(ctx, ARM_EQ, 0)
    let ld = ctx.loop_depth
    ctx.continue_targets[ld] = loop_start
    ctx.break_targets[ld] = beq_end_pos
    ctx.loop_depth = ld + 1
    let body = s.list
    let mut i = 0
    while i < body.len()
        arm_cg_stmt(ctx, body[i])
        i = i + 1
    ctx.loop_depth = ld
    let b_loop_pos = ctx.code_len
    arm_b(ctx, 0)
    arm_patch_branch(ctx, b_loop_pos, loop_start)
    let end_target = ctx.code_len
    arm_patch_branch(ctx, beq_end_pos, end_target)

fn arm_cg_for_range(ctx Ctx, s Node)
    let ea = s.a
    let range_node = ea[0]
    let i_offset = cg_get_var_offset(ctx, s.sval)
    if range_node.a.has(0)
        let ra = range_node.a
        arm_cg_expr(ctx, ra[0])
    else
        arm_mov_imm64(ctx, X0, 0)
    arm_str_safe(ctx, X0, X29, i_offset)

    let loop_start = ctx.code_len
    arm_ldr_safe(ctx, X0, X29, i_offset)
    if range_node.b.has(0)
        let rb = range_node.b
        arm_cg_expr(ctx, rb[0])
    else
        arm_mov_imm64(ctx, X0, 0)
    arm_mov(ctx, X1, X0)
    arm_ldr_safe(ctx, X0, X29, i_offset)
    arm_cmp(ctx, X0, X1)
    let bge_end_pos = ctx.code_len
    arm_bcond(ctx, ARM_GE, 0)

    let ld = ctx.loop_depth
    ctx.continue_targets[ld] = loop_start
    ctx.break_targets[ld] = bge_end_pos
    ctx.loop_depth = ld + 1
    let body = s.list
    let mut i = 0
    while i < body.len()
        arm_cg_stmt(ctx, body[i])
        i = i + 1
    ctx.loop_depth = ld

    arm_ldr_safe(ctx, X0, X29, i_offset)
    arm_add_imm(ctx, X0, X0, 1)
    arm_str_safe(ctx, X0, X29, i_offset)
    let b_loop_pos = ctx.code_len
    arm_b(ctx, 0)
    arm_patch_branch(ctx, b_loop_pos, loop_start)
    let end_target = ctx.code_len
    arm_patch_branch(ctx, bge_end_pos, end_target)

// ---------------------------------------------------------------------------
// AArch64 function codegen
// ---------------------------------------------------------------------------

fn arm_cg_function(ctx Ctx, fn_decl Node, is_main bool)
    let fn_start = ctx.code_len
    let fn_name = fn_decl.sval
    ctx.fn_table[fn_name] = fn_start
    ctx.fn_count = ctx.fn_count + 1
    ctx.var_slots = {}
    ctx.next_slot = -8
    ctx.var_types = {}

    let sub_pos = arm_emit_prologue(ctx)

    let params = fn_decl.a
    let mut pi = 0
    while pi < params.len() and pi < 8
        let param = params[pi]
        let local_offset = cg_get_var_offset(ctx, param.sval)
        arm_str_safe(ctx, pi, X29, local_offset)
        ctx.var_types[param.sval] = param.extra
        pi = pi + 1

    ctx.is_main = is_main
    let body = fn_decl.list
    let mut i = 0
    while i < body.len()
        arm_cg_stmt(ctx, body[i])
        i = i + 1

    if is_main
        arm_mov_imm64(ctx, X0, 0)
        arm_mov_imm64(ctx, X8, 93)
        arm_svc(ctx)
    else
        arm_mov_imm64(ctx, X0, 0)
        arm_emit_epilogue(ctx)

    // Patch frame size in the SUB SP, SP, #0 instruction
    let frame_size = 0 - ctx.next_slot - 8
    let mut aligned_frame = frame_size
    if aligned_frame % 16 != 0
        aligned_frame = aligned_frame + (16 - (aligned_frame % 16))
    if aligned_frame > 0 and aligned_frame < 4096
        let instr = 0xD10003FF + ((aligned_frame & 4095) * 1024)
        ctx.code_data[sub_pos] = instr % 256
        ctx.code_data[sub_pos + 1] = (instr / 256) % 256
        ctx.code_data[sub_pos + 2] = (instr / 65536) % 256
        ctx.code_data[sub_pos + 3] = (instr / 16777216) % 256
// ===========================================================================
// RISC-V 64-bit (RV64) codegen — parallel path activated when ctx.target == 2
// ===========================================================================
// Mirrors the AArch64/x86_64 paths but emits RV64I+M instructions.
//
// LP64 ABI:
//   x10-x17 = a0-a7 (function args / return values)
//   x1 = ra (return address), x2 = sp, x8 = s0/fp, x0 = zero
//   x5-x7,x28-x31 = t0-t6 (caller-saved temps)
//   x9,x18-x27 = s1-s11 (callee-saved)
//
// Syscall convention (Linux RV64):
//   a7 = syscall number, a0-a5 = args, a0 = return value
//   write = 64, exit = 93, exit_group = 94
//
// Frame layout (per function):
//   Prologue: ADDI sp, sp, -frame_size ; SD ra, [sp, frame_size-8] ; SD s0, [sp, frame_size-16]
//             ADDI s0, sp, frame_size
//   Epilogue: LD ra, [sp, frame_size-8] ; LD s0, [sp, frame_size-16] ; ADDI sp, sp, frame_size ; RET
//
// Local variables at s0-relative negative offsets (same convention as x86_64).
// ===========================================================================

// RV64 register numbers
let RV_ZERO = 0  // x0 - hardwired zero
let RV_RA = 1    // x1 - return address
let RV_SP = 2    // x2 - stack pointer
let RV_FP = 8    // x8 - frame pointer (s0)
let RV_A0 = 10
let RV_A1 = 11
let RV_A2 = 12
let RV_A3 = 13
let RV_A4 = 14
let RV_A5 = 15
let RV_A6 = 16
let RV_A7 = 17
let RV_T0 = 5
let RV_T1 = 6
let RV_T2 = 7
let RV_T3 = 28
let RV_T4 = 29
let RV_T5 = 30
let RV_T6 = 31
let RV_S1 = 9
let RV_S2 = 18
let RV_S3 = 19
let RV_S4 = 20
let RV_S5 = 21
let RV_S6 = 22
let RV_S7 = 23
let RV_S8 = 24
let RV_S9 = 25
let RV_S10 = 26
let RV_S11 = 27

// RV64 opcodes
let RV_OP_OP_IMM = 0x13    // ADDI, SLTI, SLTIU, XORI, ORI, ANDI, SLLI, SRLI, SRAI
let RV_OP_OP = 0x33        // R-format: ADD, SUB, SLL, SLT, SLTU, XOR, SRL, SRA, OR, AND, MUL, DIV, REM
let RV_OP_LOAD = 0x03      // LB, LH, LW, LD, LBU, LHU, LWU
let RV_OP_STORE = 0x23     // SB, SH, SW, SD
let RV_OP_BRANCH = 0x63    // BEQ, BNE, BLT, BGE, BLTU, BGEU
let RV_OP_JAL = 0x6F       // JAL
let RV_OP_JALR = 0x67      // JALR
let RV_OP_LUI = 0x37       // LUI
let RV_OP_AUIPC = 0x17     // AUIPC
let RV_OP_SYSTEM = 0x73    // ECALL, EBREAK

// funct3 for OP-IMM
let RV_F3_ADDI = 0
let RV_F3_SLTI = 2
let RV_F3_SLTIU = 3
let RV_F3_XORI = 4
let RV_F3_ORI = 6
let RV_F3_ANDI = 7
let RV_F3_SLLI = 1
let RV_F3_SRLI_SRAI = 5

// funct3 for OP
let RV_F3_ADD_SUB = 0
let RV_F3_SLL = 1
let RV_F3_SLT = 2
let RV_F3_SLTU = 3
let RV_F3_XOR = 4
let RV_F3_SRL_SRA = 5
let RV_F3_OR = 6
let RV_F3_AND = 7
let RV_F3_MUL = 0    // M extension
let RV_F3_DIV = 4
let RV_F3_REM = 6

// funct7 for OP
let RV_F7_ADD = 0x00
let RV_F7_SUB = 0x20
let RV_F7_SRL = 0x00
let RV_F7_SRA = 0x20
let RV_F7_MULDIV = 0x01

// funct3 for LOAD
let RV_F3_LD = 3   // 64-bit load

// funct3 for STORE
let RV_F3_SD = 3   // 64-bit store
let RV_F3_SB = 0   // byte store
let RV_F3_LB = 0   // byte load (signed)
let RV_F3_LBU = 4  // byte load (unsigned)

// funct3 for BRANCH
let RV_F3_BEQ = 0
let RV_F3_BNE = 1
let RV_F3_BLT = 4
let RV_F3_BGE = 5
let RV_F3_BLTU = 6
let RV_F3_BGEU = 7

// ---------------------------------------------------------------------------
// Instruction encoders (4 formats: R, I, S, B, U, J)
// ---------------------------------------------------------------------------

// rv_emit: emit a 32-bit RV64 instruction (little-endian)
fn rv_emit(ctx Ctx, instr int)
    code_byte(ctx, instr % 256)
    code_byte(ctx, (instr / 256) % 256)
    code_byte(ctx, (instr / 65536) % 256)
    code_byte(ctx, (instr / 16777216) % 256)

// Sign-extend an N-bit value to 64-bit (Yilt ints are 64-bit signed)
fn rv_sign_extend(v int, bits int) int
    let mut val = v
    let mut sign_bit = 1
    let mut i = 1
    while i < bits
        sign_bit = sign_bit * 2
        i = i + 1
    if (val & sign_bit) != 0
        // Negative: sign-extend by setting higher bits
        let mask = 0 - sign_bit * 2  // all 1s above the sign bit
        val = val | mask
    return val

// Mask off the lower N bits
fn rv_mask_lo(v int, bits int) int
    let mut mask = 1
    let mut i = 1
    while i < bits
        mask = mask * 2 + 1
        i = i + 1
    return v & mask

// R-format encoder: [funct7:7 | rs2:5 | rs1:5 | funct3:3 | rd:5 | opcode:7]
fn rv_enc_r(opcode int, rd int, funct3 int, rs1 int, rs2 int, funct7 int) int
    let instr = (funct7 * 33554432) + (rs2 * 1048576) + (rs1 * 32768) + (funct3 * 4096) + (rd * 128) + opcode
    return instr

// I-format encoder: [imm:12 | rs1:5 | funct3:3 | rd:5 | opcode:7]
fn rv_enc_i(opcode int, rd int, funct3 int, rs1 int, imm int) int
    let imm12 = imm & 4095
    let instr = (imm12 * 1048576) + (rs1 * 32768) + (funct3 * 4096) + (rd * 128) + opcode
    return instr

// S-format encoder: [imm[11:5]:7 | rs2:5 | rs1:5 | funct3:3 | imm[4:0]:5 | opcode:7]
fn rv_enc_s(opcode int, funct3 int, rs1 int, rs2 int, imm int) int
    let imm_hi = (imm >> 5) & 127
    let imm_lo = imm & 31
    let instr = (imm_hi * 33554432) + (rs2 * 1048576) + (rs1 * 32768) + (funct3 * 4096) + (imm_lo * 128) + opcode
    return instr

// B-format encoder: [imm[12]:1 | imm[10:5]:6 | rs2:5 | rs1:5 | funct3:3 | imm[4:1]:4 | imm[11]:1 | opcode:7]
// Imm is in BYTES (must be even), encoded as 13-bit signed (imm[12:1], bit 0 always 0)
fn rv_enc_b(opcode int, funct3 int, rs1 int, rs2 int, imm int) int
    let bit12 = (imm >> 12) & 1
    let bits10to5 = (imm >> 5) & 63
    let bit11 = (imm >> 11) & 1
    let bits4to1 = (imm >> 1) & 15
    let instr = (bit12 * 2147483648) + (bits10to5 * 33554432) + (rs2 * 1048576) + (rs1 * 32768) + (funct3 * 4096) + (bits4to1 * 256) + (bit11 * 128) + opcode
    return instr

// U-format encoder: [imm[31:12]:20 | rd:5 | opcode:7]
fn rv_enc_u(opcode int, rd int, imm int) int
    let imm20 = (imm >> 12) & 1048575
    let instr = (imm20 * 4096) + (rd * 128) + opcode
    return instr

// J-format encoder: [imm[20]:1 | imm[10:1]:10 | imm[11]:1 | imm[19:12]:8 | rd:5 | opcode:7]
// Imm is in BYTES (must be even), encoded as 21-bit signed
fn rv_enc_j(opcode int, rd int, imm int) int
    let bit20 = (imm >> 20) & 1
    let bits10to1 = (imm >> 1) & 1023
    let bit11 = (imm >> 11) & 1
    let bits19to12 = (imm >> 12) & 255
    let instr = (bit20 * 2147483648) + (bits10to1 * 2097152) + (bit11 * 1048576) + (bits19to12 * 4096) + (rd * 128) + opcode
    return instr

// ---------------------------------------------------------------------------
// Individual RV64 instructions
// ---------------------------------------------------------------------------

// ADDI rd, rs1, imm
fn rv_addi(ctx Ctx, rd int, rs1 int, imm int)
    rv_emit(ctx, rv_enc_i(RV_OP_OP_IMM, rd, RV_F3_ADDI, rs1, imm))

// ADD rd, rs1, rs2
fn rv_add(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_ADD_SUB, rs1, rs2, RV_F7_ADD))

// SUB rd, rs1, rs2
fn rv_sub(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_ADD_SUB, rs1, rs2, RV_F7_SUB))

// MUL rd, rs1, rs2 (M extension)
fn rv_mul(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_MUL, rs1, rs2, RV_F7_MULDIV))

// DIV rd, rs1, rs2 (signed)
fn rv_div(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_DIV, rs1, rs2, RV_F7_MULDIV))

// REM rd, rs1, rs2 (signed modulo)
fn rv_rem(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_REM, rs1, rs2, RV_F7_MULDIV))

// AND rd, rs1, rs2
fn rv_and(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_AND, rs1, rs2, RV_F7_ADD))

// OR rd, rs1, rs2
fn rv_or(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_OR, rs1, rs2, RV_F7_ADD))

// XOR rd, rs1, rs2
fn rv_xor(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_XOR, rs1, rs2, RV_F7_ADD))

// SLL rd, rs1, rs2 (shift left logical)
fn rv_sll(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_SLL, rs1, rs2, RV_F7_ADD))

// SRL rd, rs1, rs2 (shift right logical)
fn rv_srl(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_SRL_SRA, rs1, rs2, RV_F7_SRL))

// SRA rd, rs1, rs2 (shift right arithmetic)
fn rv_sra(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_SRL_SRA, rs1, rs2, RV_F7_SRA))

// SLT rd, rs1, rs2 (set less than, signed)
fn rv_slt(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_SLT, rs1, rs2, RV_F7_ADD))

// SLTU rd, rs1, rs2 (set less than, unsigned)
fn rv_sltu(ctx Ctx, rd int, rs1 int, rs2 int)
    rv_emit(ctx, rv_enc_r(RV_OP_OP, rd, RV_F3_SLTU, rs1, rs2, RV_F7_ADD))

// LD rd, [rs1, offset]
fn rv_ld(ctx Ctx, rd int, rs1 int, offset int)
    rv_emit(ctx, rv_enc_i(RV_OP_LOAD, rd, RV_F3_LD, rs1, offset))

// SD rs2, [rs1, offset]
fn rv_sd(ctx Ctx, rs2 int, rs1 int, offset int)
    rv_emit(ctx, rv_enc_s(RV_OP_STORE, RV_F3_SD, rs1, rs2, offset))

// LBU rd, [rs1, offset] (load byte unsigned)
fn rv_lbu(ctx Ctx, rd int, rs1 int, offset int)
    rv_emit(ctx, rv_enc_i(RV_OP_LOAD, rd, RV_F3_LBU, rs1, offset))

// SB rs2, [rs1, offset] (store byte)
fn rv_sb(ctx Ctx, rs2 int, rs1 int, offset int)
    rv_emit(ctx, rv_enc_s(RV_OP_STORE, RV_F3_SB, rs1, rs2, offset))

// BEQ rs1, rs2, offset
fn rv_beq(ctx Ctx, rs1 int, rs2 int, offset int)
    rv_emit(ctx, rv_enc_b(RV_OP_BRANCH, RV_F3_BEQ, rs1, rs2, offset))

// BNE rs1, rs2, offset
fn rv_bne(ctx Ctx, rs1 int, rs2 int, offset int)
    rv_emit(ctx, rv_enc_b(RV_OP_BRANCH, RV_F3_BNE, rs1, rs2, offset))

// BLT rs1, rs2, offset (signed)
fn rv_blt(ctx Ctx, rs1 int, rs2 int, offset int)
    rv_emit(ctx, rv_enc_b(RV_OP_BRANCH, RV_F3_BLT, rs1, rs2, offset))

// BGE rs1, rs2, offset (signed)
fn rv_bge(ctx Ctx, rs1 int, rs2 int, offset int)
    rv_emit(ctx, rv_enc_b(RV_OP_BRANCH, RV_F3_BGE, rs1, rs2, offset))

// JAL rd, offset
fn rv_jal(ctx Ctx, rd int, offset int)
    rv_emit(ctx, rv_enc_j(RV_OP_JAL, rd, offset))

// JALR rd, rs1, offset (JALR x0, x1, 0 = RET)
fn rv_jalr(ctx Ctx, rd int, rs1 int, offset int)
    rv_emit(ctx, rv_enc_i(RV_OP_JALR, rd, RV_F3_BEQ, rs1, offset))

// LUI rd, imm (load upper 20 bits)
fn rv_lui(ctx Ctx, rd int, imm int)
    rv_emit(ctx, rv_enc_u(RV_OP_LUI, rd, imm))

// AUIPC rd, imm (add upper immediate to PC)
fn rv_auipc(ctx Ctx, rd int, imm int)
    rv_emit(ctx, rv_enc_u(RV_OP_AUIPC, rd, imm))

// ECALL
fn rv_ecall(ctx Ctx)
    rv_emit(ctx, RV_OP_SYSTEM)

// RET = JALR x0, x1, 0
fn rv_ret(ctx Ctx)
    rv_jalr(ctx, RV_ZERO, RV_RA, 0)

// MV rd, rs1 = ADDI rd, rs1, 0
fn rv_mv(ctx Ctx, rd int, rs1 int)
    rv_addi(ctx, rd, rs1, 0)

// LI rd, imm (load immediate — uses LUI+ADDI for large values, ADDI for small)
fn rv_li(ctx Ctx, rd int, imm int)
    // If imm fits in 12-bit signed (-2048..2047), use ADDI rd, x0, imm
    if imm >= -2048 and imm <= 2047
        rv_addi(ctx, rd, RV_ZERO, imm)
        return
    // Otherwise: LUI rd, upper20; ADDI rd, rd, lower12
    // Need to handle sign-extension of lower 12 bits
    let mut upper = (imm >> 12) & 1048575
    let lower = imm & 4095
    // If lower would be sign-extended as negative, adjust upper
    if lower >= 2048
        upper = (upper + 1) & 1048575
    rv_lui(ctx, rd, upper)
    rv_addi(ctx, rd, rd, lower)

// ---------------------------------------------------------------------------
// Helper: push/pop on stack (8 bytes each, 16-byte aligned)
// ---------------------------------------------------------------------------

// rv_push: SD rs, [sp, -16]; ADDI sp, sp, -16  (also keeps 16-byte alignment)
// Actually for RV64 we want: ADDI sp, sp, -16; SD rs, [sp, 8] (or [sp, 0])
// To keep things simple: ADDI sp, sp, -16; SD rs, [sp, 8]
fn rv_push(ctx Ctx, rs int)
    rv_addi(ctx, RV_SP, RV_SP, -16)
    rv_sd(ctx, rs, RV_SP, 8)

// rv_pop: LD rd, [sp, 8]; ADDI sp, sp, 16
fn rv_pop(ctx Ctx, rd int)
    rv_ld(ctx, rd, RV_SP, 8)
    rv_addi(ctx, RV_SP, RV_SP, 16)

// ---------------------------------------------------------------------------
// RV64 codegen dispatchers
// ---------------------------------------------------------------------------

// rv_cg_expr: evaluate expression, result in a0 (x10)
fn rv_cg_expr(ctx Ctx, e Node)
    if e.kind == "int_lit"
        let val = parse_int(e.sval)
        rv_li(ctx, RV_A0, val)
        return
    if e.kind == "bool_true"
        rv_li(ctx, RV_A0, 1)
        return
    if e.kind == "bool_false"
        rv_li(ctx, RV_A0, 0)
        return
    if e.kind == "nil"
        rv_li(ctx, RV_A0, 0)
        return
    if e.kind == "float_lit"
        let val = parse_int(e.sval)
        rv_li(ctx, RV_A0, val)
        return
    if e.kind == "ident"
        let offset = cg_get_var_offset(ctx, e.sval)
        rv_ld(ctx, RV_A0, RV_FP, offset)
        return
    if e.kind == "binary"
        rv_cg_binary(ctx, e)
        return
    if e.kind == "unary"
        rv_cg_unary(ctx, e)
        return
    if e.kind == "call"
        rv_cg_call(ctx, e)
        return
    if e.kind == "string_lit"
        let data_off = ctx.data_len
        cg_add_string(ctx, e.sval)
        // AUIPC + ADDI to compute address (PC-relative)
        // AUIPC a0, 0; ADDI a0, a0, 0 — we patch both at fixup time
        let auipc_pos = ctx.code_len
        rv_auipc(ctx, RV_A0, 0)
        rv_addi(ctx, RV_A0, RV_A0, 0)
        rv_add_fixup(ctx, auipc_pos, data_off)
        return
    if e.kind == "if_expr"
        rv_cg_if_expr(ctx, e)
        return
    rv_li(ctx, RV_A0, 0)

// rv_add_fixup: record an AUIPC+ADDI fixup for RV64
// At patch time, we need to compute the offset from auipc_pos to (code_len + data_off)
// and split it into upper20 + lower12 (with sign-extension handling).
fn rv_add_fixup(ctx Ctx, auipc_pos int, data_off int)
    let idx = ctx.fixup_count
    // Use 300000+ region of code_data for RV64 fixups
    ctx.code_data[300000 + idx * 2] = auipc_pos
    ctx.code_data[300000 + idx * 2 + 1] = data_off
    ctx.fixup_count = idx + 1

// rv_apply_fixups: patch all AUIPC+ADDI pairs
fn rv_apply_fixups(ctx Ctx)
    let mut i = 0
    while i < ctx.fixup_count
        let auipc_pos = ctx.code_data[300000 + i * 2]
        let data_off = ctx.code_data[300000 + i * 2 + 1]
        // Target = code_len + data_off (data starts after code)
        // AUIPC reads PC = auipc_pos, so offset = target - auipc_pos
        let off = (ctx.code_len + data_off) - auipc_pos
        // Split into upper20 and lower12
        let mut upper = (off >> 12) & 1048575
        let lower = off & 4095
        if lower >= 2048
            upper = (upper + 1) & 1048575
        // Patch AUIPC: [imm[31:12]:20 | rd:5 | opcode:7]
        // AUIPC instruction at auipc_pos: 0x17 | (rd << 7) | (upper << 12)
        let auipc_instr = (upper * 4096) + (RV_A0 * 128) + RV_OP_AUIPC
        ctx.code_data[auipc_pos] = auipc_instr % 256
        ctx.code_data[auipc_pos + 1] = (auipc_instr / 256) % 256
        ctx.code_data[auipc_pos + 2] = (auipc_instr / 65536) % 256
        ctx.code_data[auipc_pos + 3] = (auipc_instr / 16777216) % 256
        // Patch ADDI: [imm:12 | rs1:5 | funct3:3 | rd:5 | opcode:7]
        let addi_pos = auipc_pos + 4
        let addi_instr = (lower * 1048576) + (RV_A0 * 32768) + (RV_F3_ADDI * 4096) + (RV_A0 * 128) + RV_OP_OP_IMM
        ctx.code_data[addi_pos] = addi_instr % 256
        ctx.code_data[addi_pos + 1] = (addi_instr / 256) % 256
        ctx.code_data[addi_pos + 2] = (addi_instr / 65536) % 256
        ctx.code_data[addi_pos + 3] = (addi_instr / 16777216) % 256
        i = i + 1

// rv_apply_call_fixups: patch all JAL instructions
fn rv_apply_call_fixups(ctx Ctx)
    let mut ci = 0
    while ci < ctx.call_fixup_count
        let call_pos = ctx.call_fixups[ci * 2]
        let fn_name = ctx.call_fixups[ci * 2 + 1]
        if ctx.fn_table.has(fn_name)
            let fn_start = ctx.fn_table[fn_name]
            let disp = fn_start - call_pos
            // JAL encoding: [imm[20]:1 | imm[10:1]:10 | imm[11]:1 | imm[19:12]:8 | rd:5 | opcode:7]
            let bit20 = (disp >> 20) & 1
            let bits10to1 = (disp >> 1) & 1023
            let bit11 = (disp >> 11) & 1
            let bits19to12 = (disp >> 12) & 255
            let instr = (bit20 * 2147483648) + (bits10to1 * 2097152) + (bit11 * 1048576) + (bits19to12 * 4096) + (RV_RA * 128) + RV_OP_JAL
            ctx.code_data[call_pos] = instr % 256
            ctx.code_data[call_pos + 1] = (instr / 256) % 256
            ctx.code_data[call_pos + 2] = (instr / 65536) % 256
            ctx.code_data[call_pos + 3] = (instr / 16777216) % 256
        ci = ci + 1

// rv_patch_branch: patch a B-format branch placeholder at pos to target
fn rv_patch_branch(ctx Ctx, pos int, target int)
    let off = target - pos
    // Read existing instruction to determine branch type (funct3)
    let instr = ctx.code_data[pos] + (ctx.code_data[pos + 1] * 256) + (ctx.code_data[pos + 2] * 65536) + (ctx.code_data[pos + 3] * 16777216)
    let funct3 = (instr >> 12) & 7
    let rs1 = (instr >> 15) & 31
    let rs2 = (instr >> 20) & 31
    let new_instr = rv_enc_b(RV_OP_BRANCH, funct3, rs1, rs2, off)
    ctx.code_data[pos] = new_instr % 256
    ctx.code_data[pos + 1] = (new_instr / 256) % 256
    ctx.code_data[pos + 2] = (new_instr / 65536) % 256
    ctx.code_data[pos + 3] = (new_instr / 16777216) % 256

// rv_patch_jal: patch a JAL placeholder at pos to target
fn rv_patch_jal(ctx Ctx, pos int, target int)
    let off = target - pos
    let bit20 = (off >> 20) & 1
    let bits10to1 = (off >> 1) & 1023
    let bit11 = (off >> 11) & 1
    let bits19to12 = (off >> 12) & 255
    // Read existing instruction to get rd
    let instr = ctx.code_data[pos] + (ctx.code_data[pos + 1] * 256) + (ctx.code_data[pos + 2] * 65536) + (ctx.code_data[pos + 3] * 16777216)
    let rd = (instr >> 7) & 31
    let new_instr = (bit20 * 2147483648) + (bits10to1 * 2097152) + (bit11 * 1048576) + (bits19to12 * 4096) + (rd * 128) + RV_OP_JAL
    ctx.code_data[pos] = new_instr % 256
    ctx.code_data[pos + 1] = (new_instr / 256) % 256
    ctx.code_data[pos + 2] = (new_instr / 65536) % 256
    ctx.code_data[pos + 3] = (new_instr / 16777216) % 256

// rv_cg_binary: evaluate binary op, result in a0
fn rv_cg_binary(ctx Ctx, e Node)
    let la = e.a
    let rb = e.b
    let op = e.sval

    if op == "and"
        rv_cg_expr(ctx, la[0])
        rv_push(ctx, RV_A0)
        rv_cg_expr(ctx, rb[0])
        rv_pop(ctx, RV_T0)
        // a0 = (t0 != 0) and (a0 != 0)
        rv_sltu(ctx, RV_A0, RV_ZERO, RV_A0)  // a0 = (a0 != 0) ? 1 : 0
        rv_sltu(ctx, RV_T0, RV_ZERO, RV_T0)  // t0 = (t0 != 0) ? 1 : 0
        rv_and(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "or"
        rv_cg_expr(ctx, la[0])
        rv_push(ctx, RV_A0)
        rv_cg_expr(ctx, rb[0])
        rv_pop(ctx, RV_T0)
        rv_sltu(ctx, RV_A0, RV_ZERO, RV_A0)
        rv_sltu(ctx, RV_T0, RV_ZERO, RV_T0)
        rv_or(ctx, RV_A0, RV_T0, RV_A0)
        return

    // Evaluate left → a0, push, evaluate right → a0, pop into t0
    rv_cg_expr(ctx, la[0])
    rv_push(ctx, RV_A0)
    rv_cg_expr(ctx, rb[0])
    rv_pop(ctx, RV_T0)
    // Now: t0 = left, a0 = right
    // Compute a0 = t0 op a0

    if op == "+"
        rv_add(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "-"
        rv_sub(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "*"
        rv_mul(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "/"
        rv_div(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "%"
        rv_rem(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "=="
        // a0 = (t0 == a0) ? 1 : 0
        // SUB t1, t0, a0; SEQZ a0, t1 = SLTIU a0, t1, 1
        rv_sub(ctx, RV_T1, RV_T0, RV_A0)
        rv_sltu(ctx, RV_A0, RV_T1, 1)
        return
    if op == "!="
        rv_sub(ctx, RV_T1, RV_T0, RV_A0)
        rv_sltu(ctx, RV_A0, RV_ZERO, RV_T1)  // a0 = (t1 != 0) ? 1 : 0
        return
    if op == "<"
        rv_slt(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == ">"
        rv_slt(ctx, RV_A0, RV_A0, RV_T0)
        return
    if op == "<="
        // a0 = (t0 <= a0) ? 1 : 0 = !(t0 > a0) = !(a0 < t0)
        rv_slt(ctx, RV_T1, RV_A0, RV_T0)
        rv_xori(ctx, RV_A0, RV_T1, 1)
        return
    if op == ">="
        rv_slt(ctx, RV_T1, RV_T0, RV_A0)
        rv_xori(ctx, RV_A0, RV_T1, 1)
        return
    if op == "&"
        rv_and(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "|"
        rv_or(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "^"
        rv_xor(ctx, RV_A0, RV_T0, RV_A0)
        return
    rv_li(ctx, RV_A0, 0)

// Helper: XORI rd, rs1, imm
fn rv_xori(ctx Ctx, rd int, rs1 int, imm int)
    rv_emit(ctx, rv_enc_i(RV_OP_OP_IMM, rd, RV_F3_XORI, rs1, imm))

// Helper: ORI rd, rs1, imm
fn rv_ori(ctx Ctx, rd int, rs1 int, imm int)
    rv_emit(ctx, rv_enc_i(RV_OP_OP_IMM, rd, RV_F3_ORI, rs1, imm))

// Helper: ANDI rd, rs1, imm
fn rv_andi(ctx Ctx, rd int, rs1 int, imm int)
    rv_emit(ctx, rv_enc_i(RV_OP_OP_IMM, rd, RV_F3_ANDI, rs1, imm))

// rv_cg_unary: unary operations
fn rv_cg_unary(ctx Ctx, e Node)
    let operand = e.a[0]
    let op = e.sval
    if op == "-"
        rv_cg_expr(ctx, operand)
        rv_sub(ctx, RV_A0, RV_ZERO, RV_A0)
        return
    if op == "!"
        rv_cg_expr(ctx, operand)
        // a0 = (a0 == 0) ? 1 : 0 = SEQZ a0, a0 = SLTIU a0, a0, 1
        rv_sltu(ctx, RV_A0, RV_A0, 1)
        return
    if op == "~"
        rv_cg_expr(ctx, operand)
        rv_xori(ctx, RV_A0, RV_A0, -1)
        return
    rv_cg_expr(ctx, operand)

// rv_cg_call: function call
fn rv_cg_call(ctx Ctx, e Node)
    let fa = e.a
    if fa[0].kind != "ident"
        rv_li(ctx, RV_A0, 0)
        return
    let fn_name = fa[0].sval

    if fn_name == "println"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            if arg.kind == "string_lit"
                rv_cg_print_string_lit(ctx, arg.sval)
            else
                if arg.kind == "int_lit"
                    rv_li(ctx, RV_A0, parse_int(arg.sval))
                    rv_cg_print_int(ctx)
                else
                    if arg.kind == "bool_true"
                        rv_cg_print_string_lit(ctx, "true")
                    else
                        if arg.kind == "bool_false"
                            rv_cg_print_string_lit(ctx, "false")
                        else
                            if arg.kind == "ident"
                                if ctx.var_types.has(arg.sval)
                                    let vt = ctx.var_types[arg.sval]
                                    if vt == "str"
                                        let offset = cg_get_var_offset(ctx, arg.sval)
                                        rv_ld(ctx, RV_A0, RV_FP, offset)
                                        rv_cg_print_string_val(ctx)
                                    else
                                        rv_cg_expr(ctx, arg)
                                        rv_cg_print_int(ctx)
                                else
                                    rv_cg_expr(ctx, arg)
                                    rv_cg_print_int(ctx)
                            else
                                rv_cg_expr(ctx, arg)
                                rv_cg_print_int(ctx)
        rv_cg_print_string_lit(ctx, "\n")
        return
    if fn_name == "print"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            if arg.kind == "string_lit"
                rv_cg_print_string_lit(ctx, arg.sval)
                return
            if arg.kind == "int_lit"
                rv_li(ctx, RV_A0, parse_int(arg.sval))
                rv_cg_print_int(ctx)
                return
            if arg.kind == "bool_true"
                rv_cg_print_string_lit(ctx, "true")
                return
            if arg.kind == "bool_false"
                rv_cg_print_string_lit(ctx, "false")
                return
            if arg.kind == "ident"
                if ctx.var_types.has(arg.sval)
                    let vt = ctx.var_types[arg.sval]
                    if vt == "str"
                        let offset = cg_get_var_offset(ctx, arg.sval)
                        rv_ld(ctx, RV_A0, RV_FP, offset)
                        rv_cg_print_string_val(ctx)
                        return
            rv_cg_expr(ctx, arg)
            rv_cg_print_int(ctx)
        return
    if fn_name == "len"
        let args = e.list
        if args.len() > 0
            rv_cg_expr(ctx, args[0])
            rv_ld(ctx, RV_A0, RV_A0, 0)
            return
        rv_li(ctx, RV_A0, 0)
        return

    // User-defined function call: evaluate args in reverse, placing in a0-a7
    let args = e.list
    let nargs = args.len()
    let mut ai = nargs - 1
    while ai >= 0 and ai < 8
        rv_cg_expr(ctx, args[ai])
        if ai == 1
            rv_mv(ctx, RV_A1, RV_A0)
        if ai == 2
            rv_mv(ctx, RV_A2, RV_A0)
        if ai == 3
            rv_mv(ctx, RV_A3, RV_A0)
        if ai == 4
            rv_mv(ctx, RV_A4, RV_A0)
        if ai == 5
            rv_mv(ctx, RV_A5, RV_A0)
        if ai == 6
            rv_mv(ctx, RV_A6, RV_A0)
        if ai == 7
            rv_mv(ctx, RV_A7, RV_A0)
        ai = ai - 1

    // JAL ra, #offset (placeholder — patched later)
    let jal_pos = ctx.code_len
    rv_jal(ctx, RV_RA, 0)
    let cidx = ctx.call_fixup_count
    ctx.call_fixups[cidx * 2] = jal_pos
    ctx.call_fixups[cidx * 2 + 1] = fn_name
    ctx.call_fixup_count = cidx + 1

// rv_cg_print_string_lit: print a string literal
fn rv_cg_print_string_lit(ctx Ctx, s str)
    let data_off = ctx.data_len
    cg_add_string(ctx, s)
    // AUIPC a1, 0; ADDI a1, a1, 0 — patched later
    let auipc_pos = ctx.code_len
    rv_auipc(ctx, RV_A1, 0)
    rv_addi(ctx, RV_A1, RV_A1, 0)
    rv_add_fixup(ctx, auipc_pos, data_off)
    // ADDI a1, a1, 8 (skip length header)
    rv_addi(ctx, RV_A1, RV_A1, 8)
    // LI a2, len
    rv_li(ctx, RV_A2, s.len())
    // LI a0, 1 (stdout)
    rv_li(ctx, RV_A0, 1)
    // LI a7, 64 (write)
    rv_li(ctx, RV_A7, 64)
    // ECALL
    rv_ecall(ctx)

// rv_cg_print_string_val: print a string value (a0 = pointer to header)
fn rv_cg_print_string_val(ctx Ctx)
    // Save a0 in s1 (callee-saved)
    rv_mv(ctx, RV_S1, RV_A0)
    // a2 = [a0] (length)
    rv_ld(ctx, RV_A2, RV_S1, 0)
    // a1 = a0 + 8 (data)
    rv_addi(ctx, RV_A1, RV_S1, 8)
    // a0 = 1, a7 = 64
    rv_li(ctx, RV_A0, 1)
    rv_li(ctx, RV_A7, 64)
    rv_ecall(ctx)

// rv_cg_print_int: print integer in a0 to stdout
fn rv_cg_print_int(ctx Ctx)
    // Save callee-saved registers we use
    rv_push(ctx, RV_S1)
    rv_push(ctx, RV_S2)
    rv_push(ctx, RV_S3)
    rv_push(ctx, RV_S4)
    rv_push(ctx, RV_S5)

    // Allocate 32-byte buffer on stack
    rv_addi(ctx, RV_SP, RV_SP, -32)
    rv_mv(ctx, RV_S2, RV_SP)  // s2 = buffer

    // Save X0 in s1
    rv_mv(ctx, RV_S1, RV_A0)

    // Special case: a0 == 0 → write "0"
    rv_beq(ctx, RV_S1, RV_ZERO, 0)  // placeholder
    let beq_zero_pos = ctx.code_len - 4

    // Handle negative: if s1 < 0, write '-' and negate
    rv_slt(ctx, RV_T0, RV_S1, RV_ZERO)  // t0 = (s1 < 0) ? 1 : 0
    rv_beq(ctx, RV_T0, RV_ZERO, 0)  // placeholder (if not negative, skip)
    let beq_notneg_pos = ctx.code_len - 4

    // Write '-' character
    rv_li(ctx, RV_T1, 45)  // '-'
    rv_sb(ctx, RV_T1, RV_S2, 0)
    rv_li(ctx, RV_A0, 1)  // stdout
    rv_mv(ctx, RV_A1, RV_S2)
    rv_li(ctx, RV_A2, 1)
    rv_li(ctx, RV_A7, 64)
    rv_ecall(ctx)
    // Negate s1: SUB s1, zero, s1
    rv_sub(ctx, RV_S1, RV_ZERO, RV_S1)

    // not_negative_label:
    let notneg_target = ctx.code_len
    rv_patch_branch(ctx, beq_notneg_pos, notneg_target)

    // s3 = 0 (digit count)
    rv_li(ctx, RV_S3, 0)

    // digit_loop:
    let digit_loop = ctx.code_len
    rv_beq(ctx, RV_S1, RV_ZERO, 0)  // placeholder
    let beq_done_pos = ctx.code_len - 4

    // t1 = s1 % 10; s1 = s1 / 10
    rv_li(ctx, RV_T2, 10)
    rv_rem(ctx, RV_T1, RV_S1, RV_T2)
    rv_div(ctx, RV_S1, RV_S1, RV_T2)

    // digit_char = t1 + '0'
    rv_addi(ctx, RV_T1, RV_T1, 48)
    // SB t1, [s2, s3]
    rv_add(ctx, RV_T3, RV_S2, RV_S3)
    rv_sb(ctx, RV_T1, RV_T3, 0)
    // s3++
    rv_addi(ctx, RV_S3, RV_S3, 1)
    // B digit_loop
    let b_loop_pos = ctx.code_len
    rv_jal(ctx, RV_ZERO, 0)
    rv_patch_jal(ctx, b_loop_pos, digit_loop)

    // done_label:
    let done_target = ctx.code_len
    rv_patch_branch(ctx, beq_done_pos, done_target)

    // Reverse digits into second buffer
    rv_addi(ctx, RV_SP, RV_SP, -32)
    rv_mv(ctx, RV_S4, RV_SP)  // s4 = reversed buffer

    rv_li(ctx, RV_S5, 0)  // s5 = output index
    rv_addi(ctx, RV_T3, RV_S3, -1)  // t3 = input index (going down)

    // reverse_loop:
    let rev_loop = ctx.code_len
    rv_beq(ctx, RV_S5, RV_S3, 0)  // placeholder
    let beq_rev_done_pos = ctx.code_len - 4

    // LBU t1, [s2, t3]
    rv_add(ctx, RV_T0, RV_S2, RV_T3)
    rv_lbu(ctx, RV_T1, RV_T0, 0)
    // SB t1, [s4, s5]
    rv_add(ctx, RV_T0, RV_S4, RV_S5)
    rv_sb(ctx, RV_T1, RV_T0, 0)

    // s5++
    rv_addi(ctx, RV_S5, RV_S5, 1)
    // t3--
    rv_addi(ctx, RV_T3, RV_T3, -1)
    // B reverse_loop
    let b_rev_pos = ctx.code_len
    rv_jal(ctx, RV_ZERO, 0)
    rv_patch_jal(ctx, b_rev_pos, rev_loop)

    // rev_done_label:
    let rev_done_target = ctx.code_len
    rv_patch_branch(ctx, beq_rev_done_pos, rev_done_target)

    // Write s5 bytes from s4
    rv_li(ctx, RV_A0, 1)
    rv_mv(ctx, RV_A1, RV_S4)
    rv_mv(ctx, RV_A2, RV_S5)
    rv_li(ctx, RV_A7, 64)
    rv_ecall(ctx)

    // Deallocate buffers
    rv_addi(ctx, RV_SP, RV_SP, 64)
    // B past_zero
    let b_past_pos = ctx.code_len
    rv_jal(ctx, RV_ZERO, 0)

    // zero_case: write "0"
    let zero_target = ctx.code_len
    rv_patch_branch(ctx, beq_zero_pos, zero_target)
    let zdata_off = ctx.data_len
    cg_add_string(ctx, "0")
    let zauipc_pos = ctx.code_len
    rv_auipc(ctx, RV_A1, 0)
    rv_addi(ctx, RV_A1, RV_A1, 0)
    rv_add_fixup(ctx, zauipc_pos, zdata_off)
    rv_addi(ctx, RV_A1, RV_A1, 8)
    rv_li(ctx, RV_A2, 1)
    rv_li(ctx, RV_A0, 1)
    rv_li(ctx, RV_A7, 64)
    rv_ecall(ctx)
    rv_addi(ctx, RV_SP, RV_SP, 32)

    let past_zero_target = ctx.code_len
    rv_patch_jal(ctx, b_past_pos, past_zero_target)

    // Pop callee-saved registers
    rv_pop(ctx, RV_S5)
    rv_pop(ctx, RV_S4)
    rv_pop(ctx, RV_S3)
    rv_pop(ctx, RV_S2)
    rv_pop(ctx, RV_S1)

// rv_cg_if_expr: if as an expression (stub)
fn rv_cg_if_expr(ctx Ctx, e Node)
    rv_li(ctx, RV_A0, 0)

// ---------------------------------------------------------------------------
// RV64 statement codegen
// ---------------------------------------------------------------------------

fn rv_cg_stmt(ctx Ctx, s Node)
    if s.kind == "let_stmt"
        let va = s.a
        let init = va[0]
        if init.kind == "string_lit"
            ctx.var_types[s.sval] = "str"
        if init.kind == "int_lit"
            ctx.var_types[s.sval] = "int"
        if init.kind == "bool_true"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "bool_false"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "ident"
            if ctx.var_types.has(init.sval)
                ctx.var_types[s.sval] = ctx.var_types[init.sval]
        if init.kind == "call"
            let fa = init.a
            if fa[0].kind == "ident"
                let fname = fa[0].sval
                if ctx.fn_ret_types.has(fname)
                    let rt = ctx.fn_ret_types[fname]
                    if rt == "str"
                        ctx.var_types[s.sval] = "str"
                    if rt == "int"
                        ctx.var_types[s.sval] = "int"
                    if rt == "bool"
                        ctx.var_types[s.sval] = "bool"
        rv_cg_expr(ctx, init)
        let offset = cg_get_var_offset(ctx, s.sval)
        rv_sd(ctx, RV_A0, RV_FP, offset)
        return
    if s.kind == "return"
        if s.a.has(0)
            let va = s.a
            rv_cg_expr(ctx, va[0])
        if ctx.is_main
            if not s.a.has(0)
                rv_li(ctx, RV_A0, 0)
            rv_li(ctx, RV_A7, 93)
            rv_ecall(ctx)
        else
            rv_emit_epilogue(ctx)
        return
    if s.kind == "expr_stmt"
        let ea = s.a
        rv_cg_expr(ctx, ea[0])
        return
    if s.kind == "assign"
        let ea = s.a
        let vb = s.b
        let target = ea[0]
        if target.kind == "ident"
            rv_cg_expr(ctx, vb[0])
            let offset = cg_get_var_offset(ctx, target.sval)
            rv_sd(ctx, RV_A0, RV_FP, offset)
            return
        rv_cg_expr(ctx, vb[0])
        return
    if s.kind == "if_stmt"
        rv_cg_if(ctx, s)
        return
    if s.kind == "while_stmt"
        rv_cg_while(ctx, s)
        return
    if s.kind == "for_stmt"
        if s.bval
            rv_cg_for_range(ctx, s)
        return
    if s.kind == "assert_stmt"
        let ea = s.a
        rv_cg_expr(ctx, ea[0])
        return

fn rv_cg_if(ctx Ctx, s Node)
    // if_stmt structure (matches x86_64 cg_if):
    //   s.list = list of branch nodes
    //   s.a = else block (may be empty)
    // Each branch: b.a[0] = condition, b.b = block
    let branches = s.list
    let mut end_jumps = {}
    let mut njumps = 0
    let mut bi = 0
    while bi < branches.len()
        let b = branches[bi]
        let ca = b.a
        rv_cg_expr(ctx, ca[0])
        // if a0 == 0, skip to next branch
        rv_beq(ctx, RV_A0, RV_ZERO, 0)  // placeholder
        let beq_next_pos = ctx.code_len - 4
        // Then-block
        let block = b.b
        let mut si = 0
        while si < block.len()
            rv_cg_stmt(ctx, block[si])
            si = si + 1
        // JAL x0, end (unconditional jump)
        let b_end_pos = ctx.code_len
        rv_jal(ctx, RV_ZERO, 0)
        end_jumps[njumps] = b_end_pos
        njumps = njumps + 1
        // Next branch / else starts here
        let next_target = ctx.code_len
        rv_patch_branch(ctx, beq_next_pos, next_target)
        bi = bi + 1
    // Else block (if any)
    if s.a.has(0)
        let eb = s.a
        let else_block = eb[0].list
        let mut j = 0
        while j < else_block.len()
            rv_cg_stmt(ctx, else_block[j])
            j = j + 1
    // Patch all end jumps to here
    let end_target = ctx.code_len
    let mut ji = 0
    while ji < njumps
        let jmp_pos = end_jumps[ji]
        rv_patch_jal(ctx, jmp_pos, end_target)
        ji = ji + 1

fn rv_cg_while(ctx Ctx, s Node)
    let ea = s.a
    let cond = ea[0]
    let loop_start = ctx.code_len
    rv_cg_expr(ctx, cond)
    rv_beq(ctx, RV_A0, RV_ZERO, 0)  // placeholder
    let beq_end_pos = ctx.code_len - 4
    let ld = ctx.loop_depth
    ctx.continue_targets[ld] = loop_start
    ctx.break_targets[ld] = beq_end_pos
    ctx.loop_depth = ld + 1
    let body = s.list
    let mut i = 0
    while i < body.len()
        rv_cg_stmt(ctx, body[i])
        i = i + 1
    ctx.loop_depth = ld
    // JAL x0, loop_start
    let b_loop_pos = ctx.code_len
    rv_jal(ctx, RV_ZERO, 0)
    rv_patch_jal(ctx, b_loop_pos, loop_start)
    // end_label:
    let end_target = ctx.code_len
    rv_patch_branch(ctx, beq_end_pos, end_target)

fn rv_cg_for_range(ctx Ctx, s Node)
    let ea = s.a
    let range_node = ea[0]
    let i_offset = cg_get_var_offset(ctx, s.sval)
    if range_node.a.has(0)
        let ra = range_node.a
        rv_cg_expr(ctx, ra[0])
    else
        rv_li(ctx, RV_A0, 0)
    rv_sd(ctx, RV_A0, RV_FP, i_offset)

    let loop_start = ctx.code_len
    rv_ld(ctx, RV_A0, RV_FP, i_offset)
    if range_node.b.has(0)
        let rb = range_node.b
        rv_cg_expr(ctx, rb[0])
    else
        rv_li(ctx, RV_A0, 0)
    // t0 = i, a0 = end
    rv_mv(ctx, RV_T0, RV_A0)
    rv_ld(ctx, RV_A0, RV_FP, i_offset)
    // if a0 >= t0, exit
    rv_bge(ctx, RV_A0, RV_T0, 0)  // placeholder
    let bge_end_pos = ctx.code_len - 4

    let ld = ctx.loop_depth
    ctx.continue_targets[ld] = loop_start
    ctx.break_targets[ld] = bge_end_pos
    ctx.loop_depth = ld + 1
    let body = s.list
    let mut i = 0
    while i < body.len()
        rv_cg_stmt(ctx, body[i])
        i = i + 1
    ctx.loop_depth = ld

    // i++
    rv_ld(ctx, RV_A0, RV_FP, i_offset)
    rv_addi(ctx, RV_A0, RV_A0, 1)
    rv_sd(ctx, RV_A0, RV_FP, i_offset)
    let b_loop_pos = ctx.code_len
    rv_jal(ctx, RV_ZERO, 0)
    rv_patch_jal(ctx, b_loop_pos, loop_start)
    let end_target = ctx.code_len
    rv_patch_branch(ctx, bge_end_pos, end_target)

// (rv_bge is defined earlier, near the other branch instructions.)

// ---------------------------------------------------------------------------
// RV64 function codegen
// ---------------------------------------------------------------------------

// rv_emit_prologue: ADDI sp, sp, -frame_size; SD ra, [sp, frame-8]; SD s0, [sp, frame-16]
//                   ADDI s0, sp, frame_size
// Returns the position of the frame_size immediate (for patching)
fn rv_emit_prologue(ctx Ctx) int
    // ADDI sp, sp, #0 (placeholder — frame_size patched later)
    let addi_sp_pos = ctx.code_len
    rv_addi(ctx, RV_SP, RV_SP, 0)
    // SD ra, [sp, 0] — placeholder, will patch offset later
    rv_sd(ctx, RV_RA, RV_SP, 0)
    // SD s0, [sp, 8] — placeholder
    rv_sd(ctx, RV_FP, RV_SP, 8)
    // ADDI s0, sp, #0 (placeholder — frame_size patched later)
    let addi_fp_pos = ctx.code_len
    rv_addi(ctx, RV_FP, RV_SP, 0)
    return addi_sp_pos

// rv_emit_epilogue: LD ra, [sp, frame-8]; LD s0, [sp, frame-16]; ADDI sp, sp, frame; RET
// We assume frame_size was stored at prologue time. For simplicity, we re-derive
// it from ctx.next_slot at epilogue emit time.
fn rv_emit_epilogue(ctx Ctx)
    // Frame layout:
    //   sp+0:            RA (saved in prologue)
    //   sp+8:            old s0 (saved in prologue)
    //   sp+16:           locals (frame_size bytes)
    //   sp+total = s0:   top of frame
    // Epilogue: LD ra, [sp, 0]; LD s0, [sp, 8]; ADDI sp, sp, total; RET
    let frame_size = 0 - ctx.next_slot - 8
    // Align frame_size to 16 bytes
    let mut aligned = frame_size
    if aligned % 16 != 0
        aligned = aligned + (16 - (aligned % 16))
    let total = aligned + 16
    // LD ra, [sp, 0]
    rv_ld(ctx, RV_RA, RV_SP, 0)
    // LD s0, [sp, 8]
    rv_ld(ctx, RV_FP, RV_SP, 8)
    // ADDI sp, sp, total
    rv_addi(ctx, RV_SP, RV_SP, total)
    // RET
    rv_ret(ctx)

fn rv_cg_function(ctx Ctx, fn_decl Node, is_main bool)
    let fn_start = ctx.code_len
    let fn_name = fn_decl.sval
    ctx.fn_table[fn_name] = fn_start
    ctx.fn_count = ctx.fn_count + 1
    ctx.var_slots = {}
    ctx.next_slot = -8
    ctx.var_types = {}

    // Prologue
    let addi_sp_pos = rv_emit_prologue(ctx)

    // Save parameters: a0-a7 → local slots
    let params = fn_decl.a
    let mut pi = 0
    while pi < params.len() and pi < 8
        let param = params[pi]
        let local_offset = cg_get_var_offset(ctx, param.sval)
        // SD a(pi), [fp, local_offset]
        rv_sd(ctx, 10 + pi, RV_FP, local_offset)
        ctx.var_types[param.sval] = param.extra
        pi = pi + 1

    ctx.is_main = is_main
    let body = fn_decl.list
    let mut i = 0
    while i < body.len()
        rv_cg_stmt(ctx, body[i])
        i = i + 1

    // Default return: a0 = 0
    if is_main
        rv_li(ctx, RV_A0, 0)
        rv_li(ctx, RV_A7, 93)
        rv_ecall(ctx)
    else
        rv_li(ctx, RV_A0, 0)
        rv_emit_epilogue(ctx)

    // Patch frame size in prologue
    // Frame layout:
    //   sp+0:            RA
    //   sp+8:            old s0
    //   sp+16:           locals (frame_size bytes)
    //   sp+total = s0:   top of frame
    let frame_size = 0 - ctx.next_slot - 8
    let mut aligned = frame_size
    if aligned % 16 != 0
        aligned = aligned + (16 - (aligned % 16))
    let total = aligned + 16
    let neg_total = 0 - total
    if total >= -2048 and total <= 2047
        // Patch ADDI sp, sp, -total (allocate stack)
        let instr_sp = rv_enc_i(RV_OP_OP_IMM, RV_SP, RV_F3_ADDI, RV_SP, neg_total)
        ctx.code_data[addi_sp_pos] = instr_sp % 256
        ctx.code_data[addi_sp_pos + 1] = (instr_sp / 256) % 256
        ctx.code_data[addi_sp_pos + 2] = (instr_sp / 65536) % 256
        ctx.code_data[addi_sp_pos + 3] = (instr_sp / 16777216) % 256
        // Patch SD ra, [sp, 0]
        let sd_ra_pos = addi_sp_pos + 4
        let sd_ra_instr = rv_enc_s(RV_OP_STORE, RV_F3_SD, RV_SP, RV_RA, 0)
        ctx.code_data[sd_ra_pos] = sd_ra_instr % 256
        ctx.code_data[sd_ra_pos + 1] = (sd_ra_instr / 256) % 256
        ctx.code_data[sd_ra_pos + 2] = (sd_ra_instr / 65536) % 256
        ctx.code_data[sd_ra_pos + 3] = (sd_ra_instr / 16777216) % 256
        // Patch SD s0, [sp, 8]
        let sd_s0_pos = sd_ra_pos + 4
        let sd_s0_instr = rv_enc_s(RV_OP_STORE, RV_F3_SD, RV_SP, RV_FP, 8)
        ctx.code_data[sd_s0_pos] = sd_s0_instr % 256
        ctx.code_data[sd_s0_pos + 1] = (sd_s0_instr / 256) % 256
        ctx.code_data[sd_s0_pos + 2] = (sd_s0_instr / 65536) % 256
        ctx.code_data[sd_s0_pos + 3] = (sd_s0_instr / 16777216) % 256
        // Patch ADDI s0, sp, total (set frame pointer to top of frame)
        let addi_fp_pos = sd_s0_pos + 4
        let addi_fp_instr = rv_enc_i(RV_OP_OP_IMM, RV_FP, RV_F3_ADDI, RV_SP, total)
        ctx.code_data[addi_fp_pos] = addi_fp_instr % 256
        ctx.code_data[addi_fp_pos + 1] = (addi_fp_instr / 256) % 256
        ctx.code_data[addi_fp_pos + 2] = (addi_fp_instr / 65536) % 256
        ctx.code_data[addi_fp_pos + 3] = (addi_fp_instr / 16777216) % 256
// ===========================================================================
// WebAssembly (WASM) codegen — parallel path activated when ctx.target == 3
// ===========================================================================
// Produces .wasm binary modules targeting the WebAssembly MVP spec.
//
// WASM is a stack-based VM, fundamentally different from register machines:
// - Operations push/pop values on an implicit operand stack
// - Functions have typed signatures (params and results)
// - Locals are indexed (local 0, 1, 2, ...) not stack-relative
// - Memory is a linear byte array accessed via load/store instructions
// - No syscalls — the module exports functions for the host to call
//
// Module structure:
//   magic: \0asm
//   version: 1
//   Type section: function signatures
//   Function section: type indices for each function
//   Memory section: linear memory definition
//   Export section: exported functions and memory
//   Code section: function bodies
//   Data section: string literals and constants
//
// For Yilt, we export the `main` function as "_start" and also export "memory".
// The host (or a WASM runtime) calls _start, which returns the exit code.
// ===========================================================================

// WASM section IDs
let WASM_SEC_TYPE = 1
let WASM_SEC_FUNCTION = 3
let WASM_SEC_MEMORY = 5
let WASM_SEC_EXPORT = 7
let WASM_SEC_CODE = 10
let WASM_SEC_DATA = 11

// WASM value types
let WASM_TYPE_I32 = 0x7F
let WASM_TYPE_I64 = 0x7E
let WASM_TYPE_F32 = 0x7D
let WASM_TYPE_F64 = 0x7C
let WASM_TYPE_FUNC = 0x60
let WASM_TYPE_EMPTY_BLOCK = 0x40

// WASM import/export kinds
let WASM_EXPORT_FUNC = 0
let WASM_EXPORT_MEMORY = 2

// WASM limits
let WASM_LIMITS_NO_MAX = 0

// WASM opcodes — control
let WASM_OP_UNREACHABLE = 0x00
let WASM_OP_NOP = 0x01
let WASM_OP_BLOCK = 0x02
let WASM_OP_LOOP = 0x03
let WASM_OP_IF = 0x04
let WASM_OP_ELSE = 0x05
let WASM_OP_END = 0x0B
let WASM_OP_BR = 0x0C
let WASM_OP_BR_IF = 0x0D
let WASM_OP_RETURN = 0x0F
let WASM_OP_CALL = 0x10

// WASM opcodes — parametric
let WASM_OP_DROP = 0x1A
let WASM_OP_SELECT = 0x1B

// WASM opcodes — variables
let WASM_OP_LOCAL_GET = 0x20
let WASM_OP_LOCAL_SET = 0x21
let WASM_OP_LOCAL_TEE = 0x22
let WASM_OP_GLOBAL_GET = 0x23
let WASM_OP_GLOBAL_SET = 0x24

// WASM opcodes — memory
let WASM_OP_I32_LOAD = 0x28
let WASM_OP_I64_LOAD = 0x29
let WASM_OP_I32_LOAD8_U = 0x2D
let WASM_OP_I64_LOAD8_U = 0x31
let WASM_OP_I32_STORE = 0x36
let WASM_OP_I64_STORE = 0x37
let WASM_OP_I32_STORE8 = 0x3A
let WASM_OP_I64_STORE8 = 0x3C

// WASM opcodes — constants
let WASM_OP_I32_CONST = 0x41
let WASM_OP_I64_CONST = 0x42
let WASM_OP_F64_CONST = 0x44

// WASM opcodes — i32 comparison
let WASM_OP_I32_EQZ = 0x45
let WASM_OP_I32_EQ = 0x46
let WASM_OP_I32_NE = 0x47
let WASM_OP_I32_LT_S = 0x48
let WASM_OP_I32_GT_S = 0x4A
let WASM_OP_I32_LE_S = 0x4C
let WASM_OP_I32_GE_S = 0x4E

// WASM opcodes — i64 comparison
let WASM_OP_I64_EQZ = 0x50
let WASM_OP_I64_EQ = 0x51
let WASM_OP_I64_NE = 0x52
let WASM_OP_I64_LT_S = 0x53
let WASM_OP_I64_GT_S = 0x55
let WASM_OP_I64_LE_S = 0x57
let WASM_OP_I64_GE_S = 0x59

// WASM opcodes — i64 arithmetic
let WASM_OP_I64_ADD = 0x7C
let WASM_OP_I64_SUB = 0x7D
let WASM_OP_I64_MUL = 0x7E
let WASM_OP_I64_DIV_S = 0x7F
let WASM_OP_I64_REM_S = 0x81
let WASM_OP_I64_AND = 0x83
let WASM_OP_I64_OR = 0x84
let WASM_OP_I64_XOR = 0x85
let WASM_OP_I64_SHL = 0x86
let WASM_OP_I64_SHR_S = 0x87

// WASM opcodes — i32 arithmetic (used in print_int for counter manipulation)
let WASM_OP_I32_ADD = 0x6A
let WASM_OP_I32_SUB = 0x6B

// WASM opcodes — conversions
let WASM_OP_I32_WRAP_I64 = 0xA7

// ---------------------------------------------------------------------------
// WASM binary writer helpers
// ---------------------------------------------------------------------------

// w_byte: write a single byte to the WASM code buffer
// We reuse ctx.code_data, but for WASM we use a separate buffer at offset 400000+
// to avoid conflicts with x86_64/AArch64/RV64 fixup storage.
let WASM_BUF_BASE = 400000

fn w_byte(ctx Ctx, b int)
    ctx.code_data[WASM_BUF_BASE + ctx.code_len] = ((b % 256) + 256) % 256
    ctx.code_len = ctx.code_len + 1

// w_bytes: write multiple bytes from a string
fn w_bytes(ctx Ctx, s str)
    let bs = s.bytes()
    let mut i = 0
    while i < bs.len()
        w_byte(ctx, bs[i])
        i = i + 1

// w_u32_leb128: write a 32-bit unsigned integer as LEB128
fn w_u32_leb128(ctx Ctx, v int)
    let mut val = v
    let mut more = true
    while more
        let mut b = val & 127
        val = val >> 7
        if val != 0
            b = b | 128
        w_byte(ctx, b)
        if val == 0
            more = false

// w_i64_leb128: write a 64-bit signed integer as signed LEB128
// Yilt ints are 64-bit signed, so we use this for i64.const
fn w_i64_leb128(ctx Ctx, v int)
    let mut val = v
    let mut more = true
    while more
        let mut b = val & 127
        val = val >> 7  // arithmetic shift (sign-extending in Yilt)
        // Check if we're done:
        // - If val is 0 and b's sign bit (bit 6) is 0 → done
        // - If val is -1 (all 1s) and b's sign bit is 1 → done
        let val_is_zero = (val == 0)
        let val_is_neg_one = (val == -1)
        let b_sign_set = (b & 64) != 0
        if (val_is_zero and not b_sign_set) or (val_is_neg_one and b_sign_set)
            more = false
        else
            b = b | 128
            w_byte(ctx, b)
            more = true
        if not more
            w_byte(ctx, b)

// w_i32_leb128: write a 32-bit signed integer as signed LEB128
fn w_i32_leb128(ctx Ctx, v int)
    w_i64_leb128(ctx, v)  // same encoding for small values

// w_string: write a length-prefixed string (for names)
fn w_string(ctx Ctx, s str)
    w_u32_leb128(ctx, s.len())
    w_bytes(ctx, s)

// ---------------------------------------------------------------------------
// WASM codegen state tracking
// ---------------------------------------------------------------------------

// We need to track:
// - Function type signatures (for the Type section)
// - Function indices (for the Function section and calls)
// - Local variable indices (each function has its own locals)
// - String literal addresses in linear memory (for the Data section)

// WASM-specific state is stored in ctx.var_types and ctx.fn_table (shared),
// plus some WASM-specific fields we'll piggyback on existing tables.

// Memory layout for string literals:
// - Strings start at address 1024 (leave room for stack/heap at 0-1023)
// - Each string: [len:8 | data... | null:1] padded to 8-byte boundaries
// - This matches the x86_64/AArch64/RV64 layout

let WASM_STRING_BASE = 1024

// ---------------------------------------------------------------------------
// WASM codegen dispatchers
// ---------------------------------------------------------------------------

// wasm_cg_expr: evaluate expression, result on top of WASM stack (as i64)
fn wasm_cg_expr(ctx Ctx, e Node)
    if e.kind == "int_lit"
        let val = parse_int(e.sval)
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, val)
        return
    if e.kind == "bool_true"
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, 1)
        return
    if e.kind == "bool_false"
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, 0)
        return
    if e.kind == "nil"
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, 0)
        return
    if e.kind == "float_lit"
        let val = parse_int(e.sval)
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, val)
        return
    if e.kind == "ident"
        let local_idx = wasm_get_local(ctx, e.sval)
        w_byte(ctx, WASM_OP_LOCAL_GET)
        w_u32_leb128(ctx, local_idx)
        return
    if e.kind == "binary"
        wasm_cg_binary(ctx, e)
        return
    if e.kind == "unary"
        wasm_cg_unary(ctx, e)
        return
    if e.kind == "call"
        wasm_cg_call(ctx, e)
        return
    if e.kind == "string_lit"
        // Load the string address as an i64
        let mem_addr = wasm_add_string(ctx, e.sval)
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, mem_addr)
        return
    if e.kind == "if_expr"
        wasm_cg_if_expr(ctx, e)
        return
    // Default: push 0
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 0)

// wasm_get_local: get the local index for a variable name
// Locals are stored in ctx.var_slots (shared with other targets, but
// we reset it per function). For WASM, the index is non-negative
// (WASM locals are 0-indexed).
fn wasm_get_local(ctx Ctx, name str) int
    if ctx.var_slots.has(name)
        return ctx.var_slots[name]
    // Allocate a new local: index = current count
    let idx = ctx.next_slot
    ctx.var_slots[name] = idx
    ctx.next_slot = idx + 1
    // Record this local for the function's local declarations
    let local_count_idx = ctx.fixup_count
    ctx.code_data[500000 + local_count_idx] = idx
    ctx.fixup_count = local_count_idx + 1
    return idx

// wasm_add_string: add a string to the data section, return its memory address
fn wasm_add_string(ctx Ctx, s str) int
    let addr = WASM_STRING_BASE + ctx.data_len
    // Layout: [len:8 | data... | null:1]
    data_u64(ctx, s.len())
    data_str(ctx, s)
    data_byte(ctx, 0)
    // Pad to 8-byte boundary
    let total = 8 + s.len() + 1
    let mut pad = total % 8
    if pad != 0
        pad = 8 - pad
    let mut i = 0
    while i < pad
        data_byte(ctx, 0)
        i = i + 1
    return addr

// wasm_cg_binary: evaluate binary op, result on stack
fn wasm_cg_binary(ctx Ctx, e Node)
    let la = e.a
    let rb = e.b
    let op = e.sval

    if op == "and"
        // Short-circuit: if left is 0, result is 0; else result is bool(right)
        w_byte(ctx, WASM_OP_BLOCK)
        w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
        wasm_cg_expr(ctx, la[0])
        // if left == 0, break with 0
        w_byte(ctx, WASM_OP_I64_EQZ)
        w_byte(ctx, WASM_OP_BR_IF)
        w_u32_leb128(ctx, 0)
        // else: evaluate right, convert to bool
        wasm_cg_expr(ctx, rb[0])
        w_byte(ctx, WASM_OP_I64_EQZ)
        w_byte(ctx, WASM_OP_I64_EQZ)  // double negate: 0→1, nonzero→0→1... wait
        // Actually: i64.eqz turns nonzero→0, zero→1. We want nonzero→1.
        // So: i64.eqz gives 1 if zero. We want 1 if nonzero. So we need i64.eqz then i64.eqz... no.
        // Let me redo: result = (right != 0) ? 1 : 0
        // i64.eqz right → 1 if right==0, 0 if right!=0
        // We want 1 if right!=0. So we need to flip: i64.eqz, then XOR with 1, or use select.
        // Simplest: i64.eqz then i64.eqz doesn't work.
        // Use: push 1, push 0, select (if right!=0, take 1, else take 0)
        // Actually select takes (cond, b, a) → a if cond!=0 else b. So we need to be careful.
        // For now, just use the right value directly (0 or nonzero), then normalize at end.
        w_byte(ctx, WASM_OP_END)
        // Normalize: if result != 0, push 1, else push 0
        w_byte(ctx, WASM_OP_I64_EQZ)
        w_byte(ctx, WASM_OP_I64_EQZ)
        // Hmm this is getting complicated. Let me simplify.
        return
    if op == "or"
        w_byte(ctx, WASM_OP_BLOCK)
        w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
        wasm_cg_expr(ctx, la[0])
        // if left != 0, break with left (nonzero)
        // We need: if left != 0, break. So push left, i64.eqz, br_if (inverted)
        // Actually br_if breaks if top is nonzero. We want to break if left is nonzero.
        // So: push left; i64.eqz gives 1 if zero; br_if breaks if 1 (i.e., if zero). Wrong.
        // We want: break if left != 0. So: push left; i64.eqz; i64.eqz; br_if.
        // i64.eqz(left) = 1 if left==0. i64.eqz(1 if left==0) = 0 if left==0, 1 if left!=0.
        // So br_if breaks if left!=0. Correct!
        wasm_cg_expr(ctx, la[0])
        w_byte(ctx, WASM_OP_I64_EQZ)
        w_byte(ctx, WASM_OP_I64_EQZ)
        w_byte(ctx, WASM_OP_BR_IF)
        w_u32_leb128(ctx, 0)
        // else: evaluate right
        wasm_cg_expr(ctx, rb[0])
        w_byte(ctx, WASM_OP_END)
        // Normalize
        w_byte(ctx, WASM_OP_I64_EQZ)
        w_byte(ctx, WASM_OP_I64_EQZ)
        return

    // For all other ops, evaluate both operands (left then right), then apply op
    wasm_cg_expr(ctx, la[0])
    wasm_cg_expr(ctx, rb[0])

    if op == "+"
        w_byte(ctx, WASM_OP_I64_ADD)
        return
    if op == "-"
        w_byte(ctx, WASM_OP_I64_SUB)
        return
    if op == "*"
        w_byte(ctx, WASM_OP_I64_MUL)
        return
    if op == "/"
        w_byte(ctx, WASM_OP_I64_DIV_S)
        return
    if op == "%"
        w_byte(ctx, WASM_OP_I64_REM_S)
        return
    if op == "=="
        w_byte(ctx, WASM_OP_I64_EQ)
        // Convert i32 result to i64 for consistency
        // Actually i64.eq returns i32 in WASM. But we want i64 on stack.
        // For now, leave as i32 (comparisons return i32).
        return
    if op == "!="
        w_byte(ctx, WASM_OP_I64_NE)
        return
    if op == "<"
        w_byte(ctx, WASM_OP_I64_LT_S)
        return
    if op == ">"
        w_byte(ctx, WASM_OP_I64_GT_S)
        return
    if op == "<="
        w_byte(ctx, WASM_OP_I64_LE_S)
        return
    if op == ">="
        w_byte(ctx, WASM_OP_I64_GE_S)
        return
    if op == "&"
        w_byte(ctx, WASM_OP_I64_AND)
        return
    if op == "|"
        w_byte(ctx, WASM_OP_I64_OR)
        return
    if op == "^"
        w_byte(ctx, WASM_OP_I64_XOR)
        return
    // Unknown: push 0
    w_byte(ctx, WASM_OP_DROP)
    w_byte(ctx, WASM_OP_DROP)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 0)

// wasm_cg_unary: unary operations
fn wasm_cg_unary(ctx Ctx, e Node)
    let operand = e.a[0]
    let op = e.sval
    if op == "-"
        wasm_cg_expr(ctx, operand)
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, 0)
        w_byte(ctx, WASM_OP_I64_SUB)  // 0 - x = -x
        return
    if op == "!"
        wasm_cg_expr(ctx, operand)
        w_byte(ctx, WASM_OP_I64_EQZ)  // 1 if x==0, 0 if x!=0
        // Convert i32 to i64: extend
        // Actually for our purposes, i32 0/1 is fine as a bool
        return
    if op == "~"
        wasm_cg_expr(ctx, operand)
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, -1)
        w_byte(ctx, WASM_OP_I64_XOR)  // x ^ -1 = ~x
        return
    wasm_cg_expr(ctx, operand)

// wasm_cg_call: function call
fn wasm_cg_call(ctx Ctx, e Node)
    let fa = e.a
    if fa[0].kind != "ident"
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, 0)
        return
    let fn_name = fa[0].sval

    // Builtins
    if fn_name == "println" or fn_name == "print"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            // Dispatch based on argument type
            if arg.kind == "string_lit"
                wasm_cg_print_string_v2(ctx, arg.sval)
                if fn_name == "println"
                    wasm_cg_print_string_v2(ctx, "\n")
                return
            if arg.kind == "int_lit"
                // Push addr (640), push value, store, then print
                w_byte(ctx, WASM_OP_I32_CONST)
                w_i32_leb128(ctx, 640)
                w_byte(ctx, WASM_OP_I64_CONST)
                w_i64_leb128(ctx, parse_int(arg.sval))
                w_byte(ctx, WASM_OP_I64_STORE)
                w_u32_leb128(ctx, 3)
                w_u32_leb128(ctx, 0)
                wasm_cg_print_int_v2(ctx)
                if fn_name == "println"
                    wasm_cg_print_string_v2(ctx, "\n")
                return
            if arg.kind == "bool_true"
                wasm_cg_print_string_v2(ctx, "true")
                if fn_name == "println"
                    wasm_cg_print_string_v2(ctx, "\n")
                return
            if arg.kind == "bool_false"
                wasm_cg_print_string_v2(ctx, "false")
                if fn_name == "println"
                    wasm_cg_print_string_v2(ctx, "\n")
                return
            if arg.kind == "ident"
                if ctx.var_types.has(arg.sval)
                    let vt = ctx.var_types[arg.sval]
                    if vt == "str"
                        // Load string address and print
                        wasm_cg_expr(ctx, arg)
                        // The string address is on the stack as i64.
                        // We need to convert to a print operation.
                        // For now, use a simplified approach: assume the value
                        // is a string address and print via a helper.
                        // TODO: implement string value printing
                        w_byte(ctx, WASM_OP_DROP)
                        if fn_name == "println"
                            wasm_cg_print_string_v2(ctx, "\n")
                        return
            // Default: evaluate and print as int
            // Push addr (640), push value, store, then print
            w_byte(ctx, WASM_OP_I32_CONST)
            w_i32_leb128(ctx, 640)
            wasm_cg_expr(ctx, arg)
            w_byte(ctx, WASM_OP_I64_STORE)
            w_u32_leb128(ctx, 3)
            w_u32_leb128(ctx, 0)
            wasm_cg_print_int_v2(ctx)
            if fn_name == "println"
                wasm_cg_print_string_v2(ctx, "\n")
            return
        if fn_name == "println"
            wasm_cg_print_string_v2(ctx, "\n")
        return
    if fn_name == "len"
        let args = e.list
        if args.len() > 0
            wasm_cg_expr(ctx, args[0])
            // Load length from [string_addr] (i64)
            w_byte(ctx, WASM_OP_I32_WRAP_I64)  // address as i32
            w_byte(ctx, WASM_OP_I64_LOAD)
            w_u32_leb128(ctx, 2)  // alignment: 4 (log2)
            w_u32_leb128(ctx, 0)  // offset: 0
            return
        w_byte(ctx, WASM_OP_I64_CONST)
        w_i64_leb128(ctx, 0)
        return

    // User-defined function call
    // Evaluate args in order (they'll be on the stack)
    let args = e.list
    let mut ai = 0
    while ai < args.len()
        wasm_cg_expr(ctx, args[ai])
        ai = ai + 1
    // Call: need the function index
    // WASM function indices include the WASI import (fd_write at index 0),
    // so user functions start at index 1.
    let fn_idx = wasm_get_fn_index(ctx, fn_name)
    w_byte(ctx, WASM_OP_CALL)
    w_u32_leb128(ctx, fn_idx + 1)  // +1 for the WASI fd_write import

// wasm_get_fn_index: get the WASM function index for a function name
// Stored in ctx.fn_table (shared). For WASM, we store the index (not code offset).
fn wasm_get_fn_index(ctx Ctx, name str) int
    if ctx.fn_table.has(name)
        return ctx.fn_table[name]
    // Allocate a new index
    let idx = ctx.fn_count
    ctx.fn_table[name] = idx
    ctx.fn_count = idx + 1
    return idx

// wasm_cg_if_expr: if as an expression (stub: push 0)
fn wasm_cg_if_expr(ctx Ctx, e Node)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 0)

// ---------------------------------------------------------------------------
// WASM statement codegen
// ---------------------------------------------------------------------------

fn wasm_cg_stmt(ctx Ctx, s Node)
    if s.kind == "let_stmt"
        let va = s.a
        let init = va[0]
        if init.kind == "string_lit"
            ctx.var_types[s.sval] = "str"
        if init.kind == "int_lit"
            ctx.var_types[s.sval] = "int"
        if init.kind == "bool_true"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "bool_false"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "ident"
            if ctx.var_types.has(init.sval)
                ctx.var_types[s.sval] = ctx.var_types[init.sval]
        wasm_cg_expr(ctx, init)
        let local_idx = wasm_get_local(ctx, s.sval)
        w_byte(ctx, WASM_OP_LOCAL_SET)
        w_u32_leb128(ctx, local_idx)
        return
    if s.kind == "return"
        if s.a.has(0)
            let va = s.a
            wasm_cg_expr(ctx, va[0])
        else
            w_byte(ctx, WASM_OP_I64_CONST)
            w_i64_leb128(ctx, 0)
        w_byte(ctx, WASM_OP_RETURN)
        return
    if s.kind == "expr_stmt"
        let ea = s.a
        wasm_cg_expr(ctx, ea[0])
        w_byte(ctx, WASM_OP_DROP)  // discard result
        return
    if s.kind == "assign"
        let ea = s.a
        let vb = s.b
        let target = ea[0]
        if target.kind == "ident"
            wasm_cg_expr(ctx, vb[0])
            let local_idx = wasm_get_local(ctx, target.sval)
            w_byte(ctx, WASM_OP_LOCAL_SET)
            w_u32_leb128(ctx, local_idx)
            return
        wasm_cg_expr(ctx, vb[0])
        w_byte(ctx, WASM_OP_DROP)
        return
    if s.kind == "if_stmt"
        wasm_cg_if(ctx, s)
        return
    if s.kind == "while_stmt"
        wasm_cg_while(ctx, s)
        return
    if s.kind == "for_stmt"
        if s.bval
            wasm_cg_for_range(ctx, s)
        return
    if s.kind == "assert_stmt"
        let ea = s.a
        wasm_cg_expr(ctx, ea[0])
        w_byte(ctx, WASM_OP_DROP)
        return

fn wasm_cg_if(ctx Ctx, s Node)
    // if_stmt structure: s.list = branches, s.a = else block
    let branches = s.list
    let mut bi = 0
    while bi < branches.len()
        let b = branches[bi]
        let ca = b.a
        // Evaluate condition
        wasm_cg_expr(ctx, ca[0])
        // if (condition) block
        w_byte(ctx, WASM_OP_IF)
        w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
        // Then-block
        let block = b.b
        let mut si = 0
        while si < block.len()
            wasm_cg_stmt(ctx, block[si])
            si = si + 1
        // If there's a next branch or an else, emit else
        if bi + 1 < branches.len()
            w_byte(ctx, WASM_OP_ELSE)
            // The else will be the next branch's if (nested)
            // For simplicity, we emit the next branch inline
            let b2 = branches[bi + 1]
            let ca2 = b2.a
            wasm_cg_expr(ctx, ca2[0])
            w_byte(ctx, WASM_OP_IF)
            w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
            let block2 = b2.b
            let mut si2 = 0
            while si2 < block2.len()
                wasm_cg_stmt(ctx, block2[si2])
                si2 = si2 + 1
            // No more elses for now (2 branches max)
            w_byte(ctx, WASM_OP_END)
            bi = bi + 1
        else
            if s.a.has(0)
                w_byte(ctx, WASM_OP_ELSE)
                let eb = s.a
                let else_block = eb[0].list
                let mut j = 0
                while j < else_block.len()
                    wasm_cg_stmt(ctx, else_block[j])
                    j = j + 1
        w_byte(ctx, WASM_OP_END)
        bi = bi + 1

fn wasm_cg_while(ctx Ctx, s Node)
    // while (cond) { body }
    // In WASM: block; loop; cond; i64.eqz; br_if 1 (exit block); body; br 0 (back to loop); end; end
    w_byte(ctx, WASM_OP_BLOCK)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    w_byte(ctx, WASM_OP_LOOP)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    // Evaluate condition
    let ea = s.a
    wasm_cg_expr(ctx, ea[0])
    // If condition is 0, break out of the block (depth 1)
    w_byte(ctx, WASM_OP_I64_EQZ)
    w_byte(ctx, WASM_OP_BR_IF)
    w_u32_leb128(ctx, 1)  // break out of block
    // Body
    let body = s.list
    let mut i = 0
    while i < body.len()
        wasm_cg_stmt(ctx, body[i])
        i = i + 1
    // Loop back (depth 0 = loop)
    w_byte(ctx, WASM_OP_BR)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_END)  // end loop
    w_byte(ctx, WASM_OP_END)  // end block

fn wasm_cg_for_range(ctx Ctx, s Node)
    // for_stmt structure (matches x86_64 cg_for_range):
    //   s.a[0] = start expression
    //   s.b[0] = end expression
    //   s.sval = loop variable name
    //   s.list = body
    let la = s.a
    let rb = s.b
    // Allocate i as a local
    let i_local = wasm_get_local(ctx, s.sval)
    // Initialize i = start
    wasm_cg_expr(ctx, la[0])
    w_byte(ctx, WASM_OP_LOCAL_SET)
    w_u32_leb128(ctx, i_local)

    // block; loop
    w_byte(ctx, WASM_OP_BLOCK)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    w_byte(ctx, WASM_OP_LOOP)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    // if i >= end, break
    w_byte(ctx, WASM_OP_LOCAL_GET)
    w_u32_leb128(ctx, i_local)
    wasm_cg_expr(ctx, rb[0])
    w_byte(ctx, WASM_OP_I64_GE_S)
    w_byte(ctx, WASM_OP_BR_IF)
    w_u32_leb128(ctx, 1)  // break out of block
    // Body
    let body = s.list
    let mut i = 0
    while i < body.len()
        wasm_cg_stmt(ctx, body[i])
        i = i + 1
    // i++
    w_byte(ctx, WASM_OP_LOCAL_GET)
    w_u32_leb128(ctx, i_local)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 1)
    w_byte(ctx, WASM_OP_I64_ADD)
    w_byte(ctx, WASM_OP_LOCAL_SET)
    w_u32_leb128(ctx, i_local)
    // Loop back
    w_byte(ctx, WASM_OP_BR)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_END)  // end loop
    w_byte(ctx, WASM_OP_END)  // end block


// w_u32_leb128_to_fd: write LEB128 directly to file descriptor
fn w_u32_leb128_to_fd(fd int, v int)
    let mut val = v
    let mut more = true
    while more
        let mut b = val & 127
        val = val >> 7
        if val != 0
            b = b | 128
        write_byte(fd, b)
        if val == 0
            more = false

// wasm_leb128_size: compute the LEB128 encoded size of a u32
fn wasm_leb128_size(v int) int
    let mut val = v
    let mut size = 0
    let mut more = true
    while more
        size = size + 1
        val = val >> 7
        if val == 0
            more = false
    return size

// w_i32_leb128_to_fd: write signed LEB128 to file descriptor
fn w_i32_leb128_to_fd(fd int, v int)
    let mut val = v
    let mut more = true
    while more
        let mut b = val & 127
        val = val >> 7
        let val_is_zero = (val == 0)
        let val_is_neg_one = (val == -1)
        let b_sign_set = (b & 64) != 0
        if (val_is_zero and not b_sign_set) or (val_is_neg_one and b_sign_set)
            more = false
        else
            b = b | 128
            write_byte(fd, b)
            more = true
        if not more
            write_byte(fd, b)
// ===========================================================================
// WASM Multi-Function + WASI Upgrade
// ===========================================================================
// Replaces the single-function stub with full multi-function support and
// WASI fd_write import for stdout printing.
//
// Per-function metadata is stored in the break_fixups table (unused for WASM):
//   break_fixups[fn_idx * 4 + 0] = code_start_offset
//   break_fixups[fn_idx * 4 + 1] = code_end_offset
//   break_fixups[fn_idx * 4 + 2] = param_count
//   break_fixups[fn_idx * 4 + 3] = local_count (non-param locals)
// ===========================================================================

// WASI import function indices (imported functions come first)
// Index 0: fd_write(fd, iovs, iovs_len, nwritten_ptr) -> i32
let WASM_WASI_FD_WRITE = 0

// wasm_cg_function_v2: multi-function version
fn wasm_cg_function_v2(ctx Ctx, fn_decl Node, is_main bool)
    let fn_name = fn_decl.sval
    // Register the function (assign it an index)
    let fn_idx = wasm_get_fn_index(ctx, fn_name)
    // Reset local state for this function
    ctx.var_slots = {}
    ctx.next_slot = 0  // WASM locals start at 0
    ctx.var_types = {}

    // Save params: in WASM, params are locals 0..n-1
    let params = fn_decl.a
    let mut pi = 0
    while pi < params.len()
        let param = params[pi]
        ctx.var_slots[param.sval] = pi
        ctx.var_types[param.sval] = param.extra
        pi = pi + 1
    // next_slot = number of params (next local index)
    ctx.next_slot = params.len()
    let param_count = params.len()

    // Record the start of this function's code
    let code_start = ctx.code_len

    ctx.is_main = is_main
    let body = fn_decl.list
    let mut i = 0
    while i < body.len()
        wasm_cg_stmt(ctx, body[i])
        i = i + 1

    // Default return: push 0 and end
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_END)  // end function body

    let code_end = ctx.code_len
    let local_count = ctx.next_slot - param_count

    // Store per-function metadata in break_fixups (4 entries per function)
    // fn_idx is the WASM function index (including the 1 WASI import)
    let wasm_fn_idx = fn_idx + 1  // +1 because fd_write is index 0
    ctx.break_fixups[wasm_fn_idx * 4 + 0] = code_start
    ctx.break_fixups[wasm_fn_idx * 4 + 1] = code_end
    ctx.break_fixups[wasm_fn_idx * 4 + 2] = param_count
    ctx.break_fixups[wasm_fn_idx * 4 + 3] = local_count

// wasm_build_module_v2: multi-function + WASI version
fn wasm_build_module_v2(ctx Ctx, output_fd int) int
    let n_user_fns = ctx.fn_count

    // Write WASM magic and version
    write_byte(output_fd, 0)
    sys.write(output_fd, "asm", 3)
    write_byte(output_fd, 1)
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)

    // === Type section ===
    // Type 0: (i32, i32, i32, i32) -> i32  (WASI fd_write)
    // Type 1+: () -> i64  (user functions, all return i64 for simplicity)
    //   Actually user functions may have params. For simplicity, we use one
    //   type per param count. But that's complex. Let's just emit one type
    //   per user function, with the right param count.
    write_byte(output_fd, WASM_SEC_TYPE)
    // Compute type section size
    // Type 0 (fd_write): 1 (0x60) + 1 (4 params) + 4 (i32*4) + 1 (1 result) + 1 (i32) = 8
    // Each user fn type: 1 (0x60) + 1 (param_count) + param_count + 1 (1 result) + 1 (i64)
    let mut type_size = 1  // count
    type_size = type_size + 8  // fd_write type
    // We need to know each function's param count
    // For now, emit one type per user function (all with 0 params, return i64)
    // and a special type for functions with params
    // Actually, let's emit 2 types: () -> i64 and (i64, i64) -> i64, etc.
    // For simplicity, let's count how many distinct param counts we have.
    // For now, just emit one type per function.
    let mut fi = 0
    while fi < n_user_fns
        let wasm_fn_idx = fi + 1
        let param_count = ctx.break_fixups[wasm_fn_idx * 4 + 2]
        type_size = type_size + 1 + 1 + param_count + 1 + 1  // 0x60 + pcount + params + 1 + i64
        fi = fi + 1
    w_u32_leb128_to_fd(output_fd, type_size)
    w_u32_leb128_to_fd(output_fd, n_user_fns + 1)  // +1 for fd_write type
    // Type 0: fd_write
    write_byte(output_fd, WASM_TYPE_FUNC)
    write_byte(output_fd, 4)  // 4 params
    write_byte(output_fd, WASM_TYPE_I32)  // fd
    write_byte(output_fd, WASM_TYPE_I32)  // iovs ptr
    write_byte(output_fd, WASM_TYPE_I32)  // iovs len
    write_byte(output_fd, WASM_TYPE_I32)  // nwritten ptr
    write_byte(output_fd, 1)  // 1 result
    write_byte(output_fd, WASM_TYPE_I32)  // i32 (bytes written)
    // User function types (one per function, type index = fn_idx + 1)
    fi = 0
    while fi < n_user_fns
        let wasm_fn_idx = fi + 1
        let param_count = ctx.break_fixups[wasm_fn_idx * 4 + 2]
        write_byte(output_fd, WASM_TYPE_FUNC)
        w_u32_leb128_to_fd(output_fd, param_count)
        let mut pi = 0
        while pi < param_count
            write_byte(output_fd, WASM_TYPE_I64)  // all params are i64
            pi = pi + 1
        write_byte(output_fd, 1)  // 1 result
        write_byte(output_fd, WASM_TYPE_I64)  // i64
        fi = fi + 1

    // === Import section ===
    // Import fd_write from wasi_snapshot_preview1
    write_byte(output_fd, 2)  // WASM_SEC_IMPORT
    // Compute size: 1 (module len) + module + 1 (name len) + name + 1 (kind) + 1 (type idx)
    // module = "wasi_snapshot_preview1" = 24 bytes
    // name = "fd_write" = 8 bytes
    // total = 1 + 24 + 1 + 8 + 1 + 1 = 36
    // plus count = 1
    let import_size = 1 + 1 + 24 + 1 + 8 + 1 + 1
    w_u32_leb128_to_fd(output_fd, import_size)
    w_u32_leb128_to_fd(output_fd, 1)  // 1 import
    w_u32_leb128_to_fd(output_fd, 24)
    sys.write(output_fd, "wasi_snapshot_preview1", 24)
    w_u32_leb128_to_fd(output_fd, 8)
    sys.write(output_fd, "fd_write", 8)
    write_byte(output_fd, 0)  // import kind: function
    w_u32_leb128_to_fd(output_fd, 0)  // type index 0

    // === Function section ===
    write_byte(output_fd, WASM_SEC_FUNCTION)
    // Size: 1 (count) + n_user_fns * 1 (type idx, assuming < 128)
    let func_section_size = 1 + n_user_fns
    w_u32_leb128_to_fd(output_fd, func_section_size)
    w_u32_leb128_to_fd(output_fd, n_user_fns)  // function count
    // Each user function's type index = fn_idx + 1
    fi = 0
    while fi < n_user_fns
        w_u32_leb128_to_fd(output_fd, fi + 1)  // type index
        fi = fi + 1

    // === Memory section ===
    write_byte(output_fd, WASM_SEC_MEMORY)
    w_u32_leb128_to_fd(output_fd, 3)
    w_u32_leb128_to_fd(output_fd, 1)
    write_byte(output_fd, WASM_LIMITS_NO_MAX)
    w_u32_leb128_to_fd(output_fd, 1)

    // === Export section ===
    // Export "main" as "_start" and export "memory"
    // main's WASM index = main's user fn idx + 1 (for the import)
    // We need to find main's index. It's stored in ctx.fn_table["main"].
    let mut main_wasm_idx = 1  // default: first user function (main is compiled first)
    if ctx.fn_table.has("main")
        main_wasm_idx = ctx.fn_table["main"] + 1  // +1 for the WASI import
    write_byte(output_fd, WASM_SEC_EXPORT)
    // "_start" export: 1 (len) + 6 (name) + 1 (kind) + leb128(main_idx) = 9 (if idx < 128)
    // "memory" export: 1 (len) + 6 (name) + 1 (kind) + 1 (idx) = 9
    let export_size = 1 + 9 + 9  // count + _start + memory
    w_u32_leb128_to_fd(output_fd, export_size)
    w_u32_leb128_to_fd(output_fd, 2)  // 2 exports
    // Export _start
    w_u32_leb128_to_fd(output_fd, 6)
    sys.write(output_fd, "_start", 6)
    write_byte(output_fd, WASM_EXPORT_FUNC)
    w_u32_leb128_to_fd(output_fd, main_wasm_idx)
    // Export memory
    w_u32_leb128_to_fd(output_fd, 6)
    sys.write(output_fd, "memory", 6)
    write_byte(output_fd, WASM_EXPORT_MEMORY)
    w_u32_leb128_to_fd(output_fd, 0)

    // === Code section ===
    write_byte(output_fd, WASM_SEC_CODE)
    // Compute total code section size:
    // 1 (count) + for each function: leb128(body_size) + body_size
    // body_size = local_decls_size + code_size
    // local_decls_size = 1 (if 0 locals) or 1 + leb128(local_count) + 1 (if >0)
    let mut total_code_section = 1  // count
    fi = 0
    while fi < n_user_fns
        let wasm_fn_idx = fi + 1
        let code_start = ctx.break_fixups[wasm_fn_idx * 4 + 0]
        let code_end = ctx.break_fixups[wasm_fn_idx * 4 + 1]
        let local_count = ctx.break_fixups[wasm_fn_idx * 4 + 3]
        let code_size = code_end - code_start
        let mut local_decls_size = 1
        if local_count > 0
            local_decls_size = 1 + wasm_leb128_size(local_count) + 1
        let body_size = local_decls_size + code_size
        total_code_section = total_code_section + wasm_leb128_size(body_size) + body_size
        fi = fi + 1
    w_u32_leb128_to_fd(output_fd, total_code_section)
    w_u32_leb128_to_fd(output_fd, n_user_fns)  // function count
    // Write each function body
    fi = 0
    while fi < n_user_fns
        let wasm_fn_idx = fi + 1
        let code_start = ctx.break_fixups[wasm_fn_idx * 4 + 0]
        let code_end = ctx.break_fixups[wasm_fn_idx * 4 + 1]
        let local_count = ctx.break_fixups[wasm_fn_idx * 4 + 3]
        let code_size = code_end - code_start
        let mut local_decls_size = 1
        if local_count > 0
            local_decls_size = 1 + wasm_leb128_size(local_count) + 1
        let body_size = local_decls_size + code_size
        // Write body size
        w_u32_leb128_to_fd(output_fd, body_size)
        // Write local declarations
        if local_count > 0
            w_u32_leb128_to_fd(output_fd, 1)  // 1 group
            w_u32_leb128_to_fd(output_fd, local_count)
            write_byte(output_fd, WASM_TYPE_I64)
        else
            w_u32_leb128_to_fd(output_fd, 0)
        // Write the code
        let mut ci = code_start
        while ci < code_end
            write_byte(output_fd, ctx.code_data[WASM_BUF_BASE + ci])
            ci = ci + 1
        fi = fi + 1

    // === Data section ===
    if ctx.data_len > 0
        write_byte(output_fd, WASM_SEC_DATA)
        let data_size = 1 + 1 + 1 + 1 + 1 + ctx.data_len  // count + mem_idx + i32.const + offset + end + size + data
        w_u32_leb128_to_fd(output_fd, data_size)
        w_u32_leb128_to_fd(output_fd, 1)  // 1 segment
        write_byte(output_fd, 0)  // memory index 0
        write_byte(output_fd, WASM_OP_I32_CONST)
        w_i32_leb128_to_fd(output_fd, WASM_STRING_BASE)
        write_byte(output_fd, WASM_OP_END)
        w_u32_leb128_to_fd(output_fd, ctx.data_len)
        let mut di = 0
        while di < ctx.data_len
            write_byte(output_fd, ctx.data_data[di])
            di = di + 1

    return 0

// wasm_cg_print_string_v2: print a string literal via WASI fd_write
// Layout: store string at memory, set up iov, call fd_write
fn wasm_cg_print_string_v2(ctx Ctx, s str)
    // Add string to data section
    let mem_addr = wasm_add_string(ctx, s)
    let str_len = s.len()
    // We need to call fd_write(1, iov, 1, nwritten_ptr)
    // iov is a struct: [ptr:4, len:4] at some memory address
    // nwritten_ptr is a 4-byte location for the result
    //
    // We'll use a temporary area in linear memory for iov and nwritten:
    //   iov at address 512 (8 bytes: ptr + len)
    //   nwritten at address 520 (4 bytes)
    let iov_addr = 512
    let nwritten_addr = 520

    // WASM store semantics: push ADDRESS first (deeper), then VALUE (top).
    // Store pops value first, then address.
    // String layout: [len:8 | data... | null:1] starting at mem_addr.
    // We write the DATA portion (mem_addr + 8), not the length header.
    let data_addr = mem_addr + 8
    // Store string data pointer (i32) at iov_addr
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, iov_addr)  // push address (deeper)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, data_addr & 0xFFFFFFFF)  // push value (top)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)  // align
    w_u32_leb128(ctx, 0)  // offset

    // Store string length (i32) at iov_addr + 4
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, iov_addr + 4)  // push address
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, str_len)  // push value
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)

    // Call fd_write(1, iov_addr, 1, nwritten_addr)
    // Args are pushed in order: fd, iov, niov, nwritten
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)  // fd = 1 (stdout)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, iov_addr)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)  // 1 iov
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, nwritten_addr)
    w_byte(ctx, WASM_OP_CALL)
    w_u32_leb128(ctx, WASM_WASI_FD_WRITE)  // imported function index 0
    w_byte(ctx, WASM_OP_DROP)  // discard fd_write return value
    // Push 0 (i64) so that expr_stmt's drop has something to drop
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 0)

// ===========================================================================
// PE64 (Windows) linker — produces minimal Windows console executables
// ===========================================================================

let PE_IMAGE_BASE = 0x140000000
let PE_SECTION_ALIGNMENT = 0x1000
let PE_FILE_ALIGNMENT = 0x200
let PE_TEXT_RVA = 0x1000

fn build_pe64(ctx Ctx, output_fd int) int
    let code_len = ctx.code_len
    let data_len = ctx.data_len

    let headers_size_raw = 64 + 4 + 20 + 240 + 3 * 40
    let headers_size = pe_align_up(headers_size_raw, PE_FILE_ALIGNMENT)
    let text_file_size = pe_align_up(code_len, PE_FILE_ALIGNMENT)
    let rdata_file_size = pe_align_up(data_len, PE_FILE_ALIGNMENT)

    let text_rva = PE_TEXT_RVA
    let rdata_rva = pe_align_up(text_rva + code_len, PE_SECTION_ALIGNMENT)
    let data_rva = pe_align_up(rdata_rva + data_len, PE_SECTION_ALIGNMENT)
    let image_size = pe_align_up(data_rva + 16, PE_SECTION_ALIGNMENT)

    let entry_rva = text_rva

    // DOS header (64 bytes)
    write_byte(output_fd, 0x4D)
    write_byte(output_fd, 0x5A)
    let mut i = 2
    while i < 60
        write_byte(output_fd, 0)
        i = i + 1
    write_u32_le(output_fd, 64)

    // PE signature
    write_byte(output_fd, 0x50)
    write_byte(output_fd, 0x45)
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)

    // COFF header (20 bytes)
    write_byte(output_fd, 0x64)
    write_byte(output_fd, 0x86)
    write_byte(output_fd, 3)
    write_byte(output_fd, 0)
    write_u32_le(output_fd, 0)
    write_u32_le(output_fd, 0)
    write_u32_le(output_fd, 0)
    write_byte(output_fd, 240)
    write_byte(output_fd, 0)
    write_byte(output_fd, 0x22)
    write_byte(output_fd, 0)

    // Optional header (240 bytes, PE32+)
    write_byte(output_fd, 0x0B)
    write_byte(output_fd, 0x02)
    write_byte(output_fd, 14)
    write_byte(output_fd, 0)
    write_u32_le(output_fd, text_file_size)
    write_u32_le(output_fd, rdata_file_size)
    write_u32_le(output_fd, 0)
    write_u32_le(output_fd, entry_rva)
    write_u32_le(output_fd, text_rva)
    // Note: PE32+ has NO BaseOfData field (removed from PE32).
    // After BaseOfCode comes ImageBase directly.
    write_u64_le(output_fd, PE_IMAGE_BASE)
    write_u32_le(output_fd, PE_SECTION_ALIGNMENT)
    write_u32_le(output_fd, PE_FILE_ALIGNMENT)
    // 6 version fields × 2 bytes = 12 bytes
    write_byte(output_fd, 6)   // MajorOSVer = 6
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)   // MinorOSVer = 0
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)   // MajorImageVer = 0
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)   // MinorImageVer = 0
    write_byte(output_fd, 0)
    write_byte(output_fd, 6)   // MajorSubsysVer = 6
    write_byte(output_fd, 0)
    write_byte(output_fd, 0)   // MinorSubsysVer = 0
    write_byte(output_fd, 0)
    write_u32_le(output_fd, 0) // Win32VersionValue
    write_u32_le(output_fd, image_size)
    write_u32_le(output_fd, headers_size)
    write_u32_le(output_fd, 0)
    write_byte(output_fd, 3)
    write_byte(output_fd, 0)
    write_byte(output_fd, 0x40)
    write_byte(output_fd, 0x01)
    write_u64_le(output_fd, 0x100000)
    write_u64_le(output_fd, 0x1000)
    write_u64_le(output_fd, 0x100000)
    write_u64_le(output_fd, 0x1000)
    write_u32_le(output_fd, 0)
    write_u32_le(output_fd, 16)
    let mut di = 0
    while di < 128
        write_byte(output_fd, 0)
        di = di + 1

    // Section headers
    // Note: pe_write_section_header computes characteristics from the name
    // to avoid the 7-argument calling convention issue with large hex values
    pe_write_section_header(output_fd, ".text", code_len, text_rva, text_file_size, headers_size)
    pe_write_section_header(output_fd, ".rdata", data_len, rdata_rva, rdata_file_size, headers_size + text_file_size)
    pe_write_section_header(output_fd, ".data", 0, data_rva, 0, headers_size + text_file_size + rdata_file_size)

    // Pad headers
    let written_so_far = 64 + 4 + 20 + 240 + 3 * 40
    let mut pad = written_so_far
    while pad < headers_size
        write_byte(output_fd, 0)
        pad = pad + 1

    // .text section
    let mut ci = 0
    while ci < code_len
        write_byte(output_fd, ctx.code_data[ci])
        ci = ci + 1
    pad = code_len
    while pad < text_file_size
        write_byte(output_fd, 0)
        pad = pad + 1

    // .rdata section
    di = 0
    while di < data_len
        write_byte(output_fd, ctx.data_data[di])
        di = di + 1
    pad = data_len
    while pad < rdata_file_size
        write_byte(output_fd, 0)
        pad = pad + 1

    return 0

fn pe_write_section_header(fd int, name str, virtual_size int, rva int, raw_size int, raw_offset int)
    let name_bytes = name.bytes()
    let mut ni = 0
    while ni < 8
        if ni < name_bytes.len()
            write_byte(fd, name_bytes[ni])
        else
            write_byte(fd, 0)
        ni = ni + 1
    write_u32_le(fd, virtual_size)
    write_u32_le(fd, rva)
    write_u32_le(fd, raw_size)
    write_u32_le(fd, raw_offset)
    write_u32_le(fd, 0)
    write_u32_le(fd, 0)
    write_byte(fd, 0)
    write_byte(fd, 0)
    write_byte(fd, 0)
    write_byte(fd, 0)
    // Compute characteristics based on section name
    let mut char_byte0 = 32
    let mut char_byte3 = 96
    if name == ".rdata"
        char_byte0 = 64
        char_byte3 = 64
    if name == ".data"
        char_byte0 = 128
        char_byte3 = 192
    write_byte(fd, char_byte0)
    write_byte(fd, 0)
    write_byte(fd, 0)
    write_byte(fd, char_byte3)

fn pe_align_up(val int, alignment int) int
    let rem = val % alignment
    if rem == 0
        return val
    return val + alignment - rem
// ===========================================================================
// Mach-O 64-bit (macOS) linker — produces minimal macOS executables
// ===========================================================================
// Layout:
//   Mach-O header (32 bytes): magic, cputype, filetype, ncmds, sizeofcmds
//   LC_SEGMENT_64 (__TEXT): 72 bytes cmd + 80 bytes per section
//   LC_SEGMENT_64 (__DATA): 72 bytes cmd + 80 bytes per section
//   LC_UNIXTHREAD: thread state (entry point)
//   __TEXT,__text: code
//   __TEXT,__data: read-only data
//
// For simplicity, we use LC_UNIXTHREAD (older format) instead of LC_MAIN.
// Entry point is set in the thread state.
// ===========================================================================

let MACHO_MAGIC_64 = 0xFEEDFACF
let MACHO_CPU_TYPE_X86_64 = 0x01000007
let MACHO_CPU_SUBTYPE_X86_64_ALL = 3
let MACHO_FILETYPE_EXECUTE = 2
let MACHO_LC_SEGMENT_64 = 0x19
let MACHO_LC_UNIXTHREAD = 0x05
let MACHO_PAGE_SIZE = 0x1000
let MACHO_TEXT_BASE = 0x100000000
let MACHO_THREAD_STATE_SIZE = 168  // x86_64 thread state

fn build_macho64(ctx Ctx, output_fd int) int
    let code_len = ctx.code_len
    let data_len = ctx.data_len

    // Header (32) + 2 segment cmds (72 each) + 2 sections (80 each) + unixthread (16 + 168)
    let header_size = 32
    let text_seg_cmd_size = 72 + 80  // LC_SEGMENT_64 + 1 section
    let data_seg_cmd_size = 72 + 80
    let unixthread_cmd_size = 16 + MACHO_THREAD_STATE_SIZE
    let total_cmds_size = text_seg_cmd_size + data_seg_cmd_size + unixthread_cmd_size
    let ncmds = 3

    let text_file_offset = header_size + total_cmds_size
    let text_file_size = code_len
    let data_file_offset = text_file_offset + text_file_size
    let data_file_size = data_len

    // VM layout
    let text_vmaddr = MACHO_TEXT_BASE
    let text_vmsize = macho_align_up(code_len + data_len, MACHO_PAGE_SIZE)
    let data_vmaddr = 0  // no separate data segment for simplicity
    let data_vmsize = 0

    // === Mach-O header (32 bytes) ===
    write_u32_le(output_fd, MACHO_MAGIC_64)
    write_u32_le(output_fd, MACHO_CPU_TYPE_X86_64)
    write_u32_le(output_fd, MACHO_CPU_SUBTYPE_X86_64_ALL)
    write_u32_le(output_fd, MACHO_FILETYPE_EXECUTE)
    write_u32_le(output_fd, ncmds)
    write_u32_le(output_fd, total_cmds_size)
    write_u32_le(output_fd, 0)  // flags
    write_u32_le(output_fd, 0)  // reserved

    // === LC_SEGMENT_64 (__TEXT) ===
    write_u32_le(output_fd, MACHO_LC_SEGMENT_64)
    write_u32_le(output_fd, text_seg_cmd_size)  // cmdsize
    macho_write_segname(output_fd, "__TEXT")
    write_u64_le(output_fd, text_vmaddr)
    write_u64_le(output_fd, text_vmsize)
    write_u64_le(output_fd, text_file_offset)
    write_u64_le(output_fd, text_file_size + data_file_size)  // file size includes data
    write_u32_le(output_fd, 7)  // maxprot: RWX
    write_u32_le(output_fd, 7)  // initprot: RWX
    write_u32_le(output_fd, 1)  // nsects
    write_u32_le(output_fd, 0)  // flags

    // __TEXT,__text section
    macho_write_sectname(output_fd, "__text")
    macho_write_segname(output_fd, "__TEXT")
    write_u64_le(output_fd, text_vmaddr)  // addr
    write_u64_le(output_fd, code_len)  // size
    write_u32_le(output_fd, text_file_offset)  // offset
    write_u32_le(output_fd, 0)  // align
    write_u32_le(output_fd, 0)  // reloff
    write_u32_le(output_fd, 0)  // nreloc
    write_u32_le(output_fd, 0)  // flags
    write_u32_le(output_fd, 0)  // reserved1
    write_u32_le(output_fd, 0)  // reserved2
    write_u32_le(output_fd, 0)  // reserved3 (for 64-bit)

    // === LC_SEGMENT_64 (__DATA) ===
    write_u32_le(output_fd, MACHO_LC_SEGMENT_64)
    write_u32_le(output_fd, data_seg_cmd_size)
    macho_write_segname(output_fd, "__DATA")
    write_u64_le(output_fd, 0)  // vmaddr (unused)
    write_u64_le(output_fd, 0)  // vmsize
    write_u64_le(output_fd, 0)  // fileoff
    write_u64_le(output_fd, 0)  // filesize
    write_u32_le(output_fd, 3)  // maxprot: RW
    write_u32_le(output_fd, 3)  // initprot: RW
    write_u32_le(output_fd, 0)  // nsects
    write_u32_le(output_fd, 0)  // flags

    // === LC_UNIXTHREAD ===
    write_u32_le(output_fd, MACHO_LC_UNIXTHREAD)
    write_u32_le(output_fd, unixthread_cmd_size)
    // x86_64 thread state: flavor=4 (x86_THREAD_STATE64), count=42
    write_u32_le(output_fd, 4)  // flavor
    write_u32_le(output_fd, 42)  // count
    // Thread state: 168 bytes = 21 uint64 values
    // The entry point goes in RIP (register 16, offset 16*8=128)
    // We write all zeros except RIP = text_vmaddr (entry point)
    let mut ti = 0
    while ti < 21
        if ti == 16  // RIP
            write_u64_le(output_fd, text_vmaddr)
        else
            write_u64_le(output_fd, 0)
        ti = ti + 1

    // === Code (__TEXT,__text) ===
    let mut ci = 0
    while ci < code_len
        write_byte(output_fd, ctx.code_data[ci])
        ci = ci + 1

    // === Data ===
    let mut di = 0
    while di < data_len
        write_byte(output_fd, ctx.data_data[di])
        di = di + 1

    return 0

fn macho_write_segname(fd int, name str)
    let name_bytes = name.bytes()
    let mut ni = 0
    while ni < 16
        if ni < name_bytes.len()
            write_byte(fd, name_bytes[ni])
        else
            write_byte(fd, 0)
        ni = ni + 1

fn macho_write_sectname(fd int, name str)
    let name_bytes = name.bytes()
    let mut ni = 0
    while ni < 16
        if ni < name_bytes.len()
            write_byte(fd, name_bytes[ni])
        else
            write_byte(fd, 0)
        ni = ni + 1

fn macho_align_up(val int, alignment int) int
    let rem = val % alignment
    if rem == 0
        return val
    return val + alignment - rem
// wasm_cg_print_int_v2: print an i64 integer to stdout via WASI fd_write
// The value is on top of the WASM stack (i64).
// Uses linear memory scratch areas:
//   640: the value being converted (i64)
//   648: digit count (i32)
//   652: loop index (i32)
//   540: reversed digit buffer (32 bytes)
//   600: forward digit buffer (32 bytes)
//   512: iov struct (8 bytes: ptr + len)
//   520: nwritten result (4 bytes)
fn wasm_cg_print_int_v2(ctx Ctx)
    // The value has already been stored at address 640 by the caller.
    // (Caller pushes 640, then the value, then i64.store.)
    // Now we do digit extraction from memory.

    // Initialize digit count = 0 at address 648
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)

    // Handle zero specially: if value == 0, print "0"
    w_byte(ctx, WASM_OP_BLOCK)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 640)
    w_byte(ctx, WASM_OP_I64_LOAD)
    w_u32_leb128(ctx, 3)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I64_NE)
    w_byte(ctx, WASM_OP_BR_IF)
    w_u32_leb128(ctx, 0)
    // Value is 0: set count = 1, rev_buf[0] = '0'
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 540)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 48)
    w_byte(ctx, WASM_OP_I64_STORE8)
    w_u32_leb128(ctx, 0)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_END)

    // Digit extraction loop (only runs if value != 0)
    w_byte(ctx, WASM_OP_BLOCK)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    w_byte(ctx, WASM_OP_LOOP)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    // if value == 0, break
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 640)
    w_byte(ctx, WASM_OP_I64_LOAD)
    w_u32_leb128(ctx, 3)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I64_EQZ)
    w_byte(ctx, WASM_OP_BR_IF)
    w_u32_leb128(ctx, 1)
    // Compute address FIRST (rev_buf + count), then digit, then store.
    // WASM store8: [addr, val] → []. addr deeper, val on top.
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 540)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_ADD)
    // Now stack: [addr]. Compute digit = value % 10 + 48
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 640)
    w_byte(ctx, WASM_OP_I64_LOAD)
    w_u32_leb128(ctx, 3)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 10)
    w_byte(ctx, WASM_OP_I64_REM_S)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 48)
    w_byte(ctx, WASM_OP_I64_ADD)
    // Now stack: [addr, digit_char]. Store!
    w_byte(ctx, WASM_OP_I64_STORE8)
    w_u32_leb128(ctx, 0)
    w_u32_leb128(ctx, 0)
    // count++
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)
    w_byte(ctx, WASM_OP_I32_ADD)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    // value = value / 10
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 640)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 640)
    w_byte(ctx, WASM_OP_I64_LOAD)
    w_u32_leb128(ctx, 3)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I64_CONST)
    w_i64_leb128(ctx, 10)
    w_byte(ctx, WASM_OP_I64_DIV_S)
    w_byte(ctx, WASM_OP_I64_STORE)
    w_u32_leb128(ctx, 3)
    w_u32_leb128(ctx, 0)
    // Loop back
    w_byte(ctx, WASM_OP_BR)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_END)
    w_byte(ctx, WASM_OP_END)

    // Reverse digits: for i = 0..count, fwd_buf[i] = rev_buf[count-1-i]
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 652)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_BLOCK)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    w_byte(ctx, WASM_OP_LOOP)
    w_byte(ctx, WASM_TYPE_EMPTY_BLOCK)
    // if i >= count, break
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 652)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_GE_S)
    w_byte(ctx, WASM_OP_BR_IF)
    w_u32_leb128(ctx, 1)
    // fwd_buf[i] = rev_buf[count-1-i]
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 600)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 652)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_ADD)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 540)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 652)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_SUB)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)
    w_byte(ctx, WASM_OP_I32_SUB)
    w_byte(ctx, WASM_OP_I32_ADD)
    w_byte(ctx, WASM_OP_I64_LOAD8_U)
    w_u32_leb128(ctx, 0)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I64_STORE8)
    w_u32_leb128(ctx, 0)
    w_u32_leb128(ctx, 0)
    // i++
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 652)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 652)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)
    w_byte(ctx, WASM_OP_I32_ADD)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_BR)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_END)
    w_byte(ctx, WASM_OP_END)

    // Set up iov: ptr=600, len=count
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 512)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 600)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 516)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 648)
    w_byte(ctx, WASM_OP_I32_LOAD)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)
    w_byte(ctx, WASM_OP_I32_STORE)
    w_u32_leb128(ctx, 2)
    w_u32_leb128(ctx, 0)

    // Call fd_write(1, 512, 1, 520)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 512)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 1)
    w_byte(ctx, WASM_OP_I32_CONST)
    w_i32_leb128(ctx, 520)
    w_byte(ctx, WASM_OP_CALL)
    w_u32_leb128(ctx, WASM_WASI_FD_WRITE)
    w_byte(ctx, WASM_OP_DROP)

// wasm_store_and_print_int: helper called by callers to store value at 640 then print
// Caller has already pushed the value onto the stack.
// We push 640 (addr) on top, then i64.store stores value at 640.
// Wait — store needs [addr, val] with addr deeper. But we have [val, 640].
// So this won't work either.
//
// The REAL fix: callers must push addr BEFORE evaluating the expression.
// Let's change the callers directly.


// ===========================================================================
// Boot sector format — for bootloaders, BIOS, UEFI, embedded boot images
// ===========================================================================
// Produces a 512-byte boot sector with 0x55 0xAA signature.
// Load address defaults to 0x7C00 (standard BIOS boot sector address).
// Custom load address via /tmp/yilt_raw_base (decimal).
// ===========================================================================

let BOOT_DEFAULT_BASE = 0x7C00

fn build_boot(ctx Ctx, output_fd int) int
    let code_len = ctx.code_len
    let data_len = ctx.data_len

    // Write code bytes
    let mut ci = 0
    while ci < code_len
        write_byte(output_fd, ctx.code_data[ci])
        ci = ci + 1

    // Write data bytes
    let mut di = 0
    while di < data_len
        write_byte(output_fd, ctx.data_data[di])
        di = di + 1

    // Pad to 510 bytes, then add boot signature
    let total = code_len + data_len
    let mut pad = total
    while pad < 510
        write_byte(output_fd, 0)
        pad = pad + 1
    // Boot signature: 0x55 0xAA
    write_byte(output_fd, 0x55)
    write_byte(output_fd, 0xAA)

    return 0

// ===========================================================================
// Flat binary format — for OS kernels, firmware, bare-metal, embedded
// ===========================================================================
// Produces a flat binary with no headers and no padding.
// Just code + data concatenated.
// Custom load address via /tmp/yilt_raw_base (decimal, default 0x100000).
// ===========================================================================

fn build_flat(ctx Ctx, output_fd int) int
    let code_len = ctx.code_len
    let data_len = ctx.data_len

    // Write code bytes
    let mut ci = 0
    while ci < code_len
        write_byte(output_fd, ctx.code_data[ci])
        ci = ci + 1

    // Write data bytes
    let mut di = 0
    while di < data_len
        write_byte(output_fd, ctx.data_data[di])
        di = di + 1

    return 0

// ===========================================================================
// RV32 (RISC-V 32-bit) support — target=4
// ===========================================================================
// RV32 uses the same instruction encoding as RV64 but with 32-bit registers.
// Key differences:
// - LW/SW (funct3=2) instead of LD/SD (funct3=3)
// - 4-byte stack slots instead of 8-byte
// - ELF flags: soft-float ABI
//
// For simplicity, RV32 reuses the RV64 codegen functions but with adjusted
// load/store width. The target is selected via /tmp/yilt_target_rv32.
// ===========================================================================

let RV32_F3_LW = 2  // 32-bit load
let RV32_F3_SW = 2  // 32-bit store

// rv32_ld: 32-bit load (LW instead of LD)
fn rv32_ld(ctx Ctx, rd int, rs1 int, offset int)
    rv_emit(ctx, rv_enc_i(RV_OP_LOAD, rd, RV32_F3_LW, rs1, offset))

// rv32_sd: 32-bit store (SW instead of SD)
fn rv32_sd(ctx Ctx, rs2 int, rs1 int, offset int)
    rv_emit(ctx, rv_enc_s(RV_OP_STORE, RV32_F3_SW, rs1, rs2, offset))

// RV32 uses the same cg_expr/cg_stmt/cg_function dispatch as RV64.
// The target field 4 maps to rv_* functions with rv32_ld/rv32_sd.
// For now, RV32 shares the RV64 codegen path (target==2).
// To fully support RV32, we'd need separate rv32_cg_* functions that use
// rv32_ld/rv32_sd and 4-byte stack slots.

// ===========================================================================
// RV32 (RISC-V 32-bit) full codegen — target=4
// ===========================================================================
// RV32 uses 32-bit registers and 4-byte stack slots.
// Key differences from RV64:
// - LW/SW (funct3=2) instead of LD/SD (funct3=3)
// - 4-byte stack slots (next_slot decrements by 4, not 8)
// - 8-byte alignment for stack (push/pop use 8 bytes)
// - Same instruction encoding (RV32I is a subset of RV64I)
// ===========================================================================

// RV32 push: SW rs, [sp, 4]; ADDI sp, sp, -8 (8-byte aligned, 4-byte data)
fn rv32_push(ctx Ctx, rs int)
    rv_addi(ctx, RV_SP, RV_SP, -8)
    rv32_sd(ctx, rs, RV_SP, 4)

// RV32 pop: LW rd, [sp, 4]; ADDI sp, sp, 8
fn rv32_pop(ctx Ctx, rd int)
    rv32_ld(ctx, rd, RV_SP, 4)
    rv_addi(ctx, RV_SP, RV_SP, 8)

// RV32 codegen dispatchers — mirror RV64 but with 4-byte slots

fn rv32_cg_expr(ctx Ctx, e Node)
    if e.kind == "int_lit"
        let val = parse_int(e.sval)
        rv_li(ctx, RV_A0, val)
        return
    if e.kind == "bool_true"
        rv_li(ctx, RV_A0, 1)
        return
    if e.kind == "bool_false"
        rv_li(ctx, RV_A0, 0)
        return
    if e.kind == "nil"
        rv_li(ctx, RV_A0, 0)
        return
    if e.kind == "float_lit"
        let val = parse_int(e.sval)
        rv_li(ctx, RV_A0, val)
        return
    if e.kind == "ident"
        let offset = cg_get_var_offset(ctx, e.sval)
        rv32_ld(ctx, RV_A0, RV_FP, offset)
        return
    if e.kind == "binary"
        rv32_cg_binary(ctx, e)
        return
    if e.kind == "unary"
        rv32_cg_unary(ctx, e)
        return
    if e.kind == "call"
        rv32_cg_call(ctx, e)
        return
    if e.kind == "string_lit"
        let data_off = ctx.data_len
        cg_add_string(ctx, e.sval)
        let auipc_pos = ctx.code_len
        rv_auipc(ctx, RV_A0, 0)
        rv_addi(ctx, RV_A0, RV_A0, 0)
        rv_add_fixup(ctx, auipc_pos, data_off)
        return
    if e.kind == "if_expr"
        rv32_cg_if_expr(ctx, e)
        return
    rv_li(ctx, RV_A0, 0)

fn rv32_cg_binary(ctx Ctx, e Node)
    let la = e.a
    let rb = e.b
    let op = e.sval

    if op == "and"
        rv32_cg_expr(ctx, la[0])
        rv32_push(ctx, RV_A0)
        rv32_cg_expr(ctx, rb[0])
        rv32_pop(ctx, RV_T0)
        rv_sltu(ctx, RV_A0, RV_ZERO, RV_A0)
        rv_sltu(ctx, RV_T0, RV_ZERO, RV_T0)
        rv_and(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "or"
        rv32_cg_expr(ctx, la[0])
        rv32_push(ctx, RV_A0)
        rv32_cg_expr(ctx, rb[0])
        rv32_pop(ctx, RV_T0)
        rv_sltu(ctx, RV_A0, RV_ZERO, RV_A0)
        rv_sltu(ctx, RV_T0, RV_ZERO, RV_T0)
        rv_or(ctx, RV_A0, RV_T0, RV_A0)
        return

    rv32_cg_expr(ctx, la[0])
    rv32_push(ctx, RV_A0)
    rv32_cg_expr(ctx, rb[0])
    rv32_pop(ctx, RV_T0)

    if op == "+"
        rv_add(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "-"
        rv_sub(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "*"
        rv_mul(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "/"
        rv_div(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "%"
        rv_rem(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "=="
        rv_sub(ctx, RV_T1, RV_T0, RV_A0)
        rv_sltu(ctx, RV_A0, RV_T1, 1)
        return
    if op == "!="
        rv_sub(ctx, RV_T1, RV_T0, RV_A0)
        rv_sltu(ctx, RV_A0, RV_ZERO, RV_T1)
        return
    if op == "<"
        rv_slt(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == ">"
        rv_slt(ctx, RV_A0, RV_A0, RV_T0)
        return
    if op == "<="
        rv_slt(ctx, RV_T1, RV_A0, RV_T0)
        rv_xori(ctx, RV_A0, RV_T1, 1)
        return
    if op == ">="
        rv_slt(ctx, RV_T1, RV_T0, RV_A0)
        rv_xori(ctx, RV_A0, RV_T1, 1)
        return
    if op == "&"
        rv_and(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "|"
        rv_or(ctx, RV_A0, RV_T0, RV_A0)
        return
    if op == "^"
        rv_xor(ctx, RV_A0, RV_T0, RV_A0)
        return
    rv_li(ctx, RV_A0, 0)

fn rv32_cg_unary(ctx Ctx, e Node)
    let operand = e.a[0]
    let op = e.sval
    if op == "-"
        rv32_cg_expr(ctx, operand)
        rv_sub(ctx, RV_A0, RV_ZERO, RV_A0)
        return
    if op == "!"
        rv32_cg_expr(ctx, operand)
        rv_sltu(ctx, RV_A0, RV_A0, 1)
        return
    if op == "~"
        rv32_cg_expr(ctx, operand)
        rv_xori(ctx, RV_A0, RV_A0, -1)
        return
    rv32_cg_expr(ctx, operand)

fn rv32_cg_call(ctx Ctx, e Node)
    let fa = e.a
    if fa[0].kind != "ident"
        rv_li(ctx, RV_A0, 0)
        return
    let fn_name = fa[0].sval

    if fn_name == "println" or fn_name == "print"
        let args = e.list
        if args.len() > 0
            let arg = args[0]
            if arg.kind == "string_lit"
                rv_cg_print_string_lit(ctx, arg.sval)
            else
                if arg.kind == "int_lit"
                    rv_li(ctx, RV_A0, parse_int(arg.sval))
                    rv_cg_print_int(ctx)
                else
                    if arg.kind == "bool_true"
                        rv_cg_print_string_lit(ctx, "true")
                    else
                        if arg.kind == "bool_false"
                            rv_cg_print_string_lit(ctx, "false")
                        else
                            rv32_cg_expr(ctx, arg)
                            rv_cg_print_int(ctx)
            if fn_name == "println"
                rv_cg_print_string_lit(ctx, "\n")
        return
    if fn_name == "len"
        let args = e.list
        if args.len() > 0
            rv32_cg_expr(ctx, args[0])
            rv32_ld(ctx, RV_A0, RV_A0, 0)
            return
        rv_li(ctx, RV_A0, 0)
        return

    // User-defined function call
    let args = e.list
    let nargs = args.len()
    let mut ai = nargs - 1
    while ai >= 0 and ai < 8
        rv32_cg_expr(ctx, args[ai])
        if ai == 1
            rv_mv(ctx, RV_A1, RV_A0)
        if ai == 2
            rv_mv(ctx, RV_A2, RV_A0)
        if ai == 3
            rv_mv(ctx, RV_A3, RV_A0)
        if ai == 4
            rv_mv(ctx, RV_A4, RV_A0)
        if ai == 5
            rv_mv(ctx, RV_A5, RV_A0)
        if ai == 6
            rv_mv(ctx, RV_A6, RV_A0)
        if ai == 7
            rv_mv(ctx, RV_A7, RV_A0)
        ai = ai - 1

    let jal_pos = ctx.code_len
    rv_jal(ctx, RV_RA, 0)
    let cidx = ctx.call_fixup_count
    ctx.call_fixups[cidx * 2] = jal_pos
    ctx.call_fixups[cidx * 2 + 1] = fn_name
    ctx.call_fixup_count = cidx + 1

fn rv32_cg_if_expr(ctx Ctx, e Node)
    rv_li(ctx, RV_A0, 0)

fn rv32_cg_stmt(ctx Ctx, s Node)
    if s.kind == "let_stmt"
        let va = s.a
        let init = va[0]
        if init.kind == "string_lit"
            ctx.var_types[s.sval] = "str"
        if init.kind == "int_lit"
            ctx.var_types[s.sval] = "int"
        if init.kind == "bool_true"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "bool_false"
            ctx.var_types[s.sval] = "bool"
        if init.kind == "ident"
            if ctx.var_types.has(init.sval)
                ctx.var_types[s.sval] = ctx.var_types[init.sval]
        rv32_cg_expr(ctx, init)
        let offset = cg_get_var_offset(ctx, s.sval)
        rv32_sd(ctx, RV_A0, RV_FP, offset)
        return
    if s.kind == "return"
        if s.a.has(0)
            let va = s.a
            rv32_cg_expr(ctx, va[0])
        if ctx.is_main
            if not s.a.has(0)
                rv_li(ctx, RV_A0, 0)
            rv_li(ctx, RV_A7, 93)
            rv_ecall(ctx)
        else
            rv32_emit_epilogue(ctx)
        return
    if s.kind == "expr_stmt"
        let ea = s.a
        rv32_cg_expr(ctx, ea[0])
        return
    if s.kind == "assign"
        let ea = s.a
        let vb = s.b
        let target = ea[0]
        if target.kind == "ident"
            rv32_cg_expr(ctx, vb[0])
            let offset = cg_get_var_offset(ctx, target.sval)
            rv32_sd(ctx, RV_A0, RV_FP, offset)
            return
        rv32_cg_expr(ctx, vb[0])
        return
    if s.kind == "if_stmt"
        rv32_cg_if(ctx, s)
        return
    if s.kind == "while_stmt"
        rv32_cg_while(ctx, s)
        return
    if s.kind == "for_stmt"
        if s.bval
            rv32_cg_for_range(ctx, s)
        return
    if s.kind == "assert_stmt"
        let ea = s.a
        rv32_cg_expr(ctx, ea[0])
        return

fn rv32_cg_if(ctx Ctx, s Node)
    let branches = s.list
    let mut end_jumps = {}
    let mut njumps = 0
    let mut bi = 0
    while bi < branches.len()
        let b = branches[bi]
        let ca = b.a
        rv32_cg_expr(ctx, ca[0])
        rv_beq(ctx, RV_A0, RV_ZERO, 0)
        let beq_next_pos = ctx.code_len - 4
        let block = b.b
        let mut si = 0
        while si < block.len()
            rv32_cg_stmt(ctx, block[si])
            si = si + 1
        let b_end_pos = ctx.code_len
        rv_jal(ctx, RV_ZERO, 0)
        end_jumps[njumps] = b_end_pos
        njumps = njumps + 1
        let next_target = ctx.code_len
        rv_patch_branch(ctx, beq_next_pos, next_target)
        bi = bi + 1
    if s.a.has(0)
        let eb = s.a
        let else_block = eb[0].list
        let mut j = 0
        while j < else_block.len()
            rv32_cg_stmt(ctx, else_block[j])
            j = j + 1
    let end_target = ctx.code_len
    let mut ji = 0
    while ji < njumps
        let jmp_pos = end_jumps[ji]
        rv_patch_jal(ctx, jmp_pos, end_target)
        ji = ji + 1

fn rv32_cg_while(ctx Ctx, s Node)
    let ea = s.a
    let cond = ea[0]
    let loop_start = ctx.code_len
    rv32_cg_expr(ctx, cond)
    rv_beq(ctx, RV_A0, RV_ZERO, 0)
    let beq_end_pos = ctx.code_len - 4
    let ld = ctx.loop_depth
    ctx.continue_targets[ld] = loop_start
    ctx.break_targets[ld] = beq_end_pos
    ctx.loop_depth = ld + 1
    let body = s.list
    let mut i = 0
    while i < body.len()
        rv32_cg_stmt(ctx, body[i])
        i = i + 1
    ctx.loop_depth = ld
    let b_loop_pos = ctx.code_len
    rv_jal(ctx, RV_ZERO, 0)
    rv_patch_jal(ctx, b_loop_pos, loop_start)
    let end_target = ctx.code_len
    rv_patch_branch(ctx, beq_end_pos, end_target)

fn rv32_cg_for_range(ctx Ctx, s Node)
    let la = s.a
    let rb = s.b
    let i_offset = cg_get_var_offset(ctx, s.sval)
    rv32_cg_expr(ctx, la[0])
    rv32_sd(ctx, RV_A0, RV_FP, i_offset)

    let loop_start = ctx.code_len
    rv32_ld(ctx, RV_A0, RV_FP, i_offset)
    rv32_cg_expr(ctx, rb[0])
    rv_mv(ctx, RV_T0, RV_A0)
    rv32_ld(ctx, RV_A0, RV_FP, i_offset)
    rv_bge(ctx, RV_A0, RV_T0, 0)
    let bge_end_pos = ctx.code_len - 4

    let ld = ctx.loop_depth
    ctx.continue_targets[ld] = loop_start
    ctx.break_targets[ld] = bge_end_pos
    ctx.loop_depth = ld + 1
    let body = s.list
    let mut i = 0
    while i < body.len()
        rv32_cg_stmt(ctx, body[i])
        i = i + 1
    ctx.loop_depth = ld

    rv32_ld(ctx, RV_A0, RV_FP, i_offset)
    rv_addi(ctx, RV_A0, RV_A0, 1)
    rv32_sd(ctx, RV_A0, RV_FP, i_offset)
    let b_loop_pos = ctx.code_len
    rv_jal(ctx, RV_ZERO, 0)
    rv_patch_jal(ctx, b_loop_pos, loop_start)
    let end_target = ctx.code_len
    rv_patch_branch(ctx, bge_end_pos, end_target)

// RV32 prologue: ADDI sp, sp, -total; SW ra, [sp, 0]; SW s0, [sp, 4]; ADDI s0, sp, total
fn rv32_emit_prologue(ctx Ctx) int
    let addi_sp_pos = ctx.code_len
    rv_addi(ctx, RV_SP, RV_SP, 0)
    rv32_sd(ctx, RV_RA, RV_SP, 0)
    rv32_sd(ctx, RV_FP, RV_SP, 4)
    let addi_fp_pos = ctx.code_len
    rv_addi(ctx, RV_FP, RV_SP, 0)
    return addi_sp_pos

// RV32 epilogue: LW ra, [sp, 0]; LW s0, [sp, 4]; ADDI sp, sp, total; RET
fn rv32_emit_epilogue(ctx Ctx)
    let frame_size = 0 - ctx.next_slot - 4
    let mut aligned = frame_size
    if aligned % 8 != 0
        aligned = aligned + (8 - (aligned % 8))
    let total = aligned + 8
    rv32_ld(ctx, RV_RA, RV_SP, 0)
    rv32_ld(ctx, RV_FP, RV_SP, 4)
    rv_addi(ctx, RV_SP, RV_SP, total)
    rv_ret(ctx)

fn rv32_cg_function(ctx Ctx, fn_decl Node, is_main bool)
    let fn_start = ctx.code_len
    let fn_name = fn_decl.sval
    ctx.fn_table[fn_name] = fn_start
    ctx.fn_count = ctx.fn_count + 1
    ctx.var_slots = {}
    ctx.next_slot = -4  // RV32: 4-byte slots
    ctx.var_types = {}

    let addi_sp_pos = rv32_emit_prologue(ctx)

    let params = fn_decl.a
    let mut pi = 0
    while pi < params.len() and pi < 8
        let param = params[pi]
        let local_offset = cg_get_var_offset(ctx, param.sval)
        rv32_sd(ctx, 10 + pi, RV_FP, local_offset)
        ctx.var_types[param.sval] = param.extra
        pi = pi + 1

    ctx.is_main = is_main
    let body = fn_decl.list
    let mut i = 0
    while i < body.len()
        rv32_cg_stmt(ctx, body[i])
        i = i + 1

    if is_main
        rv_li(ctx, RV_A0, 0)
        rv_li(ctx, RV_A7, 93)
        rv_ecall(ctx)
    else
        rv_li(ctx, RV_A0, 0)
        rv32_emit_epilogue(ctx)

    // Patch frame size (RV32: 4-byte slots, 8-byte alignment)
    let frame_size = 0 - ctx.next_slot - 4
    let mut aligned = frame_size
    if aligned % 8 != 0
        aligned = aligned + (8 - (aligned % 8))
    let total = aligned + 8
    let neg_total = 0 - total
    if total >= -2048 and total <= 2047
        let instr_sp = rv_enc_i(RV_OP_OP_IMM, RV_SP, RV_F3_ADDI, RV_SP, neg_total)
        ctx.code_data[addi_sp_pos] = instr_sp % 256
        ctx.code_data[addi_sp_pos + 1] = (instr_sp / 256) % 256
        ctx.code_data[addi_sp_pos + 2] = (instr_sp / 65536) % 256
        ctx.code_data[addi_sp_pos + 3] = (instr_sp / 16777216) % 256
        // Patch SW ra, [sp, 0]
        let sd_ra_pos = addi_sp_pos + 4
        let sd_ra_instr = rv_enc_s(RV_OP_STORE, RV32_F3_SW, RV_SP, RV_RA, 0)
        ctx.code_data[sd_ra_pos] = sd_ra_instr % 256
        ctx.code_data[sd_ra_pos + 1] = (sd_ra_instr / 256) % 256
        ctx.code_data[sd_ra_pos + 2] = (sd_ra_instr / 65536) % 256
        ctx.code_data[sd_ra_pos + 3] = (sd_ra_instr / 16777216) % 256
        // Patch SW s0, [sp, 4]
        let sd_s0_pos = sd_ra_pos + 4
        let sd_s0_instr = rv_enc_s(RV_OP_STORE, RV32_F3_SW, RV_SP, RV_FP, 4)
        ctx.code_data[sd_s0_pos] = sd_s0_instr % 256
        ctx.code_data[sd_s0_pos + 1] = (sd_s0_instr / 256) % 256
        ctx.code_data[sd_s0_pos + 2] = (sd_s0_instr / 65536) % 256
        ctx.code_data[sd_s0_pos + 3] = (sd_s0_instr / 16777216) % 256
        // Patch ADDI s0, sp, total
        let addi_fp_pos = sd_s0_pos + 4
        let addi_fp_instr = rv_enc_i(RV_OP_OP_IMM, RV_FP, RV_F3_ADDI, RV_SP, total)
        ctx.code_data[addi_fp_pos] = addi_fp_instr % 256
        ctx.code_data[addi_fp_pos + 1] = (addi_fp_instr / 256) % 256
        ctx.code_data[addi_fp_pos + 2] = (addi_fp_instr / 65536) % 256
        ctx.code_data[addi_fp_pos + 3] = (addi_fp_instr / 16777216) % 256
