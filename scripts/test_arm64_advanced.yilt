fn fact(n int) int
    if n <= 1
        return 1
    return n * fact(n - 1)

fn fib(n int) int
    if n < 2
        return n
    return fib(n - 1) + fib(n - 2)

fn main() int
    println(fact(5))
    println(fib(10))
    let mut i = 1
    let mut sum = 0
    while i <= 10
        sum = sum + i
        i = i + 1
    println(sum)
    return 0
