// Range-for with function call in bounds and mutable variables
pub fn get_limit()
    return 5

fn main()
    // Function call as upper bound
    for i in 0..get_limit()
        print(i)

    // Range creating a table
    let mut t = {}
    for i in 0..4
        t[i] = i * i
    for i in 0..4
        print(t[i])

    // Range with arithmetic in bounds
    for i in 1..3 + 2
        print(i)
