fn main()
    let result = safe_divide(10, 2)
    let result2 = safe_divide(10, 0)

fn safe_divide(a, b)
    if b == 0
        return nil
    return a / b

fn may_fail(x)
    if x < 0
        return nil
    return x * 2

fn chain_errors()
    let a = may_fail(5)?
    let b = may_fail(a)?
    return b
